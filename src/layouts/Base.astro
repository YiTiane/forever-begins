---
/**
 * Base.astro · 全站基础布局（v0.4 完整 SEO + JSON-LD Event + OG/Twitter · §1.1.13）
 *
 * 当前职责：
 *   ① 渲染 <FontFaces /> 组件 → 8 条 base-aware @font-face 注入 head（v0.2 起）
 *   ② <head> 注入 2 条字体 preload（cormorant-italic + noto-serif-sc-light）
 *   ③ frontmatter `import '@/styles/global.css'` —— **全站样式入口**（v0.3 §1.1.12）：
 *      Tailwind v4 base + src/styles/reset.css + src/styles/tokens.css + 7 个 helper class
 *   ④ **完整 SEO meta**（v0.4 §1.1.13）：
 *      - charset / viewport (含 viewport-fit=cover for iOS 刘海) / generator / title / description
 *      - link rel=canonical（基于 Astro.site + Astro.url.pathname 一份斜杠归一）
 *      - theme-color 固定 #FAF6EC paper，保留婚礼站浅纸面设计
 *      - color-scheme: light（v1.83：禁止 iOS / Safari 夜间自动切 dark palette）
 *      - robots（noindex Prop 用于 dev-only 路由）
 *   ⑤ **Open Graph + Twitter Card**（v0.4）：
 *      - og:* 8 条（type/title/description/url/image[+w/h/alt]/locale/site_name）
 *      - twitter:card=summary_large_image + 标题/描述/图同 OG
 *      - 默认图源为同源 `/share/wechat-card-v1.jpg`：无 JS-SDK 条件下优先保证
 *        微信抓取稳定；改图时换文件名而不是 query，绕开微信缓存
 *   ⑥ **JSON-LD Event schema**（v0.4）：
 *      - @type: SocialEvent · Schema.org 推荐 · Google Rich Results 支持
 *      - 婚礼日期 2026-06-14T19:00 (UTC+8) → 23:00 · 二道桥大剧院 · CN/新疆/乌鲁木齐
 *      - organizer 双 Person（杨倚天 & 希尔娜依）
 *      - eventStatus: EventScheduled · eventAttendanceMode: OfflineEventAttendanceMode
 *   ⑦ <slot /> 留给页面
 *   ⑧ noindex Prop —— 与 astro.config.mjs sitemap.filter 配合形成 dev-only 路由双重防护
 *
 * 历史修订：
 *   v0.2（v1.24）：字体单源迁移到 <FontFaces />，URL 由 import.meta.env.BASE_URL 模板生成
 *   v0.3（v1.30）：接入 global.css，token / reset / helper 系统首次接进生产 root
 *   v0.4（v1.31）：完整 SEO + canonical + OG + Twitter + JSON-LD Event；OG 图源走 cdnUrl helper
 *
 * preload URL 与 favicon URL 均经 base.replace(/\/$/, '') 归一化，
 * 保证 base 写 '/forever-begins' 或 '/forever-begins/' 都得到一份斜杠。
 *
 * crossorigin 属性：preload font 必须含 crossorigin（即使同源，规范要求）；
 * 否则浏览器会重新发起一次跨域请求覆盖 preload 命中。
 */
import FontFaces from "@/components/FontFaces.astro";
import CdnEarlyProbe from "@/components/CdnEarlyProbe.astro";

// v0.3 §1.1.12：全站样式入口（Tailwind v4 base + reset + tokens + helper class）
// 顺序契约 / 约束 / 缺哪条会怎么坏 见 src/styles/global.css 文件头注释
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  /**
   * 禁止搜索引擎索引（v1.24 新增）。
   * 用于开发期路由（如 /dev-fonts/），与 astro.config.mjs 的 sitemap.filter 配合
   * 形成"sitemap 不收录 + 单页 noindex"双重防护。
   */
  noindex?: boolean;
  /**
   * 页面级 OG 图片覆盖（v0.4 新增）。
   * 不传则走默认的同源微信方图 `/share/wechat-card-v1.jpg`。
   * 用例：未来 Cover/Story/Cats 等章节如有专属 OG 图可单独覆盖。
   */
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  /**
   * 抑制 OG / Twitter card 与 JSON-LD Event schema 输出（v0.5 新增）。
   * 用于 dev-only 路由（/dev-fonts/）：noindex + sitemap.filter 已防搜索收录，
   * 但社交分享预览（微信 / Twitter card / Slack unfurl）会**不顾 robots** 直接抓 head。
   * 此 Prop 让 Base 不再吐 og:* / twitter:* / JSON-LD —— 即便 dev URL 被分享，
   * 抓不到任何婚礼信息，也不会把开发页伪装成婚礼站。
   * 真页面（Cover / Story / Cats / Details）保持默认 false，正常出 OG/JSON-LD。
   */
  suppressSocialMeta?: boolean;
}

const {
  title = "杨倚天 & 希尔娜依 · 二〇二六年六月十四日 · 永恒之始",
  description = "我们无法判断一个瞬间的价值，直至它变成回忆。",
  lang = "zh-CN",
  noindex = false,
  ogImage,
  ogImageWidth = 800,
  ogImageHeight = 800,
  suppressSocialMeta = false,
} = Astro.props;

// import.meta.env.BASE_URL 是否带尾斜杠取决于 astro.config.mjs 中 base 的写法
// （'/forever-begins' → 不带 / · '/forever-begins/' → 带 /）。
// 用 normalize 兜底保证后续拼接 `${base}/foo` 永远是 '/forever-begins/foo' 一份斜杠。
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// canonical URL —— Astro.site (https://yitiane.github.io) + Astro.url.pathname
// （Astro 自动包含 base 前缀；URL 构造器去重斜杠）。
// 注意：Astro.site 在 astro.config.mjs 中已配；如未配会抛 build 警告。
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

// OG 主图：默认同源微信分享卡。没有微信 JS-SDK 时，同源 + 版本化文件名
// 比远程 CDN / query 参数更稳定；更换图时新建 wechat-card-vN.jpg。
const defaultOgImage = new URL(`${base}/share/wechat-card-v1.jpg`, Astro.site)
  .href;
const finalOgImage = ogImage ?? defaultOgImage;

// JSON-LD Event schema · 婚礼是 SocialEvent (Schema.org) 子类型
// Google Rich Results / Apple Mail / 微信文档预览均支持。
// 时间用 ISO 8601 含时区（+08:00 = Asia/Urumqi 实质等同 +06:00 但乌鲁木齐市内
// 通用使用北京时间 +08:00）。
const eventSchema = {
  "@context": "https://schema.org",
  "@type": "SocialEvent",
  name: "杨倚天 & 希尔娜依 · 婚礼",
  description: "诚邀构成我们生命不同经纬的你，共同见证这份回忆的开始。",
  startDate: "2026-06-14T19:00:00+08:00",
  endDate: "2026-06-14T23:00:00+08:00",
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: {
    "@type": "Place",
    name: "二道桥大剧院",
    address: {
      "@type": "PostalAddress",
      streetAddress: "二道桥民俗风情一条街",
      addressLocality: "乌鲁木齐",
      addressRegion: "新疆维吾尔自治区",
      postalCode: "830094",
      addressCountry: "CN",
    },
  },
  organizer: [
    { "@type": "Person", name: "杨倚天" },
    { "@type": "Person", name: "希尔娜依" },
  ],
  url: canonicalURL,
  image: finalOgImage,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    {/* —— 基础 meta —— */}
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    {/* —— 主题色固定浅纸面（v1.83：保留设计，不随系统 dark mode 切黑）—— */}
    <meta name="theme-color" content="#FAF6EC" />
    <meta name="color-scheme" content="light" />

    {
      /* —— Open Graph + Twitter Card + JSON-LD（v0.5：suppressSocialMeta=true 时整组跳过）—— */
    }
    {
      !suppressSocialMeta && (
        <>
          <meta property="og:type" content="website" />
          <meta property="og:title" content={title} />
          <meta property="og:description" content={description} />
          <meta property="og:url" content={canonicalURL} />
          <meta property="og:image" content={finalOgImage} />
          <meta property="og:image:width" content={String(ogImageWidth)} />
          <meta property="og:image:height" content={String(ogImageHeight)} />
          <meta
            property="og:image:alt"
            content="杨倚天 & 希尔娜依 · 二〇二六年六月十四日"
          />
          <meta property="og:locale" content="zh_CN" />
          <meta property="og:site_name" content="Forever Begins · 永恒之始" />

          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:title" content={title} />
          <meta name="twitter:description" content={description} />
          <meta name="twitter:image" content={finalOgImage} />
        </>
      )
    }

    {/* —— 字体单一源 + 2 条 preload（v0.2 base-aware）—— */}
    <FontFaces />
    {
      /* 关键字体 preload —— DESIGN §2.3.7 / PLAN §1.1.9 契约：
        仅 cormorant-italic + noto-serif-sc-light，合计 ≈ 188KB，目标 < 200KB。
        其他 6 个字体走 @font-face + font-display: swap 自然加载。 */
    }
    <link
      rel="preload"
      href={`${base}/fonts/cormorant-italic.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={`${base}/fonts/noto-serif-sc-light.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />

    {/* —— favicon —— */}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="alternate icon" href={`${base}/favicon.ico`} />

    {
      /* —— CDN 早期探测（v0.5 §1.1.15 上车）：
         主路径（jsDelivr）健康时零开销；故障时一次切全页 srcset 到 backup。
         即使本页无 <CdnImage>（如 dev-fonts），probe 仍是单次 HEAD HEAD，无害。 */
    }
    <CdnEarlyProbe />

    {
      /* —— JSON-LD Event schema · 让 Google / Apple / 微博 / 企业微信抓婚礼信息 ——
         （v0.5：suppressSocialMeta=true 时跳过；与 OG/Twitter 同档抑制） */
    }
    {
      !suppressSocialMeta && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(eventSchema)}
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
