---
/**
 * GlobeBeat.astro · §2.B 地球高潮 · Vercel static globe
 *   v0.3（Vercel 静态版）
 *
 * 数据流（DESIGN §15.1 单一源）：
 *   - poem lines / kind=globe 来自 src/content/story-poem/main.json beat 11
 *   - from / to / distanceKm / routes 来自 src/content/journey/long-distance.json
 *   - 两源在本组件 props 与 collection 处合流，不在 React 岛里再 fetch
 *
 * 渲染机制：
 *   - 外层 .globe-beat 给 hash 锚 #beat-11-heading（与 PoemBeat 同款契约）
 *   - Vercel 静态版不 import React/R3F/Three，不 hydrate，不响应拖拽；
 *     构建时把 Natural Earth 1:110m 陆地轮廓投影成 inline SVG 静态地球
 *   - 内层 .globe-stage：Vercel 静态版全断点自然流式，不保留原滚动 sticky spacer
 *   - 文字浮卡 .globe-text 居中或贴底，带 backdrop-blur，与 vignette 同语
 *   - 静态地球图形 + 主/次路线 + 文字卡是正式体验，不是错误页
 *   - v1.87：GlobeDistanceScene 不只画最长距离；routes[] 渲染全部去过地点
 *     连线，乌鲁木齐 ↔ 墨尔本作为 primary 更粗且有轻微呼吸闪烁，其它路线
 *     用细 sage 线作为旅行网络背景
 *
 * a11y：
 *   - section aria-labelledby 指向 sr-only h3（与 PoemBeat 同款契约）
 *   - canvas 容器 role="img" aria-label 含距离数字 / 城市名
 *   - 动效信息（脉冲 / 弧线）不向 AT 暴露——AT 只朗读 alt 文字
 *
 */
import { getCollection } from "astro:content";
import { geoDistance, geoInterpolate, geoOrthographic, geoPath } from "d3-geo";
import { NATURAL_EARTH_LAND_110M } from "@/lib/story/naturalEarthLand110m";
import type {
  Feature,
  FeatureCollection,
  LineString,
  Point,
  Polygon,
  Position,
} from "geojson";

interface Props {
  /** main.json beat 11 的 lines（"松开刹那，" "才见已过万重山。"） */
  lines: readonly string[];
}

const { lines } = Astro.props;

const journeyEntries = await getCollection("journey");
const longDistance = journeyEntries.find((e) => e.id === "long-distance");
if (!longDistance) {
  throw new Error(
    "GlobeBeat.astro: src/content/journey/long-distance.json missing — schema 已严约束 from/to/distanceKm",
  );
}
const { from, to, distanceKm, routes = [] } = longDistance.data;
if (!from || !to || distanceKm === undefined) {
  throw new Error(
    "GlobeBeat.astro: long-distance.json 缺 from/to/distanceKm —— DESIGN §15.1 单一源契约",
  );
}

// 距离格式化：10755 → "10,755"
const distanceLabel = distanceKm.toLocaleString("en-US");

const headingId = "beat-11-heading";
const ariaHeadingId = "beat-11-aria-heading";

// v1.74 文案收口：用户审计要求"10,755 公里"前加"我们最远时相距"
// 完整句："我们最远时相距 10,755 公里"。aria-label 同步用同款叙述，避免
// AT 朗读到的"球面大圆距离"等技术语让叙事失味。
const distancePrefix = "我们最远时相距";
const routeLabel =
  routes.length > 1 ? `，并连起重庆、合肥、杭州、新加坡等共同走过的地方` : "";
const ariaLabel = `${from.name} ↔ ${to.name}，${distancePrefix} ${distanceLabel} 公里${routeLabel}`;
const globeProps = {
  from: { lat: from.lat, lng: from.lng },
  to: { lat: to.lat, lng: to.lng },
  routes: routes.map((route) => ({
    from: {
      name: route.from.name,
      lat: route.from.lat,
      lng: route.from.lng,
    },
    to: {
      name: route.to.name,
      lat: route.to.lat,
      lng: route.to.lng,
    },
    kind: route.kind,
  })),
};

type ProjectedPoint = readonly [x: number, y: number];

const GLOBE_CENTER = {
  lng: 113,
  lat: 5,
};
const GLOBE_RADIUS = 48;

function fmt(value: number): string {
  return value.toFixed(2).replace(/\.?0+$/, "");
}

const globeProjection = geoOrthographic()
  .rotate([-GLOBE_CENTER.lng, -GLOBE_CENTER.lat])
  .translate([50, 50])
  .scale(GLOBE_RADIUS)
  .clipAngle(90)
  .precision(0.25);
const globePath = geoPath(globeProjection);
const centerPosition: Position = [GLOBE_CENTER.lng, GLOBE_CENTER.lat];

const landFeatures: Feature<Polygon>[] = NATURAL_EARTH_LAND_110M.map(
  (ring) => ({
    type: "Feature",
    properties: {},
    geometry: {
      type: "Polygon",
      coordinates: [ring.map(([lng, lat]) => [lng, lat] satisfies Position)],
    },
  }),
);
const landCollection: FeatureCollection<Polygon> = {
  type: "FeatureCollection",
  features: landFeatures,
};
const staticLandPath = globePath(landCollection) ?? "";

function buildGreatCirclePath(
  start: { lng: number; lat: number },
  end: { lng: number; lat: number },
  steps = 72,
): string {
  const interpolate = geoInterpolate(
    [start.lng, start.lat],
    [end.lng, end.lat],
  );
  const coordinates = Array.from(
    { length: steps + 1 },
    (_, index) => interpolate(index / steps) as Position,
  );
  const feature: Feature<LineString> = {
    type: "Feature",
    properties: {},
    geometry: { type: "LineString", coordinates },
  };
  return globePath(feature) ?? "";
}

function projectVisiblePoint(lng: number, lat: number): ProjectedPoint | null {
  const position: Position = [lng, lat];
  if (geoDistance(centerPosition, position) > Math.PI / 2 + 0.02) return null;
  const feature: Feature<Point> = {
    type: "Feature",
    properties: {},
    geometry: { type: "Point", coordinates: position },
  };
  const path = globePath.centroid(feature);
  if (!Number.isFinite(path[0]) || !Number.isFinite(path[1])) return null;
  return [path[0], path[1]];
}

const staticRoutes = globeProps.routes.map((route) => ({
  kind: route.kind,
  path: buildGreatCirclePath(route.from, route.to),
  from: projectVisiblePoint(route.from.lng, route.from.lat),
  to: projectVisiblePoint(route.to.lng, route.to.lat),
}));
---

<section
  class="globe-beat"
  id={headingId}
  data-beat-id="11"
  data-kind="globe"
  aria-labelledby={ariaHeadingId}
>
  <div class="globe-stage">
    <h3 id={ariaHeadingId} class="sr-only">第 11 段 · {lines[0]}</h3>

    <div class="globe-canvas" role="img" aria-label={ariaLabel}>
      <div
        class="globe-canvas-root"
        data-globe-motion-root
        data-motion-tier="static"
        data-motion-reason="vercel-static"
        data-progress="1.000"
      >
        <div class="globe-static-scene" aria-hidden="true">
          <div class="globe-static-orb">
            <svg
              class="globe-static-routes"
              viewBox="0 0 100 100"
              focusable="false"
            >
              <defs>
                <clipPath id="static-globe-clip">
                  <circle cx="50" cy="50" r={GLOBE_RADIUS}></circle>
                </clipPath>
                <radialGradient
                  id="static-globe-water"
                  cx="32%"
                  cy="24%"
                  r="78%"
                >
                  <stop offset="0%" stop-color="#496b3b"></stop>
                  <stop offset="58%" stop-color="#10251b"></stop>
                  <stop offset="100%" stop-color="#10251b"></stop>
                </radialGradient>
                <radialGradient
                  id="static-globe-limb"
                  cx="32%"
                  cy="24%"
                  r="82%"
                >
                  <stop offset="55%" stop-color="#000000" stop-opacity="0"
                  ></stop>
                  <stop offset="100%" stop-color="#000000" stop-opacity="0.06"
                  ></stop>
                </radialGradient>
              </defs>
              <circle class="static-water" cx="50" cy="50" r={GLOBE_RADIUS}
              ></circle>
              <g clip-path="url(#static-globe-clip)">
                <path class="static-land" d={staticLandPath}></path>
                <circle class="static-limb" cx="50" cy="50" r={GLOBE_RADIUS}
                ></circle>
                {
                  staticRoutes.map(
                    (route) =>
                      route.path && (
                        <path
                          class={`route ${route.kind === "primary" ? "primary" : "secondary"}`}
                          d={route.path}
                        />
                      ),
                  )
                }
                {
                  staticRoutes.flatMap((route) =>
                    [route.from, route.to]
                      .filter((point): point is ProjectedPoint =>
                        Boolean(point),
                      )
                      .map(([x, y]) => (
                        <circle
                          class={`point ${route.kind === "primary" ? "primary-point" : ""}`}
                          cx={fmt(x)}
                          cy={fmt(y)}
                          r={route.kind === "primary" ? "2.4" : "1.4"}
                        />
                      )),
                  )
                }
              </g>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div class="globe-text">
      <p class="globe-line cn-kaishu">
        {
          lines.map((line, i) => (
            <span class={`globe-text-line line-${i}`}>{line}</span>
          ))
        }
      </p>
      <p class="globe-distance">
        <span class="globe-cities">{from.name} ↔ {to.name}</span>
        <span class="globe-km">
          <span class="globe-km-prefix">{distancePrefix}</span>
          <span class="globe-km-num">{distanceLabel}</span>
          <span class="globe-km-unit">公里</span>
        </span>
      </p>
    </div>

    <noscript>
      <p class="globe-fallback">
        {from.name} ↔ {to.name}，{distancePrefix}
        {distanceLabel} 公里。
      </p>
    </noscript>
  </div>
</section>

<style>
  .globe-beat {
    position: relative;
    /* 与 .poem-beat 同款 hash-anchor 契约 */
    scroll-margin-top: 0;
    min-height: auto;
    padding: clamp(1.25rem, 3vh, 2.25rem) 0 clamp(1.5rem, 4vh, 3rem);
  }

  /* Vercel 静态版：不再保留原 R3F sticky spacer。地球作为自然流式静态章节，
     刷新/深链时直接出现完整地球 + 文字卡，避免 #beat-11 落到前一张照片尾部。 */
  .globe-stage {
    position: relative;
    top: auto;
    min-height: min(92svh, 900px);
    overflow: visible;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr auto;
    /* row 1 (canvas) 居中、row 2 (card) 下边界自适应；都横向居中 */
    justify-items: center;
    align-items: stretch;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(1.25rem, 3vh, 2rem) 1.5rem clamp(1rem, 2.5vh, 1.5rem);
    gap: 1rem;
    box-sizing: border-box;
  }

  .globe-stage .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* canvas 容器：占第一行 1fr，自适应剩余高度；不再做 overlay 1/1 */
  .globe-canvas {
    width: 100%;
    height: 100%;
    min-height: min(70vh, 760px);
  }

  /* Vercel 静态版：不加载 R3F；root 只承载 inline SVG 静态地球。 */
  .globe-canvas :global(.globe-canvas-root) {
    position: relative;
    width: 100%;
    height: 100%;
    /* 无背景 → 透明 alpha；让站点 page 背景透出，与 §2 章节呼吸一致 */
  }

  .globe-static-scene {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }
  .globe-static-orb {
    position: relative;
    width: min(76vh, 74vw, 760px);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    background: #10251b;
    box-shadow:
      inset 0.9rem 1rem 2rem rgba(238, 229, 186, 0.1),
      0 1.25rem 2.6rem rgba(53, 71, 45, 0.14);
  }
  .globe-static-routes {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .globe-static-routes .static-water {
    fill: url("#static-globe-water");
  }
  .globe-static-routes .static-land {
    fill: rgba(78, 118, 58, 0.9);
    stroke: rgba(238, 230, 187, 0.16);
    stroke-width: 0.06;
  }
  .globe-static-routes .static-limb {
    display: none;
  }
  .globe-static-routes .route {
    fill: none;
    stroke: rgba(255, 247, 207, 0.88);
    stroke-width: 0.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .globe-static-routes .route.primary {
    stroke: #e7c34d;
    stroke-width: 1.65;
  }
  .globe-static-routes .point {
    fill: rgba(255, 249, 218, 0.94);
  }
  .globe-static-routes .primary-point {
    fill: #e7c34d;
    stroke: rgba(31, 25, 7, 0.48);
    stroke-width: 0.35;
  }

  /* 文字卡：v1.79 起占 grid 第二行 auto，不再 overlay 在 canvas 之上。
     卡片宽度仍收紧到 380px 让构图有呼吸感；不再需要 backdrop-blur 因为不
     压在 globe 之上（保留半透明背景给 sage 主题轻微离屏感，但浓度降低）。 */
  .globe-text {
    width: min(380px, 84%);
    padding: 0.85rem 1.25rem;
    background: rgba(245, 240, 230, 0.62);
    border-radius: var(--radius-sm);
    text-align: center;
    color: var(--c-olive-ink);
  }

  .globe-line {
    margin: 0 0 0.85rem;
    font-size: 1.5rem;
    line-height: 1.85;
    font-weight: 300;
  }
  .globe-text-line {
    display: block;
  }

  .globe-distance {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--c-sage-deep);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: center;
  }

  .globe-cities {
    color: var(--c-sage);
    font-weight: 400;
    letter-spacing: 0.04em;
  }

  .globe-km {
    color: var(--c-honey, #c69d4e);
    font-size: 1.65rem;
    line-height: 1.2;
    font-weight: 400;
    /* v1.74：prefix + num + unit 横向排成一句，让 "我们最远时相距 10,755 公里"
       视觉上是连贯的一行；过窄屏 wrap 自然换行（flex-wrap 让标签换行不破坏对齐） */
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.35em;
  }
  .globe-km-prefix {
    /* prefix "我们最远时相距" —— 比数字克制，sage 色让数字自己抓眼 */
    font-size: 1rem;
    color: var(--c-sage);
    letter-spacing: 0.04em;
    /* 与数字之间留一个字宽 */
    margin-right: 0.05em;
  }
  .globe-km-num {
    /* 数字 cn-kaishu 不合适——保持站点 default 衬线/sans 字族 */
    /* 数字 tabular 防 CountUp（如果将来加）抖动 */
    font-variant-numeric: tabular-nums;
  }
  .globe-km-unit {
    font-size: 1rem;
    color: var(--c-sage);
  }
  /* v1.79：grid 不再 1×1 overlay；fallback 直接占 row 1 (canvas 位置) 居中 */
  .globe-fallback {
    color: var(--c-olive-ink);
    text-align: center;
    align-self: center;
  }

  /* portrait（小平板 / 大手机竖屏）：自然流式下收紧高度 */
  @media (max-width: 899px) {
    .globe-beat {
      min-height: auto;
    }
    .globe-stage {
      min-height: 80vh;
      padding-block: clamp(2rem, 6vh, 4rem);
    }
    .globe-canvas {
      min-height: 60vh;
    }
  }

  /* compact（≤540 phone）：进一步缩，stage padding 更紧 */
  @media (max-width: 540px) {
    .globe-stage {
      padding: 1rem 0.75rem;
      gap: 1rem;
    }
    .globe-canvas {
      min-height: 50vh;
    }
    .globe-line {
      font-size: 1.25rem;
    }
    .globe-km {
      font-size: 1.4rem;
    }
  }
</style>
