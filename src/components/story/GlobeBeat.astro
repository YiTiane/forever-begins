---
/**
 * GlobeBeat.astro · §2.B 地球高潮 · motion-tier loader + GlobeDistanceScene
 *   v0.2（Phase 2 §2.B · v2.12 low-end hardening）
 *
 * 数据流（DESIGN §15.1 单一源）：
 *   - poem lines / kind=globe 来自 src/content/story-poem/main.json beat 11
 *   - from / to / distanceKm / routes 来自 src/content/journey/long-distance.json
 *   - 两源在本组件 props 与 collection 处合流，不在 React 岛里再 fetch
 *
 * 渲染机制：
 *   - 外层 .globe-beat 给 hash 锚 #beat-11-heading（与 PoemBeat 同款契约）
 *   - v2.12：先加载轻量 globeMotionLoader，同步判断 full/lite/static motion tier；
 *     static 不 import React/R3F/Three，直接展示 HTML/CSS 静态地球与路线网络
 *   - full/lite 进入视口后动态 import GlobeDistanceScene；R3F root 与真实 canvas
 *     都显式 100% sizing；hash 深链由 StoryPoemScroller 写 data-initial-progress
 *     并派发 globe:set-progress
 *   - 内层 .globe-stage：wide 模式 sticky 100vh / portrait 自然流式
 *   - 文字浮卡 .globe-text 居中或贴底，带 backdrop-blur，与 vignette 同语
 *   - static/reduced-motion：正式静态地球图形 + 主/次路线 + 文字卡，不是错误页
 *   - v1.87：GlobeDistanceScene 不只画最长距离；routes[] 渲染全部去过地点
 *     连线，乌鲁木齐 ↔ 墨尔本作为 primary 更粗且有轻微呼吸闪烁，其它路线
 *     用细 sage 线作为旅行网络背景
 *
 * a11y：
 *   - section aria-labelledby 指向 sr-only h3（与 PoemBeat 同款契约）
 *   - canvas 容器 role="img" aria-label 含距离数字 / 城市名
 *   - 动效信息（脉冲 / 弧线）不向 AT 暴露——AT 只朗读 alt 文字
 *
 * NOT in this batch（v0.2 留刀）：
 *   - 2K 水彩贴图 globe-watercolor-2k.jpg（misc CDN 仓 Phase 3 资产 push 后接）
 *   - Bloom + Vignette + ToneMapping postprocessing
 *   - 距离数字 CountUp（简化先静态渲染；motion polish 批接 IO + raf ease-out）
 *   - 城市标签 3D <Html> 锚定（先用 2D 侧栏避免 reflow / a11y 复杂度）
 */
import { getCollection } from "astro:content";

interface Props {
  /** main.json beat 11 的 lines（"松开刹那，" "才见已过万重山。"） */
  lines: readonly string[];
}

const { lines } = Astro.props;

const journeyEntries = await getCollection("journey");
const longDistance = journeyEntries.find((e) => e.id === "long-distance");
if (!longDistance) {
  throw new Error(
    "GlobeBeat.astro: src/content/journey/long-distance.json missing — schema 已严约束 from/to/distanceKm",
  );
}
const { from, to, distanceKm, routes = [] } = longDistance.data;
if (!from || !to || distanceKm === undefined) {
  throw new Error(
    "GlobeBeat.astro: long-distance.json 缺 from/to/distanceKm —— DESIGN §15.1 单一源契约",
  );
}

// 距离格式化：10755 → "10,755"
const distanceLabel = distanceKm.toLocaleString("en-US");

const headingId = "beat-11-heading";
const ariaHeadingId = "beat-11-aria-heading";

// v1.74 文案收口：用户审计要求"10,755 公里"前加"我们最远时相距"
// 完整句："我们最远时相距 10,755 公里"。aria-label 同步用同款叙述，避免
// AT 朗读到的"球面大圆距离"等技术语让叙事失味。
const distancePrefix = "我们最远时相距";
const routeLabel =
  routes.length > 1 ? `，并连起重庆、合肥、杭州、新加坡等共同走过的地方` : "";
const ariaLabel = `${from.name} ↔ ${to.name}，${distancePrefix} ${distanceLabel} 公里${routeLabel}`;
const globeProps = {
  from: { lat: from.lat, lng: from.lng },
  to: { lat: to.lat, lng: to.lng },
  routes: routes.map((route) => ({
    from: {
      name: route.from.name,
      lat: route.from.lat,
      lng: route.from.lng,
    },
    to: {
      name: route.to.name,
      lat: route.to.lat,
      lng: route.to.lng,
    },
    kind: route.kind,
  })),
};
---

<script>
  import "@/components/story/globeMotionLoader";
</script>

<section
  class="globe-beat"
  id={headingId}
  data-beat-id="11"
  data-kind="globe"
  aria-labelledby={ariaHeadingId}
>
  <div class="globe-stage">
    <h3 id={ariaHeadingId} class="sr-only">第 11 段 · {lines[0]}</h3>

    <div class="globe-canvas" role="img" aria-label={ariaLabel}>
      <div
        class="globe-canvas-root"
        data-globe-motion-root
        data-motion-tier="pending"
        data-motion-reason="pending"
        data-progress="0.000"
        data-globe-props={JSON.stringify(globeProps)}
      >
        <div class="globe-static-scene" aria-hidden="true">
          <div class="globe-static-orb">
            <span class="globe-static-land land-a"></span>
            <span class="globe-static-land land-b"></span>
            <span class="globe-static-land land-c"></span>
            <svg
              class="globe-static-routes"
              viewBox="0 0 100 100"
              focusable="false"
            >
              <path class="route secondary" d="M32 41 C42 28 54 35 63 29"
              ></path>
              <path class="route secondary" d="M47 33 C54 43 59 52 69 58"
              ></path>
              <path class="route secondary" d="M42 49 C50 39 56 42 62 47"
              ></path>
              <path class="route secondary" d="M36 36 C50 42 61 48 73 44"
              ></path>
              <path class="route primary" d="M34 34 C54 8 75 52 70 72"></path>
              <circle class="point primary-point" cx="34" cy="34" r="2.5"
              ></circle>
              <circle class="point primary-point" cx="70" cy="72" r="2.5"
              ></circle>
              <circle class="point" cx="48" cy="55" r="1.5"></circle>
              <circle class="point" cx="61" cy="43" r="1.5"></circle>
              <circle class="point" cx="72" cy="44" r="1.5"></circle>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div class="globe-text">
      <p class="globe-line cn-kaishu">
        {
          lines.map((line, i) => (
            <span class={`globe-text-line line-${i}`}>{line}</span>
          ))
        }
      </p>
      <p class="globe-distance">
        <span class="globe-cities">{from.name} ↔ {to.name}</span>
        <span class="globe-km">
          <span class="globe-km-prefix">{distancePrefix}</span>
          <span class="globe-km-num">{distanceLabel}</span>
          <span class="globe-km-unit">公里</span>
        </span>
      </p>
    </div>

    <noscript>
      <p class="globe-fallback">
        {from.name} ↔ {to.name}，{distancePrefix}
        {distanceLabel} 公里。
      </p>
    </noscript>
  </div>
</section>

<style>
  .globe-beat {
    position: relative;
    /* 与 .poem-beat 同款 hash-anchor 契约 */
    scroll-margin-top: 0;
    /* wide 模式给 sticky 100vh 一段 spacer，让滚动有"经过地球"的节奏；
       portrait/compact 退化为自然高度（在 media query 内覆盖） */
    min-height: 130vh;
  }

  /* v1.79（v1.78 audit P2-3 修）：grid 1×1 全 overlay → grid 行 1fr + auto，
     globe canvas 拿 1fr 自适应高度，文字卡 .globe-text 独占第二行 auto。
     这样卡片不再压在球面上，端点 / 弧线 / 球体下缘都有自己的"安全区"，文字
     卡有自己的"安全区"——一个真正的 stage solver，而不是靠 margin-bottom
     的 overlay workaround。
     副作用：globe canvas 的可用高度 = 100vh - card 高度 - padding；
     ResponsiveCamera 的 z 自动按 canvas 实尺寸算，无需显式调整。 */
  .globe-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr auto;
    /* row 1 (canvas) 居中、row 2 (card) 下边界自适应；都横向居中 */
    justify-items: center;
    align-items: stretch;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.5rem 1.25rem;
    gap: 1rem;
    box-sizing: border-box;
  }

  .globe-stage .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* canvas 容器：占第一行 1fr，自适应剩余高度；不再做 overlay 1/1 */
  .globe-canvas {
    width: 100%;
    height: 100%;
    min-height: 0; /* 允许 grid 1fr 收缩到比子内容小（canvas 不会限制其父） */
  }

  /* v2.12：.globe-canvas-root 先由轻量 loader 决定 motion tier。static
     不加载 R3F；full/lite 进入视口后再动态 import GlobeDistanceScene。 */
  .globe-canvas :global(.globe-canvas-root) {
    position: relative;
    width: 100%;
    height: 100%;
    /* 无背景 → 透明 alpha；让站点 page 背景透出，与 §2 章节呼吸一致 */
  }
  .globe-canvas :global(.globe-r3f-root) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .globe-canvas :global(.globe-canvas-root canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  .globe-static-scene {
    position: absolute;
    inset: 0;
    display: none;
    place-items: center;
  }
  .globe-canvas
    :global(.globe-canvas-root[data-motion-tier="static"])
    .globe-static-scene {
    display: grid;
  }
  .globe-static-orb {
    position: relative;
    width: min(62vh, 62vw, 520px);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 35% 28%,
        rgba(245, 240, 230, 0.22),
        transparent 24%
      ),
      radial-gradient(circle at 50% 55%, #274b35 0 62%, #183124 100%);
    box-shadow:
      inset -2.2rem -2rem 3.4rem rgba(7, 17, 13, 0.48),
      inset 1rem 1.2rem 2.6rem rgba(245, 240, 230, 0.12),
      0 1.5rem 3rem rgba(53, 71, 45, 0.18);
  }
  .globe-static-land {
    position: absolute;
    display: block;
    background: rgba(136, 166, 112, 0.82);
    filter: blur(0.2px);
  }
  .globe-static-land.land-a {
    width: 34%;
    height: 18%;
    left: 22%;
    top: 25%;
    border-radius: 52% 42% 46% 58%;
    transform: rotate(-18deg);
  }
  .globe-static-land.land-b {
    width: 30%;
    height: 24%;
    right: 18%;
    top: 37%;
    border-radius: 48% 60% 44% 54%;
    transform: rotate(16deg);
  }
  .globe-static-land.land-c {
    width: 16%;
    height: 12%;
    right: 22%;
    bottom: 20%;
    border-radius: 56% 42% 54% 40%;
    transform: rotate(26deg);
  }
  .globe-static-routes {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .globe-static-routes .route {
    fill: none;
    stroke: rgba(250, 245, 231, 0.68);
    stroke-width: 0.85;
    stroke-linecap: round;
  }
  .globe-static-routes .route.primary {
    stroke: var(--c-honey);
    stroke-width: 1.9;
  }
  .globe-static-routes .point {
    fill: rgba(250, 245, 231, 0.9);
  }
  .globe-static-routes .primary-point {
    fill: var(--c-honey);
  }

  /* 文字卡：v1.79 起占 grid 第二行 auto，不再 overlay 在 canvas 之上。
     卡片宽度仍收紧到 380px 让构图有呼吸感；不再需要 backdrop-blur 因为不
     压在 globe 之上（保留半透明背景给 sage 主题轻微离屏感，但浓度降低）。 */
  .globe-text {
    width: min(380px, 84%);
    padding: 0.85rem 1.25rem;
    background: rgba(245, 240, 230, 0.62);
    border-radius: var(--radius-sm);
    text-align: center;
    color: var(--c-olive-ink);
  }

  .globe-line {
    margin: 0 0 0.85rem;
    font-size: 1.5rem;
    line-height: 1.85;
    font-weight: 300;
  }
  .globe-text-line {
    display: block;
  }

  .globe-distance {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--c-sage-deep);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: center;
  }

  .globe-cities {
    color: var(--c-sage);
    font-weight: 400;
    letter-spacing: 0.04em;
  }

  .globe-km {
    color: var(--c-honey, #c69d4e);
    font-size: 1.65rem;
    line-height: 1.2;
    font-weight: 400;
    /* v1.74：prefix + num + unit 横向排成一句，让 "我们最远时相距 10,755 公里"
       视觉上是连贯的一行；过窄屏 wrap 自然换行（flex-wrap 让标签换行不破坏对齐） */
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.35em;
  }
  .globe-km-prefix {
    /* prefix "我们最远时相距" —— 比数字克制，sage 色让数字自己抓眼 */
    font-size: 1rem;
    color: var(--c-sage);
    letter-spacing: 0.04em;
    /* 与数字之间留一个字宽 */
    margin-right: 0.05em;
  }
  .globe-km-num {
    /* 数字 cn-kaishu 不合适——保持站点 default 衬线/sans 字族 */
    /* 数字 tabular 防 CountUp（如果将来加）抖动 */
    font-variant-numeric: tabular-nums;
  }
  .globe-km-unit {
    font-size: 1rem;
    color: var(--c-sage);
  }
  /* v1.79：grid 不再 1×1 overlay；fallback 直接占 row 1 (canvas 位置) 居中 */
  .globe-fallback {
    color: var(--c-olive-ink);
    text-align: center;
    align-self: center;
  }

  /* portrait（小平板 / 大手机竖屏）：释放 sticky，回归自然流式 */
  @media (max-width: 899px) {
    .globe-beat {
      min-height: auto;
    }
    .globe-stage {
      position: relative;
      top: auto;
      height: auto;
      min-height: 80vh;
      padding-block: clamp(2rem, 6vh, 4rem);
    }
    .globe-canvas {
      min-height: 60vh;
    }
  }

  /* compact（≤540 phone）：进一步缩，stage padding 更紧 */
  @media (max-width: 540px) {
    .globe-stage {
      padding: 1rem 0.75rem;
      gap: 1rem;
    }
    .globe-canvas {
      min-height: 50vh;
    }
    .globe-line {
      font-size: 1.25rem;
    }
    .globe-km {
      font-size: 1.4rem;
    }
  }
</style>
