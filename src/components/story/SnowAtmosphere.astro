---
/**
 * SnowAtmosphere.astro · § 2 vignette 重点舞台 · 雪粒子 canvas
 *   v0.2（v1.86 修 v1.85 audit P2：雪层不可见）
 *
 * v0.2 修复重点：
 *   - canvas overlay 样式从父组件 PoemBeat scoped CSS 移回本组件。Astro 父组件
 *     scoped selector 会编译成 `.snow-atmosphere[data-astro-cid-parent]`，但本
 *     组件生成的 canvas 不带父组件 cid，导致 position/z-index/mix-blend-mode
 *     全部不命中，桌面和手机都看不到真正覆盖在照片上的雪层。
 *   - ResizeObserver 监听 canvas 父 figure。图片懒加载前 canvas 可能初始 0×0；
 *     父容器获得真实尺寸后立即重算 backing store、重建粒子、绘制静态帧。
 *   - 粒子略增亮 / 增密，保证在 Snow_08 暗角和不同 DPR 设备上可见。
 *
 * Snow_08 是 Story 序列中第一张"夜色 / 互道晚安"主题的氛围照；用户期望它有
 * 额外的雪动画来强化重点。本组件给 vignette layout 在 photo 之上叠一层
 * Canvas 雪粒子，慢慢从顶部飘落，营造夜色 + 雪夜的亲密语境。
 *
 * 设计：
 *   - Canvas 2D 渲染 ~32-72 个粒子（粒子对象保留 x / y / radius / driftX / fallSpeed）
 *   - 粒子下落速度 10-28 px/s，横向 sway ±0.45 px/帧，半径 1.1-3.2px，
 *     opacity 0.55-0.92；越靠前景越亮 / 越快，给前后景深感
 *   - 粒子飘出底部 → 重投到顶部上方 (-radius-10) 让循环自然
 *   - 粒子背景透明，blendMode = 'screen' 让雪在暗角夜色上自然发亮
 *
 * 性能 / 节能：
 *   - IntersectionObserver 监 .poem-beat（vignette）：进视口启动 rAF；离视口
 *     cancelAnimationFrame —— 不可见时 0 CPU
 *   - visibilitychange 双层守卫：tab 切后台 → pause；切回 → resume
 *   - resize 时按当前 canvas 实尺寸重新分布粒子（不重新创建对象）
 *   - prefers-reduced-motion → 不绑事件、不跑 rAF；canvas 保留静态首帧雪粒
 *
 * a11y：
 *   - canvas aria-hidden="true"（纯装饰，不进 AT 朗读）
 *
 * 调试：window.__snowAtmosphere?.particles() 看粒子状态
 */
---

<canvas class="snow-atmosphere" aria-hidden="true"></canvas>

<style>
  .snow-atmosphere {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 3;
    border-radius: var(--radius-sm);
    mix-blend-mode: screen;
  }
</style>

<script>
  (function setupSnowAtmosphere() {
    if (typeof window === "undefined") return;

    const canvases =
      document.querySelectorAll<HTMLCanvasElement>(".snow-atmosphere");
    if (canvases.length === 0) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    interface Particle {
      x: number;
      y: number;
      radius: number;
      driftX: number;
      fallSpeed: number;
      opacity: number;
    }

    interface Stage {
      canvas: HTMLCanvasElement;
      ctx: CanvasRenderingContext2D;
      particles: Particle[];
      width: number;
      height: number;
      rafId: number;
      inView: boolean;
      tabVisible: boolean;
      lastT: number;
    }

    const stages: Stage[] = [];

    function createParticle(width: number, height: number): Particle {
      // 半径 1.1-3.2，越大越前景（更不透明 + 更快下落）
      const radius = 1.1 + Math.random() * 2.1;
      const depth = (radius - 1.1) / 2.1; // 0 (远) - 1 (近)
      return {
        x: Math.random() * width,
        y: Math.random() * height,
        radius,
        driftX: (Math.random() - 0.5) * 0.9, // ±0.45px/帧 横向 sway
        fallSpeed: 10 + depth * 18, // 10-28 px/s
        opacity: 0.55 + depth * 0.37, // 远 0.55 / 近 0.92
      };
    }

    function syncCanvasSize(stage: Stage): boolean {
      const rect = stage.canvas.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const nextWidth = rect.width;
      const nextHeight = rect.height;
      const changed =
        Math.abs(stage.width - nextWidth) > 1 ||
        Math.abs(stage.height - nextHeight) > 1;
      // CSS 尺寸
      stage.width = nextWidth;
      stage.height = nextHeight;
      // 实际像素分辨率
      stage.canvas.width = Math.round(nextWidth * dpr);
      stage.canvas.height = Math.round(nextHeight * dpr);
      stage.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      return changed;
    }

    function ensureParticles(stage: Stage): void {
      // 数量随面积 scale，但夹在 32-72 之间
      const target = Math.round(
        Math.min(72, Math.max(32, (stage.width * stage.height) / 9000)),
      );
      while (stage.particles.length < target) {
        stage.particles.push(createParticle(stage.width, stage.height));
      }
      if (stage.particles.length > target) stage.particles.length = target;
    }

    function step(stage: Stage, dt: number): void {
      const { ctx, width, height, particles } = stage;
      ctx.clearRect(0, 0, width, height);
      ctx.globalCompositeOperation = "screen";
      for (const p of particles) {
        // 更新位置
        p.y += p.fallSpeed * (dt / 1000);
        p.x += p.driftX;
        // 横向 sway 自然回弹
        if (p.x < -2) p.x = width + 2;
        else if (p.x > width + 2) p.x = -2;
        // 飘出底部 → 重投到顶上
        if (p.y > height + p.radius + 2) {
          p.y = -p.radius - Math.random() * 30;
          p.x = Math.random() * width;
        }
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(245, 248, 255, ${p.opacity.toFixed(3)})`;
        ctx.fill();
      }
      ctx.globalCompositeOperation = "source-over";
    }

    function resizeAndPaint(stage: Stage): void {
      const oldWidth = stage.width;
      const oldHeight = stage.height;
      const changed = syncCanvasSize(stage);
      const wasZero = oldWidth < 1 || oldHeight < 1;
      if (
        changed &&
        (wasZero || stage.width < oldWidth || stage.height < oldHeight)
      ) {
        stage.particles = [];
      }
      ensureParticles(stage);
      // 保证 reduced-motion / 尚未进视口时也有一帧可见雪层。
      step(stage, 16);
    }

    function tick(stage: Stage, t: number): void {
      stage.rafId = 0;
      if (!stage.inView || !stage.tabVisible) return;
      const dt = Math.min(50, t - stage.lastT || 16); // clamp 50ms 防 tab 切回大跳
      stage.lastT = t;
      step(stage, dt);
      stage.rafId = window.requestAnimationFrame((tt) => tick(stage, tt));
    }

    function start(stage: Stage): void {
      if (stage.rafId !== 0) return;
      stage.lastT = performance.now();
      stage.rafId = window.requestAnimationFrame((t) => tick(stage, t));
    }

    function stop(stage: Stage): void {
      if (stage.rafId === 0) return;
      window.cancelAnimationFrame(stage.rafId);
      stage.rafId = 0;
    }

    canvases.forEach((canvas) => {
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      const stage: Stage = {
        canvas,
        ctx,
        particles: [],
        width: 0,
        height: 0,
        rafId: 0,
        inView: false,
        tabVisible: !document.hidden,
        lastT: 0,
      };
      stages.push(stage);
      // 静态首帧（reduced-motion 也能看到雪粒分布，只是不动）
      resizeAndPaint(stage);
    });

    const resizeObserver =
      typeof ResizeObserver !== "undefined"
        ? new ResizeObserver((entries) => {
            const targets = new Set(entries.map((entry) => entry.target));
            stages.forEach((stage) => {
              if (
                targets.has(stage.canvas) ||
                (stage.canvas.parentElement &&
                  targets.has(stage.canvas.parentElement))
              ) {
                resizeAndPaint(stage);
              }
            });
          })
        : null;

    if (resizeObserver) {
      stages.forEach((stage) => {
        resizeObserver.observe(stage.canvas);
        if (stage.canvas.parentElement) {
          resizeObserver.observe(stage.canvas.parentElement);
        }
      });
    }

    if (prefersReduced) {
      // 不绑事件、不启动 rAF；保留首帧静态雪粒
      return;
    }

    // 单 IO 监所有 vignette beat 是否在视口
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const stage = stages.find(
            (s) => s.canvas.closest(".poem-beat") === entry.target,
          );
          if (!stage) continue;
          stage.inView = entry.isIntersecting;
          if (stage.inView && stage.tabVisible) start(stage);
          else stop(stage);
        }
      },
      { rootMargin: "10% 0px 10% 0px", threshold: [0, 0.05] },
    );
    stages.forEach((s) => {
      const beat = s.canvas.closest(".poem-beat");
      if (beat) io.observe(beat);
    });

    // visibilitychange：tab 切后台 → 全停；切回 → 视 IO 状态决定恢复
    document.addEventListener("visibilitychange", () => {
      const tabNow = !document.hidden;
      stages.forEach((s) => {
        s.tabVisible = tabNow;
        if (tabNow && s.inView) start(s);
        else stop(s);
      });
    });

    // resize：重新同步 canvas 物理尺寸 + 调整粒子数量
    window.addEventListener(
      "resize",
      () => {
        stages.forEach((s) => resizeAndPaint(s));
      },
      { passive: true },
    );

    // 调试钩子
    (
      window as unknown as {
        __snowAtmosphere?: {
          particles: () => Array<{ count: number; size: [number, number] }>;
        };
      }
    ).__snowAtmosphere = {
      particles: () =>
        stages.map((s) => ({
          count: s.particles.length,
          size: [s.width, s.height],
        })),
    };
  })();
</script>
