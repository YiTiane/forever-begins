---
/**
 * StoryPoemScroller.astro · §2 第一章长卷骨架（v0.2 · v1.54 修 v1.53 P2 #1 占位泄漏）
 *
 * v0.2 修：删除 v0.1 渲染的 deferred-beats 可见占位（"§2.B · globe · beat 11
 * · 后续 batch 实装" 之类的工程标记）。aria-hidden 只对 AT 隐藏，对所有视觉访客
 * 仍显形 — 这不该出现在婚礼站。改为：beats 11/12 数据保留在 main.json（schema
 * 已严约束 11=globe / 12=finale），但**不渲染任何 DOM**；后续 batch 3/4 直接
 * 在 § —— 后续 batch 挂点 —— 注释处插入 GlobeDistanceScene / StarCarouselFinale。
 *
 * 上层 wrapper：从 src/content/story-poem/main.json 读全部 beats，
 * 按 batch 范围渲染前 N 个 photo-poem beat（默认 N=4，可由 prop 调整）。
 *
 * batch 1 落地范围（**严格收敛** · 与 §0/§1 第一刀同等抽象）：
 *   ✓ 渲染 BEATS_TO_RENDER (默认 4) 个 photo-poem beat 用 `<PoemBeat>`
 *   ✓ 单个 IntersectionObserver 观察所有 .poem-beat，进入视口加 .visible
 *   ✓ rootMargin "-15%" → 进入 ~85vh 处才触发，避免一进 §2 顶就全亮
 *   ✓ 视口外 unobserve(entry.target) 解绑（一次性触发，避免 hover 抖动）
 *   ✓ visibilitychange 不需要（IO 自动暂停）
 *   ✓ a11y：`<section aria-labelledby="story-poem-heading">` + h2 'Our Story' latin-italic
 *   ✓ stacking 隔离：position: relative + isolation: isolate（与 §0/§1 同款）
 *
 * **NOT in batch 1**（明确留 §2 后续刀，避免一刀混太多）：
 *   ✗ globe (beat 11) → 等 R3F + Three.js + 水彩贴图地球到位（独立刀）
 *   ✗ finale (beat 12) → 等 StarCarouselFinale Shader Dissolve 到位（独立刀）
 *   ✗ 后 6 个 photo-poem beat (05-10) → 等 batch 2 视觉收口前 4 个再扩
 *   ✗ 章节级 sticky scroll-jacking / 文字 stagger / 照片 layer parallax（motion polish）
 *
 * 数据流（DESIGN §15.1 数据接缝唯一原则）：
 *   - getCollection('storyPoem') → main.json
 *   - 取 entry.data.beats，filter kind === 'photo-poem'，slice(0, N)
 *   - anchor_date 当前未消费（beat 05 [N] 天 CountUp 留独立小刀）
 */
import { getCollection } from "astro:content";
import PoemBeat from "@/components/story/PoemBeat.astro";

interface Props {
  /** 渲染前 N 个 photo-poem beat（batch 1 默认 4，未来批次可上调）。 */
  maxBeats?: number;
}

const { maxBeats = 4 } = Astro.props;

const storyPoemEntries = await getCollection("storyPoem");
const main = storyPoemEntries.find((e) => e.id === "main");
if (!main) {
  throw new Error(
    "StoryPoemScroller.astro: src/content/story-poem/main.json missing — check content collection state",
  );
}

// 仅渲染 photo-poem 类型的 beat，前 maxBeats 个
const photoPoemBeats = main.data.beats
  .filter((b) => b.kind === "photo-poem")
  .slice(0, maxBeats);

/*
 * v1.54（v1.53 P2 #1 修）：删除可见的 deferred-beats 占位区。v1.53 把
 * "§2.B · globe · beat 11 · 后续 batch 实装" 渲染成 `<p>` 留在公开页面，aria-hidden
 * 只对 AT 隐藏，对所有视觉访客（包括婚礼宾客）仍显形 — 这不该出现在婚礼站。
 *
 * 现在策略：beats 11/12 数据仍保留在 main.json（schema 已严约束 beat 11=globe / 12=finale）
 * 让未来 batch 3/4 直接挂 GlobeDistanceScene / StarCarouselFinale 时就能读到位置；
 * 但**不渲染任何 DOM**。挂点定位从"渲染极淡灰小字"改为"读源码注释 + JSON beat ids"。
 */
---

<section class="story-poem" aria-labelledby="story-poem-heading">
  {/* 章节标题（拉丁体细斜，与 §1 'Invitation' 同档） */}
  <h2 id="story-poem-heading" class="section-title latin-italic">Our Story</h2>

  {
    /* —— 12 beats 中前 N 个 photo-poem 渲染 ——
       § 2 整段都在 §0 Cover + §1 Invitation 之下（≥ 2 屏滚动），任何 photo
       都不在首屏；不传 firstAboveFold，让每张图都走 lazy loading。
       v1.55：把 layout 字段一路透传到 PoemBeat（schema 已强约束 photo-poem
       必有 layout），让 data-layout 反射到 DOM 触发 4 套真正不同的空间 CSS。 */
  }
  {
    photoPoemBeats.map((beat) => (
      <PoemBeat
        id={beat.id}
        layout={beat.layout}
        lines={beat.lines}
        photos={beat.photos}
      />
    ))
  }

  {/* —— 后续 batch 挂点（v1.54 之后不再渲染可见占位） —— */}
  {
    /* batch 3 · §2.B GlobeDistanceScene 将插在这里，对应 main.json beats[10]（id="11" kind="globe"）*/
  }
  {
    /* batch 4 · §2.C StarCarouselFinale 将插在这里，对应 main.json beats[11]（id="12" kind="finale"）*/
  }
</section>

<style>
  .story-poem {
    /* 与 §0/§1 同款 stacking 隔离，让 §2 内部 z-index 计算闭合 */
    position: relative;
    isolation: isolate;
    /* 章节自带版心；PoemBeat 内部再各自 max-width: 1280px 居中 */
    width: 100%;
    padding: 4rem 0 2rem;
  }

  .section-title {
    font-size: 2rem;
    line-height: 1.1;
    color: var(--c-sage);
    font-weight: 300;
    margin: 0 auto 2rem;
    text-align: center;
  }

  @media (min-width: 960px) {
    .section-title {
      font-size: 2.25rem;
    }
  }

  @media (max-width: 540px) {
    .section-title {
      font-size: 1.75rem;
      margin: 0 auto 1.5rem;
    }
  }
</style>

<script>
  (function setupStoryPoemScroller() {
    if (typeof window === "undefined") return;

    const beats = document.querySelectorAll<HTMLElement>(".poem-beat");
    if (beats.length === 0) return;

    // prefers-reduced-motion：直接全部 visible，跳过 IO（也避免空跑 IO 资源）
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReduced) {
      beats.forEach((b) => b.classList.add("visible"));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            // 一次性触发，立即解绑（不会因为 hover / 反复滚动重复 transition）
            io.unobserve(entry.target);
          }
        }
      },
      {
        // 进入视口约 15% 后才触发，让用户先看到一点 beat 再淡入
        rootMargin: "-15% 0px -15% 0px",
        threshold: 0,
      },
    );

    beats.forEach((b) => io.observe(b));

    // 调试钩子：window.__storyPoem.list() 看哪些 beat 已 visible
    (
      window as unknown as {
        __storyPoem?: { list: () => string[] };
      }
    ).__storyPoem = {
      list: () =>
        Array.from(document.querySelectorAll<HTMLElement>(".poem-beat.visible"))
          .map((e) => e.dataset.beatId ?? "?")
          .sort(),
    };
  })();
</script>
