---
/**
 * StoryPoemScroller.astro · §2 第一章长卷骨架（v0.5 · v1.59 接入 layout solver）
 *
 * v0.5 新增（v1.59 P2 #1+#2 修）：接入 src/lib/story/beatLayoutSolver.ts。
 *   v1.58 之前 PoemBeat 的 4 套 layout 用 magic % / clamp + 媒体查询断点硬编码 photo 宽 /
 *   文字最大宽 / gap，结果窄屏 / 小平板纵向几乎必崩（市场视口矩阵 360-820px portrait
 *   多档都报失败：空屏 / 文字图距离失衡 / radial 单图脱顶）。v0.5 让 init / window.resize
 *   时跑一次 solver，把 viewport × layout × photo aspectRatio 求出的尺寸 / gap 写到 beat
 *   元素的 CSS 自定义属性上；CSS 只消费变量。layout 不再依赖断点凑型。
 *
 * v0.4 修 v1.56 审计 P2 #2 + P3：
 *   - **P2 #2（rAF 常驻空跑）**：v1.56 / v0.3 inView 时每帧
 *     `requestAnimationFrame(tick)` 无条件再调度，访客在 stage 上停下来读时 rAF 仍
 *     60Hz 空跑、与 §0 Parallax / §1 Countdown 的"idle 0 CPU"承诺不一致。v0.4 把
 *     rAF 改为 **scroll / resize 事件驱动**：单帧 dirty flag `rafScheduled`，
 *     scroll/resize 事件触发时 `requestAnimationFrame(flushUpdate)` 一次；flush 完
 *     帧后 dirty=false，无新事件就不再 schedule。滚动停 → 0 rAF / 0 CPU。同时配
 *     ResizeObserver 监 `.poem-beat` 自身高度变化（图片懒加载、字体回流），保证
 *     布局 shift 也能触发更新。
 *   - **P3（头注释 stale）**：v0.2 注释还在描述 v1.54 的"一次性 IO + .visible +
 *     unobserve"行为，与 v1.56 起的 sticky stage + scroll-progress driven
 *     choreography 已脱节。v0.4 重写头注释，描述真实运行机制：rAF flush / phase
 *     变量 / IO + scroll + RO 三条触发路径 / debug hook。
 *
 * 上层 wrapper：从 src/content/story-poem/main.json 读全部 beats，按 batch 范围
 * 渲染前 N 个 photo-poem beat（默认 N=4，可由 prop 调整）；beats 11/12（globe/
 * finale）数据保留 schema 但不渲染 DOM —— 后续 batch 在 JSX 注释挂点处插入对应组件。
 *
 * 当前批次 §2 落地范围（v1.57）：
 *   ✓ 渲染前 maxBeats (默认 4) 个 photo-poem beat 用 `<PoemBeat>`，每个是 sticky
 *     cinematic stage（外层 scroll spacer + 内层 100vh sticky 舞台）
 *   ✓ 文字 + 照片 baseline opacity 1，整个 stage 任意停留点都看得到完整 composed 帧
 *     （v1.57 P2 #1 修 v1.56 broken visual frame）
 *   ✓ 单 IO 报告 in/out；scroll / resize / ResizeObserver 三路事件统一进
 *     scheduleUpdate；单帧 dirty flag 防多次 rAF；写 4 个 CSS 变量到 beat 元素：
 *     `--p` / `--p-photo-1` / `--p-photo-2` / `--p-text`（PoemBeat 的 layout CSS
 *     用 calc(var(--p)) 表达 transform / mask-radius / scale / filter）
 *   ✓ prefers-reduced-motion → 不绑事件、不跑 rAF，直接给所有 beat 写 --p:1 终态
 *   ✓ a11y：`<section aria-labelledby="story-poem-heading">` + h2 'Our Story'
 *     latin-italic
 *   ✓ stacking 隔离：position: relative + isolation: isolate（与 §0/§1 同款）
 *
 * **NOT in current batch**（明确留 §2 后续刀）：
 *   ✗ globe (beat 11) → 等 R3F + Three.js + 水彩贴图地球到位（独立刀）
 *   ✗ finale (beat 12) → 等 StarCarouselFinale Shader Dissolve 到位（独立刀）
 *   ✗ 后 6 个 photo-poem beat (05-10) → batch 1-3 视觉收口后再 lift maxBeats
 *   ✗ 文字字符级 stagger / 鼠标 inertia parallax（Phase 5 motion polish）
 *
 * 数据流（DESIGN §15.1 数据接缝唯一原则）：
 *   - getCollection('storyPoem') → main.json
 *   - 取 entry.data.beats，filter kind === 'photo-poem'，slice(0, N)
 *   - anchor_date 当前未消费（beat 05 [N] 天 CountUp 留独立小刀）
 *
 * 调试：window.__storyPoem.progress() / .list() / .active() —— 看进度 / 全部 beat /
 *   当前 inView beats。
 */
import { getCollection } from "astro:content";
import CdnImage from "@/components/CdnImage.astro";
import PoemBeat from "@/components/story/PoemBeat.astro";

interface Props {
  /** 渲染前 N 个 photo-poem beat（batch 1 默认 4，未来批次可上调）。 */
  maxBeats?: number;
}

const { maxBeats = 4 } = Astro.props;

const storyPoemEntries = await getCollection("storyPoem");
const main = storyPoemEntries.find((e) => e.id === "main");
if (!main) {
  throw new Error(
    "StoryPoemScroller.astro: src/content/story-poem/main.json missing — check content collection state",
  );
}

// 仅渲染 photo-poem 类型的 beat，前 maxBeats 个
const photoPoemBeats = main.data.beats
  .filter((b) => b.kind === "photo-poem")
  .slice(0, maxBeats);

/*
 * v1.54（v1.53 P2 #1 修）：删除可见的 deferred-beats 占位区。v1.53 把
 * "§2.B · globe · beat 11 · 后续 batch 实装" 渲染成 `<p>` 留在公开页面，aria-hidden
 * 只对 AT 隐藏，对所有视觉访客（包括婚礼宾客）仍显形 — 这不该出现在婚礼站。
 *
 * 现在策略：beats 11/12 数据仍保留在 main.json（schema 已严约束 beat 11=globe / 12=finale）
 * 让未来 batch 3/4 直接挂 GlobeDistanceScene / StarCarouselFinale 时就能读到位置；
 * 但**不渲染任何 DOM**。挂点定位从"渲染极淡灰小字"改为"读源码注释 + JSON beat ids"。
 */
---

<section class="story-poem" aria-labelledby="story-poem-heading">
  {/* 章节标题（拉丁体细斜，与 §1 'Invitation' 同档） */}
  <h2 id="story-poem-heading" class="section-title latin-italic">Our Story</h2>

  {
    /* —— 12 beats 中前 N 个 photo-poem 渲染 ——
       § 2 整段都在 §0 Cover + §1 Invitation 之下（≥ 2 屏滚动），任何 photo
       都不在首屏；不传 firstAboveFold，让每张图都走 lazy loading。
       v1.55：把 layout 字段一路透传到 PoemBeat（schema 已强约束 photo-poem
       必有 layout），让 data-layout 反射到 DOM 触发 4 套真正不同的空间 CSS。 */
  }
  {
    photoPoemBeats.map((beat) => (
      <PoemBeat
        id={beat.id}
        layout={beat.layout}
        lines={beat.lines}
        photos={beat.photos}
      />
    ))
  }

  {/* —— 后续 batch 挂点（v1.54 之后不再渲染可见占位） —— */}
  {
    /* batch 3 · §2.B GlobeDistanceScene 将插在这里，对应 main.json beats[10]（id="11" kind="globe"）*/
  }
  {
    /* batch 4 · §2.C StarCarouselFinale 将插在这里，对应 main.json beats[11]（id="12" kind="finale"）*/
  }

  {
    /* —— Story end cap（v1.60 P2 #3 修）：临时叙事收束 ——
       v1.59 之前 §2 在最后一个 beat 后就是空白背景，访客滚过最后一个 beat 后落到
       看不到任何内容的纯背景区。等 batch 4-6 把 globe / finale 接上之后这块自然
       被取代；本批先放一个克制的 "未完待续" 收束，让滚动有终点感。*/
  }
  <div class="story-end-cap" aria-label="故事临时收束">
    <div class="story-end-card">
      <figure class="story-end-photo">
        <CdnImage
          cdnTarget="pearl"
          stem="Pearl_04"
          alt="珍珠系列主海报 · 两个人相拥"
          priority="high"
          widths={[320, 640, 1024, 1600, 2400]}
          sizes="(min-width: 960px) 520px, (min-width: 540px) 58vw, 82vw"
          width={3000}
          height={2000}
        />
      </figure>
      <div class="story-end-copy">
        <p class="story-end-kicker latin-roman">To be continued</p>
        <p class="story-end-line cn-kaishu">还好我们有牢牢抱紧。</p>
        <p class="story-end-line cn-kaishu">幸好最终是你。</p>
      </div>
    </div>
  </div>
</section>

<style>
  .story-poem {
    /* 与 §0/§1 同款 stacking 隔离，让 §2 内部 z-index 计算闭合 */
    position: relative;
    isolation: isolate;
    /* 章节自带版心；PoemBeat 内部再各自 max-width: 1280px 居中 */
    width: 100%;
    padding: 4rem 0 2rem;
  }

  .section-title {
    font-size: 2rem;
    line-height: 1.1;
    color: var(--c-sage);
    font-weight: 300;
    margin: 0 auto 2rem;
    text-align: center;
  }

  @media (min-width: 960px) {
    .section-title {
      font-size: 2.25rem;
    }
  }

  @media (max-width: 540px) {
    .section-title {
      font-size: 1.75rem;
      margin: 0 auto 1.5rem;
    }
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* story end cap（v1.60 P2 #3）：最后一个 beat 后的叙事收束           */
  /* 视觉：一行霞鹜文楷"未完待续"，宽字距，柔色 sage，不抢戏              */
  /* min-height 60vh 让用户滚到最后能落在一个 intentional 视觉，不再    */
  /* 看到纯背景空屏；后续 batch 4-6 接 globe/finale 时自然替代。       */
  /* ──────────────────────────────────────────────────────────────  */
  .story-end-cap {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(4rem, 10vh, 7rem) 1.5rem;
  }
  .story-end-card {
    display: grid;
    grid-template-columns: minmax(0, 520px) minmax(16rem, 24rem);
    align-items: center;
    gap: clamp(2rem, 6vw, 4.5rem);
    max-width: min(1080px, calc(100vw - 3rem));
    width: 100%;
  }
  .story-end-photo {
    margin: 0;
    box-shadow: var(--shadow-paper);
  }
  .story-end-photo :global(picture),
  .story-end-photo :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }
  .story-end-copy {
    text-align: left;
    color: var(--c-olive-ink);
  }
  .story-end-kicker {
    margin: 0 0 1.25rem;
    color: var(--c-sage);
    font-size: clamp(1.1rem, 2.2vw, 1.7rem);
    line-height: 1.1;
  }
  .story-end-line {
    margin: 0;
    font-size: clamp(1.25rem, 3.3vw, 2rem);
    line-height: 1.8;
    letter-spacing: 0;
  }

  @media (max-width: 899px) {
    .story-end-card {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: 1.75rem;
      max-width: min(640px, calc(100vw - 2rem));
    }
    .story-end-photo {
      width: min(82vw, 520px);
    }
    .story-end-copy {
      text-align: center;
    }
  }
</style>

<script>
  import {
    getStoryLayoutMode,
    solveBeatLayout,
    type BeatLayout,
    type PhotoSpec,
  } from "@/lib/story/beatLayoutSolver";

  /*
   * v1.59（v1.58 P2 #1+#2 修）· 接入 constraint-based layout solver
   *
   *   v1.58 之前 PoemBeat 的 4 套 layout 用 magic % / clamp + 媒体查询断点硬编码 photo
   *   宽 / 文字宽 / gap，窄屏几乎必崩。v1.59 在 init / window.resize 时跑一次 solver
   *   `solveBeatLayout(...)`，求出 4-12 个 CSS 自定义属性写到 .poem-beat 上，CSS 只消费。
   *
   * v1.57（v1.56 P2 #2 修）· scroll-event driven · idle 0 CPU
   *
   *   v1.56 用"inView 时每帧 rAF tick"驱动 scroll-progress，访客在 stage 上停下来读
   *   时 rAF 仍 60Hz 空跑、与 §0 Parallax / §1 Countdown 的 idle 0 CPU 承诺不一致。
   *   v1.57 改为 **scroll / resize / ResizeObserver 事件驱动**：
   *
   *     1. IO 监所有 beat 是否在视口；进视口加入 inViewBeats Set，离开移除
   *     2. window scroll / resize 事件 → scheduleUpdate() 单帧 dirty flag rAF flush
   *     3. ResizeObserver 监 .poem-beat offsetHeight（图片懒加载、字体回流的兜底）
   *     4. flushUpdate() 只对 inViewBeats 中的 beat 写 CSS 变量；非视口 beat 不算
   *     5. flush 完帧 dirty=false；无新事件就不再 schedule
   *
   *   写到 beat 元素的 4 个 CSS 自定义属性（PoemBeat 的 layout CSS 直接消费）：
   *     --p           主进度（线性 0→1）
   *     --p-photo-1   phase-1（0..0.35 段映射 0→1）
   *     --p-photo-2   phase-2（0.35..0.7 段映射 0→1）
   *     --p-text      phase-3（0.55..0.9 段映射 0→1）
   *
   *   性能：
   *     - 滚动停 → 0 rAF 调度 / 0 CPU
   *     - 单帧只 read 一次 getBoundingClientRect + write 4 个 CSS 变量（成本恒定）
   *     - prefers-reduced-motion → 不绑事件，写 --p:1 终态后即返回
   *
   *   调试：window.__storyPoem.progress() / .list() / .active()
   */
  (function setupStoryPoemScroller() {
    if (typeof window === "undefined") return;

    const beats = Array.from(
      document.querySelectorAll<HTMLElement>(".poem-beat"),
    );
    if (beats.length === 0) return;

    function clamp01(n: number): number {
      return n < 0 ? 0 : n > 1 ? 1 : n;
    }

    function writeProgress(beat: HTMLElement, p: number): void {
      const pPhoto1 = clamp01(p / 0.35);
      const pPhoto2 = clamp01((p - 0.35) / 0.35);
      const pText = clamp01((p - 0.55) / 0.35);
      beat.style.setProperty("--p", String(p));
      beat.style.setProperty("--p-photo-1", String(pPhoto1));
      beat.style.setProperty("--p-photo-2", String(pPhoto2));
      beat.style.setProperty("--p-text", String(pText));
    }

    function computeProgress(beat: HTMLElement): number {
      const rect = beat.getBoundingClientRect();
      const vh = window.innerHeight;
      const scrollable = beat.offsetHeight - vh;
      if (scrollable <= 0) return 1;
      const scrolled = -rect.top;
      return clamp01(scrolled / scrollable);
    }

    /**
     * v1.59 layout solver：把每个 beat 当前 viewport 下的 photo 尺寸 / gap / 文字宽
     * 求出来写到 .poem-beat 的 CSS 自定义属性上。CSS 只消费变量，不再写 magic %。
     * 仅在 init / window.resize / 文字尺寸变化时跑（开销不敏感）；scroll 期间只更新
     * phase 变量。
     *
     * v1.60 升级（v1.59 P2 #2 修）：先实测 .poem-text 的 box height，再传给 solver。
     * 这样 radial-mask / anchor-single / parallax-pair narrow / diagonal-gaze narrow
     * 都能按真实 text 高度去分配剩余 stage 空间给 photo —— 不再用 vh×0.18 这种
     * "凭直觉" 的常量做估算。
     */
    function applyLayout(beat: HTMLElement): void {
      const layout = beat.dataset.layout as BeatLayout | undefined;
      if (!layout) return;
      const photoEls = Array.from(
        beat.querySelectorAll<HTMLElement>(".poem-photo"),
      );
      if (photoEls.length === 0) return;
      const photos: PhotoSpec[] = photoEls.map((el) => ({
        aspectRatio:
          parseFloat(el.dataset.aspectRatio ?? "") ||
          (el.dataset.role === "top-left" || el.dataset.role === "bottom-right"
            ? 0.6667
            : 1.5),
        role: el.dataset.role ?? "",
      }));

      // 实测 text 块的高 / 宽（getBoundingClientRect 不触发 layout 因为 stage
      // 已经 paint 过；首帧时 text 用 fallback 值，第二帧（RO 触发）就是真值）。
      const textEl = beat.querySelector<HTMLElement>(".poem-text");
      const textRect = textEl?.getBoundingClientRect();
      const textHeight = textRect?.height;
      const textWidth = textRect?.width;
      const mode = getStoryLayoutMode(window.innerWidth, window.innerHeight);
      beat.dataset.storyMode = mode;

      const vars = solveBeatLayout({
        vw: window.innerWidth,
        vh: window.innerHeight,
        layout,
        photos,
        ...(textHeight !== undefined ? { textHeight } : {}),
        ...(textWidth !== undefined ? { textWidth } : {}),
      });
      for (const [key, value] of Object.entries(vars)) {
        beat.style.setProperty(key, value);
      }
    }

    // 初始一次：page load 后立刻给每个 beat 算一遍 layout 变量
    beats.forEach(applyLayout);

    // prefers-reduced-motion：写终态后退出；不绑事件、不跑 rAF。
    // （solver 已经在上面跑过了，layout 尺寸已写到位）
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReduced) {
      beats.forEach((b) => writeProgress(b, 1));
      return;
    }

    // 当前在视口的 beat（只对这些 beat 算 progress；非视口 beat 不算）。
    const inViewBeats = new Set<HTMLElement>();

    // 单帧 dirty flag：scroll / resize / RO 事件多次触发时 coalesce 为一次 rAF flush。
    let rafScheduled = false;

    function flushUpdate(): void {
      rafScheduled = false;
      for (const beat of inViewBeats) {
        writeProgress(beat, computeProgress(beat));
      }
    }

    function scheduleUpdate(): void {
      if (rafScheduled) return;
      rafScheduled = true;
      window.requestAnimationFrame(flushUpdate);
    }

    // IO：仅决定 inView 集合；不再驱动 rAF 自循环。
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const beat = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            inViewBeats.add(beat);
            // 进入视口立刻写一次，避免显示初始 --p:0 的"未渲染帧"
            writeProgress(beat, computeProgress(beat));
          } else {
            inViewBeats.delete(beat);
            // 离开视口最后写一次终态（视口上方 p=1 / 视口下方 p=0）
            writeProgress(beat, computeProgress(beat));
          }
        }
      },
      {
        rootMargin: "10% 0px 10% 0px",
        threshold: [0, 0.05, 0.95, 1],
      },
    );
    beats.forEach((beat) => io.observe(beat));

    // scroll / resize 事件驱动 scheduleUpdate：访客滚动 / 调整窗口才触发 rAF。
    // 滚动停 → 没有事件 → 没有 rAF 调度 → 0 CPU（与 §0 Parallax / §1 Countdown 同策略）。
    window.addEventListener("scroll", scheduleUpdate, { passive: true });
    // resize 上还需要重跑 layout solver（viewport 变了，photo / gap 尺寸也要重算）。
    window.addEventListener("resize", () => {
      beats.forEach(applyLayout);
      scheduleUpdate();
    });

    // ResizeObserver：图片懒加载完成 / 字体回流改变 .poem-beat offsetHeight 时
    // computeProgress 的分母会变，scrolled 也可能漂；用 RO 兜一道，保证布局 shift
    // 不会让进度卡在错误值。
    const ro = new ResizeObserver(() => scheduleUpdate());
    beats.forEach((beat) => ro.observe(beat));

    // v1.60 P2 #2：单独 RO 观察每个 beat 的 .poem-text，在文字尺寸变化时（字体
    // 加载、viewport 改变后断行重排）重跑 solver。比起 window.resize 回调更精准
    // —— 字体加载 / lang 切换 / 浏览器 zoom 等都能及时反映到 photo 尺寸约束。
    // 用单独的 RO 实例避免与 beat-level RO 混淆触发条件。
    const textRO = new ResizeObserver((entries) => {
      for (const entry of entries) {
        const textEl = entry.target as HTMLElement;
        const beat = textEl.closest<HTMLElement>(".poem-beat");
        if (beat) {
          applyLayout(beat);
          scheduleUpdate();
        }
      }
    });
    beats.forEach((beat) => {
      const textEl = beat.querySelector<HTMLElement>(".poem-text");
      if (textEl) textRO.observe(textEl);
    });

    // 调试钩子：window.__storyPoem.progress() / .list() / .active()
    (
      window as unknown as {
        __storyPoem?: {
          progress: () => Record<
            string,
            { p: number; p1: number; p2: number; pt: number }
          >;
          list: () => string[];
          active: () => string[];
        };
      }
    ).__storyPoem = {
      progress: () => {
        const out: Record<
          string,
          { p: number; p1: number; p2: number; pt: number }
        > = {};
        beats.forEach((b) => {
          const id = b.dataset.beatId ?? "?";
          const css = getComputedStyle(b);
          out[id] = {
            p: Number(css.getPropertyValue("--p")) || 0,
            p1: Number(css.getPropertyValue("--p-photo-1")) || 0,
            p2: Number(css.getPropertyValue("--p-photo-2")) || 0,
            pt: Number(css.getPropertyValue("--p-text")) || 0,
          };
        });
        return out;
      },
      list: () => beats.map((b) => b.dataset.beatId ?? "?"),
      active: () =>
        Array.from(inViewBeats)
          .map((b) => b.dataset.beatId ?? "?")
          .sort(),
    };
  })();
</script>
