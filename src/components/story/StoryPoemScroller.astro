---
/**
 * StoryPoemScroller.astro · §2 第一章长卷骨架（v0.2 · v1.54 修 v1.53 P2 #1 占位泄漏）
 *
 * v0.2 修：删除 v0.1 渲染的 deferred-beats 可见占位（"§2.B · globe · beat 11
 * · 后续 batch 实装" 之类的工程标记）。aria-hidden 只对 AT 隐藏，对所有视觉访客
 * 仍显形 — 这不该出现在婚礼站。改为：beats 11/12 数据保留在 main.json（schema
 * 已严约束 11=globe / 12=finale），但**不渲染任何 DOM**；后续 batch 3/4 直接
 * 在 § —— 后续 batch 挂点 —— 注释处插入 GlobeDistanceScene / StarCarouselFinale。
 *
 * 上层 wrapper：从 src/content/story-poem/main.json 读全部 beats，
 * 按 batch 范围渲染前 N 个 photo-poem beat（默认 N=4，可由 prop 调整）。
 *
 * batch 1 落地范围（**严格收敛** · 与 §0/§1 第一刀同等抽象）：
 *   ✓ 渲染 BEATS_TO_RENDER (默认 4) 个 photo-poem beat 用 `<PoemBeat>`
 *   ✓ 单个 IntersectionObserver 观察所有 .poem-beat，进入视口加 .visible
 *   ✓ rootMargin "-15%" → 进入 ~85vh 处才触发，避免一进 §2 顶就全亮
 *   ✓ 视口外 unobserve(entry.target) 解绑（一次性触发，避免 hover 抖动）
 *   ✓ visibilitychange 不需要（IO 自动暂停）
 *   ✓ a11y：`<section aria-labelledby="story-poem-heading">` + h2 'Our Story' latin-italic
 *   ✓ stacking 隔离：position: relative + isolation: isolate（与 §0/§1 同款）
 *
 * **NOT in batch 1**（明确留 §2 后续刀，避免一刀混太多）：
 *   ✗ globe (beat 11) → 等 R3F + Three.js + 水彩贴图地球到位（独立刀）
 *   ✗ finale (beat 12) → 等 StarCarouselFinale Shader Dissolve 到位（独立刀）
 *   ✗ 后 6 个 photo-poem beat (05-10) → 等 batch 2 视觉收口前 4 个再扩
 *   ✗ 章节级 sticky scroll-jacking / 文字 stagger / 照片 layer parallax（motion polish）
 *
 * 数据流（DESIGN §15.1 数据接缝唯一原则）：
 *   - getCollection('storyPoem') → main.json
 *   - 取 entry.data.beats，filter kind === 'photo-poem'，slice(0, N)
 *   - anchor_date 当前未消费（beat 05 [N] 天 CountUp 留独立小刀）
 */
import { getCollection } from "astro:content";
import PoemBeat from "@/components/story/PoemBeat.astro";

interface Props {
  /** 渲染前 N 个 photo-poem beat（batch 1 默认 4，未来批次可上调）。 */
  maxBeats?: number;
}

const { maxBeats = 4 } = Astro.props;

const storyPoemEntries = await getCollection("storyPoem");
const main = storyPoemEntries.find((e) => e.id === "main");
if (!main) {
  throw new Error(
    "StoryPoemScroller.astro: src/content/story-poem/main.json missing — check content collection state",
  );
}

// 仅渲染 photo-poem 类型的 beat，前 maxBeats 个
const photoPoemBeats = main.data.beats
  .filter((b) => b.kind === "photo-poem")
  .slice(0, maxBeats);

/*
 * v1.54（v1.53 P2 #1 修）：删除可见的 deferred-beats 占位区。v1.53 把
 * "§2.B · globe · beat 11 · 后续 batch 实装" 渲染成 `<p>` 留在公开页面，aria-hidden
 * 只对 AT 隐藏，对所有视觉访客（包括婚礼宾客）仍显形 — 这不该出现在婚礼站。
 *
 * 现在策略：beats 11/12 数据仍保留在 main.json（schema 已严约束 beat 11=globe / 12=finale）
 * 让未来 batch 3/4 直接挂 GlobeDistanceScene / StarCarouselFinale 时就能读到位置；
 * 但**不渲染任何 DOM**。挂点定位从"渲染极淡灰小字"改为"读源码注释 + JSON beat ids"。
 */
---

<section class="story-poem" aria-labelledby="story-poem-heading">
  {/* 章节标题（拉丁体细斜，与 §1 'Invitation' 同档） */}
  <h2 id="story-poem-heading" class="section-title latin-italic">Our Story</h2>

  {
    /* —— 12 beats 中前 N 个 photo-poem 渲染 ——
       § 2 整段都在 §0 Cover + §1 Invitation 之下（≥ 2 屏滚动），任何 photo
       都不在首屏；不传 firstAboveFold，让每张图都走 lazy loading。
       v1.55：把 layout 字段一路透传到 PoemBeat（schema 已强约束 photo-poem
       必有 layout），让 data-layout 反射到 DOM 触发 4 套真正不同的空间 CSS。 */
  }
  {
    photoPoemBeats.map((beat) => (
      <PoemBeat
        id={beat.id}
        layout={beat.layout}
        lines={beat.lines}
        photos={beat.photos}
      />
    ))
  }

  {/* —— 后续 batch 挂点（v1.54 之后不再渲染可见占位） —— */}
  {
    /* batch 3 · §2.B GlobeDistanceScene 将插在这里，对应 main.json beats[10]（id="11" kind="globe"）*/
  }
  {
    /* batch 4 · §2.C StarCarouselFinale 将插在这里，对应 main.json beats[11]（id="12" kind="finale"）*/
  }
</section>

<style>
  .story-poem {
    /* 与 §0/§1 同款 stacking 隔离，让 §2 内部 z-index 计算闭合 */
    position: relative;
    isolation: isolate;
    /* 章节自带版心；PoemBeat 内部再各自 max-width: 1280px 居中 */
    width: 100%;
    padding: 4rem 0 2rem;
  }

  .section-title {
    font-size: 2rem;
    line-height: 1.1;
    color: var(--c-sage);
    font-weight: 300;
    margin: 0 auto 2rem;
    text-align: center;
  }

  @media (min-width: 960px) {
    .section-title {
      font-size: 2.25rem;
    }
  }

  @media (max-width: 540px) {
    .section-title {
      font-size: 1.75rem;
      margin: 0 auto 1.5rem;
    }
  }
</style>

<script>
  /*
   * v1.56（v1.55 P2 #1+#2 修）·  scroll-progress driven choreography
   *
   *   v1.55 之前是 "一次 IO 触发 .visible + 一次 CSS transition" 的 one-shot reveal。
   *   v1.56 让每个 beat 在 sticky stage 被钉住时，根据"已滚多少 / 总可滚多少"算出
   *   归一化进度 p ∈ [0, 1]，把 p 与三个分阶段变量写到 beat 元素的 CSS 自定义属性上：
   *     --p           主进度（线性 0→1）
   *     --p-photo-1   phase-1（0..0.35 段映射到 0→1，之后保持 1）
   *     --p-photo-2   phase-2（0.35..0.7 段映射到 0→1）
   *     --p-text      phase-3（0.55..0.9 段映射到 0→1）
   *   PoemBeat 的 layout CSS 全用 calc(var(--p)) 表达 transform / mask / opacity，
   *   每帧 rAF 重写 → CSS calc 即时反映 → 真正的 scroll-driven choreography。
   *
   * 性能：
   *   - rAF 仅在 IO 报告 beat 进视口时跑；离开 viewport → cancelAnimationFrame
   *   - 单帧只 read 一次 getBoundingClientRect + write 4 个 CSS 变量到 beat（成本恒定）
   *   - prefers-reduced-motion → 不跑 rAF，所有变量直接写 1（PoemBeat 同时也有 CSS 兜底）
   *
   * 调试：window.__storyPoem.progress() 看每个 beat 当前 --p / 子阶段值
   */
  (function setupStoryPoemScroller() {
    if (typeof window === "undefined") return;

    const beats = Array.from(
      document.querySelectorAll<HTMLElement>(".poem-beat"),
    );
    if (beats.length === 0) return;

    function clamp01(n: number): number {
      return n < 0 ? 0 : n > 1 ? 1 : n;
    }

    // 把 phase 变量统一写在 beat 元素上（CSS calc 直接读到）。
    function writeProgress(beat: HTMLElement, p: number): void {
      const pPhoto1 = clamp01(p / 0.35);
      const pPhoto2 = clamp01((p - 0.35) / 0.35);
      const pText = clamp01((p - 0.55) / 0.35);
      beat.style.setProperty("--p", String(p));
      beat.style.setProperty("--p-photo-1", String(pPhoto1));
      beat.style.setProperty("--p-photo-2", String(pPhoto2));
      beat.style.setProperty("--p-text", String(pText));
    }

    // prefers-reduced-motion：跳过 rAF，所有 beat 直接显示完整 composed 帧。
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReduced) {
      beats.forEach((b) => writeProgress(b, 1));
      return;
    }

    // 每个 beat 一份 tracker：rAF id + inView flag + 计算函数。
    type Tracker = {
      beat: HTMLElement;
      rafId: number;
      inView: boolean;
    };
    const trackers = new Map<HTMLElement, Tracker>();

    function computeProgress(beat: HTMLElement): number {
      // outer .poem-beat 高度 = scroll spacer；inner .poem-stage 是 sticky 100vh。
      // 当 beat.top = 0（刚滚到 stage 顶）→ p=0
      // 当 beat.bottom = vh（刚要离开 stage）→ p=1
      // 总可滚距离 = beat.height - vh
      const rect = beat.getBoundingClientRect();
      const vh = window.innerHeight;
      const scrollable = beat.offsetHeight - vh;
      if (scrollable <= 0) return 1; // beat 比 vh 还矮：直接给 final 帧
      const scrolled = -rect.top; // 顶部滚出视口的距离
      return clamp01(scrolled / scrollable);
    }

    function tick(beat: HTMLElement): void {
      const t = trackers.get(beat);
      if (!t) return;
      t.rafId = 0;
      if (!t.inView) return;
      writeProgress(beat, computeProgress(beat));
      t.rafId = window.requestAnimationFrame(() => tick(beat));
    }

    function ensureRunning(beat: HTMLElement): void {
      const t = trackers.get(beat);
      if (!t || t.rafId !== 0 || !t.inView) return;
      t.rafId = window.requestAnimationFrame(() => tick(beat));
    }

    function stop(beat: HTMLElement): void {
      const t = trackers.get(beat);
      if (!t || t.rafId === 0) return;
      window.cancelAnimationFrame(t.rafId);
      t.rafId = 0;
    }

    // 单 IO 监听全部 beat；进视口 → tracker.inView=true → ensureRunning；
    // 离视口 → tracker.inView=false → stop。多个 threshold 让边界更精细。
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const beat = entry.target as HTMLElement;
          const t = trackers.get(beat);
          if (!t) continue;
          t.inView = entry.isIntersecting;
          if (t.inView) {
            // 进入视口立刻先写一次（避免第一帧还显示初始 --p:0）
            writeProgress(beat, computeProgress(beat));
            ensureRunning(beat);
          } else {
            stop(beat);
            // 离开视口写一次终态：在视口上方时 p=1（已滚过），在视口下方时 p=0（未到达）
            // computeProgress 在两种情况下分别返回 1 / 0，符合预期，无需额外分支。
          }
        }
      },
      {
        // 上下都给一点 margin，让 stage 进 / 出视口时有"准备帧"
        rootMargin: "10% 0px 10% 0px",
        threshold: [0, 0.05, 0.95, 1],
      },
    );

    beats.forEach((beat) => {
      trackers.set(beat, { beat, rafId: 0, inView: false });
      io.observe(beat);
    });

    // 调试钩子：window.__storyPoem.progress() / .list()
    (
      window as unknown as {
        __storyPoem?: {
          progress: () => Record<
            string,
            { p: number; p1: number; p2: number; pt: number }
          >;
          list: () => string[];
        };
      }
    ).__storyPoem = {
      progress: () => {
        const out: Record<
          string,
          { p: number; p1: number; p2: number; pt: number }
        > = {};
        beats.forEach((b) => {
          const id = b.dataset.beatId ?? "?";
          const css = getComputedStyle(b);
          out[id] = {
            p: Number(css.getPropertyValue("--p")) || 0,
            p1: Number(css.getPropertyValue("--p-photo-1")) || 0,
            p2: Number(css.getPropertyValue("--p-photo-2")) || 0,
            pt: Number(css.getPropertyValue("--p-text")) || 0,
          };
        });
        return out;
      },
      list: () =>
        Array.from(document.querySelectorAll<HTMLElement>(".poem-beat"))
          .map((e) => e.dataset.beatId ?? "?")
          .sort(),
    };
  })();
</script>
