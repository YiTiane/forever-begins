---
/**
 * PoemBeat.astro · §2 第一章单个 beat 渲染（v0.7 · v1.59 constraint-based layout）
 *
 * v0.7 修 v1.58 审计两处 P2（窄屏 / 小平板纵向构图碎掉 + exit-fade 反而留空白）：
 *
 *   v1.58 之前 layout 用「magic % + clamp + 媒体查询断点」硬编码，照片宽 / 文字宽 / gap
 *   全是凑出来的；窄屏几乎必崩。v1.59 把这套替换成 src/lib/story/beatLayoutSolver.ts
 *   的 **constraint-based solver**：
 *     - 输入：viewport(vw,vh) × layout 类型 × photo aspectRatio[]
 *     - 输出：CSS 自定义属性（--photo-w / --photo-h / --text-max-w / --stage-gap /
 *       --stage-cols 等）
 *     - StoryPoemScroller 在 init / window.resize 时跑一次 solver，写到 `.poem-beat`
 *       上；CSS 只负责 `width: var(--photo-w)` / `gap: var(--stage-gap)` 这种消费工作
 *     - 滚动 progress（--p / --p-photo-1/2 / --p-text）继续每帧 rAF flush，互不干扰
 *
 *   同时 v1.59 也修 v1.58 P2 #4（exit-fade 反而出现整屏空白）：
 *     - 收紧每个 beat 的 min-height，把 release zone 从 v1.58 的 ~40-140vh 压到 10-30vh
 *       （sticky 100vh + 短 release）；自然滚动跨过这点的时间 ≪ 一秒，肉眼察觉不到
 *     - 删掉 v1.58 的 `.poem-stage` exit-fade —— 既然 release zone 极短，让两个 beat 在
 *       这 10-30vh 自然重叠比强行 fade 出空白更合理；用户审计具体说明的"空白屏"由此修复
 *
 *   每张 photo 通过 data-aspect-ratio 暴露 width/height ratio 给 solver；缺失时 solver
 *   会用合理 fallback。
 *
 * v0.6 修 v1.57 审计 P2 #3+#4：541-719px 断点缺口下沉到 541px；.poem-stage 加 exit-fade
 *   防 beat 跨转时半截上下两段并存。v1.59 后断点逻辑被 solver 接管，exit-fade 已删除。
 *
 * v0.5 修 v1.56 审计 P2 #1：v1.56 的 grid 1fr/auto + align-self start/end 把 text 与 photo
 *   拆到 100vh 两端的"残缺帧"问题，全部 4 套 layout 重写为 baseline opacity:1 + 紧凑居中堆叠。
 *
 * v0.4 修 v1.55 审计 P2 #1+#2：cinematic stage 架构（外层 scroll spacer + 内层 100vh sticky）。
 *
 * v0.3 修 v1.54 审计：role-driven layout 落地（4 套 data-layout CSS）。
 *
 * v0.2 修 v1.53 P2 #2：data-photo-count 从 .poem-beat 挪到 .poem-photos 让选择器命中。
 *
 * 落地范围（v1.59 收口标准）：
 *   ✓ 4 套 data-layout 真正不同的空间组合 + per-photo 入场 settle
 *   ✓ photo 尺寸 / 文字宽 / gap 全部由 solver 在 viewport 维度求解
 *   ✓ sticky cinematic stage（外层 110-150vh 短 spacer + 内层 100vh sticky）
 *   ✓ scroll-progress driven choreography（StoryPoemScroller 写 --p 等变量，CSS calc 消费）
 *   ✓ a11y：sr-only h3 aria-labelledby + reduced-motion fallback
 *
 * **NOT in this batch**（仍留 §2 后续刀）：
 *   ✗ vignette / overlap / reveal / wooden / pearl 五套 layout solver + CSS（schema 已留位）
 *   ✗ 文字字符级 stagger / blur enter（Phase 5 motion polish）
 *   ✗ beat 05 [N] 天 daysTogether CountUp（DESIGN §2.D · 留独立小刀）
 *   ✗ 鼠标 / 真 inertia parallax（CSS calc scroll-progress 已能表达"远近 settle"）
 */
import CdnImage from "@/components/CdnImage.astro";

interface BeatPhoto {
  stem: string;
  cdnTarget:
    | "snow-a"
    | "snow-b"
    | "grassland"
    | "wooden-door"
    | "pearl"
    | "retro"
    | "misc";
  alt: string;
  role:
    | "far"
    | "near"
    | "top-left"
    | "bottom-right"
    | "center"
    | "anchor"
    | "vignette"
    | "overlap"
    | "reveal"
    | "wooden"
    | "pearl";
  width?: number;
  height?: number;
}

type BeatLayout =
  | "parallax-pair"
  | "diagonal-gaze"
  | "radial-mask"
  | "anchor-single"
  | "vignette"
  | "overlap"
  | "reveal"
  | "wooden"
  | "pearl";

interface Props {
  id: string; // '01'..'12'
  layout?: BeatLayout;
  lines: string[];
  photos: BeatPhoto[];
  /** 第一帧首屏内（极少数：仅 §2 第 01 个 beat 紧邻 §1）→ priority 'high'；其它 'auto' lazy。 */
  firstAboveFold?: boolean;
}

const { id, layout, lines, photos, firstAboveFold = false } = Astro.props;

const headingId = `beat-${id}-heading`;
const firstLine = lines[0] ?? "";

// 给 solver 用的 aspect ratio：原始 width/height 算 w/h 比；缺失时按 layout 给 fallback
function getAspectRatio(p: BeatPhoto): string {
  if (p.width && p.height) return (p.width / p.height).toFixed(4);
  // portrait fallback for diagonal-gaze; landscape fallback for others
  if (p.role === "top-left" || p.role === "bottom-right") return "0.6667";
  return "1.5";
}
---

<section
  class="poem-beat"
  data-beat-id={id}
  data-layout={layout}
  aria-labelledby={headingId}
>
  <div class="poem-stage">
    <h3 id={headingId} class="sr-only">
      第 {id} 段 · {firstLine}
    </h3>

    <div class="poem-text cn-song">
      {lines.map((line) => <p>{line}</p>)}
    </div>

    {
      photos.length > 0 && (
        <div
          class="poem-photos"
          data-photo-count={photos.length}
          data-roles={photos.map((p) => p.role).join(",")}
        >
          {photos.map((photo) => (
            <figure
              class="poem-photo"
              data-role={photo.role}
              data-aspect-ratio={getAspectRatio(photo)}
            >
              <CdnImage
                cdnTarget={photo.cdnTarget}
                stem={photo.stem}
                alt={photo.alt}
                priority={firstAboveFold ? "high" : "auto"}
                widths={[320, 640, 1024, 1600, 2400]}
                sizes="(min-width: 720px) 38vw, (min-width: 540px) 60vw, 90vw"
                width={photo.width}
                height={photo.height}
              />
            </figure>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  /* ────────────────────────────────────────────────────────────── */
  /* 外层 scroll-spacer · 高度 = 100vh sticky + 极短 release zone     */
  /* v1.59 收紧 release zone：从 v1.58 的 60-140vh → 10-30vh         */
  /* 自然滚动越过 release zone < 半秒，无需 exit-fade 也不会留空白    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-beat {
    position: relative;
    /* 默认 fallback（无 data-layout 时）：130vh */
    min-height: 130vh;
    /* phase 变量初值 0；StoryPoemScroller 的 rAF 接管后 0..1 写入 */
    --p: 0;
    --p-photo-1: 0;
    --p-photo-2: 0;
    --p-text: 0;
    /* solver 输出变量 fallback —— 在 JS 接管前给一个能看的初始值 */
    --stage-cols: 1fr;
    --stage-gap: 24px;
    --text-col-w: 100%;
    --text-max-w: 100%;
    --photos-col-w: 100%;
    --photos-col-h: 60vh;
    --photo-w: 80%;
    --photo-h: auto;
    --photo-far-w: 56%;
    --photo-far-h: auto;
    --photo-near-w: 64%;
    --photo-near-h: auto;
    --photo-tl-w: 240px;
    --photo-tl-h: auto;
    --photo-br-w: 240px;
    --photo-br-h: auto;
  }
  .poem-beat[data-layout="parallax-pair"] {
    min-height: 150vh;
  }
  .poem-beat[data-layout="diagonal-gaze"] {
    min-height: 160vh;
  }
  .poem-beat[data-layout="radial-mask"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="anchor-single"] {
    min-height: 130vh;
  }

  /* ────────────────────────────────────────────────────────────── */
  /* sticky 100vh stage                                              */
  /* ────────────────────────────────────────────────────────────── */
  .poem-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: grid;
    grid-template-columns: var(--stage-cols);
    grid-template-rows: 1fr;
    align-items: center;
    justify-items: center;
    padding: 2rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    box-sizing: border-box;
    gap: var(--stage-gap);
  }

  /* sr-only 兜底 */
  .poem-stage :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ────────────────────────────────────────────────────────────── */
  /* 文字 baseline                                                    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-text {
    color: var(--c-olive-ink);
    font-weight: 300;
    font-size: 1.5rem;
    line-height: 1.85;
    text-align: center;
    width: 100%;
  }
  .poem-text p {
    margin: 0.35em 0;
  }

  /* 移动端字号收一档 */
  @media (max-width: 540px) {
    .poem-text {
      font-size: 1.25rem;
      line-height: 1.7;
    }
  }

  /* ────────────────────────────────────────────────────────────── */
  /* 照片 baseline                                                    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-photos {
    display: grid;
    gap: 1.25rem;
    width: 100%;
    grid-template-columns: 1fr;
  }
  .poem-photo {
    margin: 0;
    box-shadow: var(--shadow-paper);
    will-change: transform, opacity, filter;
  }
  .poem-photo :global(picture),
  .poem-photo :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = parallax-pair · beat 01                                 */
  /* solver 给 stage 双列 + photos 容器尺寸；CSS 只放固定 absolute     */
  /* 位置 + 入场 transform                                           */
  /* ──────────────────────────────────────────────────────────────  */
  @media (min-width: 541px) {
    .poem-beat[data-layout="parallax-pair"] .poem-text {
      grid-column: 1;
      align-self: center;
      justify-self: end;
      text-align: left;
      max-width: var(--text-col-w);
      z-index: 2;
      transform: translateX(calc((1 - var(--p, 0)) * -8px));
    }
    .poem-beat[data-layout="parallax-pair"] .poem-photos {
      grid-column: 2;
      position: relative;
      align-self: center;
      width: var(--photos-col-w);
      height: var(--photos-col-h);
      max-width: none;
      grid-template-columns: 1fr;
      gap: 0;
      z-index: 1;
    }
    .poem-beat[data-layout="parallax-pair"] .poem-photo[data-role="far"] {
      position: absolute;
      top: 0;
      right: 0;
      width: var(--photo-far-w);
      height: var(--photo-far-h);
      filter: saturate(0.92);
      transform: translateY(calc((1 - var(--p, 0)) * -14%))
        scale(calc(0.96 + var(--p, 0) * 0.04));
    }
    .poem-beat[data-layout="parallax-pair"] .poem-photo[data-role="near"] {
      position: absolute;
      bottom: 0;
      left: 0;
      width: var(--photo-near-w);
      height: var(--photo-near-h);
      z-index: 1;
      transform: translateY(calc((1 - var(--p, 0)) * 14%))
        scale(calc(0.96 + var(--p, 0) * 0.04));
    }
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = diagonal-gaze · beat 02                                 */
  /* ──────────────────────────────────────────────────────────────  */
  @media (min-width: 541px) {
    .poem-beat[data-layout="diagonal-gaze"] .poem-stage {
      grid-template-columns: 1fr;
      grid-template-rows: 1fr;
      padding: 0;
    }
    .poem-beat[data-layout="diagonal-gaze"] .poem-text {
      grid-area: 1 / 1;
      align-self: center;
      justify-self: center;
      max-width: var(--text-max-w);
      text-align: center;
      z-index: 2;
      padding: 1.25rem 1.5rem;
      background: rgba(245, 240, 230, 0.7);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: var(--radius-sm);
      transform: translateY(calc((1 - var(--p, 0)) * 6px));
    }
    .poem-beat[data-layout="diagonal-gaze"] .poem-photos {
      grid-area: 1 / 1;
      position: relative;
      width: 100%;
      height: 100%;
      grid-template-columns: 1fr;
      gap: 0;
      z-index: 1;
    }
    .poem-beat[data-layout="diagonal-gaze"] .poem-photo[data-role="top-left"] {
      position: absolute;
      top: 4%;
      left: 4%;
      width: var(--photo-tl-w);
      height: var(--photo-tl-h);
      transform: translate(
        calc((1 - var(--p, 0)) * -15%),
        calc((1 - var(--p, 0)) * -15%)
      );
    }
    .poem-beat[data-layout="diagonal-gaze"]
      .poem-photo[data-role="bottom-right"] {
      position: absolute;
      bottom: 4%;
      right: 4%;
      width: var(--photo-br-w);
      height: var(--photo-br-h);
      transform: translate(
        calc((1 - var(--p, 0)) * 15%),
        calc((1 - var(--p, 0)) * 15%)
      );
    }
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = radial-mask · beat 03                                   */
  /* solver 给 photo 单图尺寸；CSS 单 stage 紧凑居中堆叠              */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="radial-mask"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="radial-mask"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="radial-mask"] .poem-photo[data-role="center"] {
    width: var(--photo-w);
    height: var(--photo-h);
    --mask-inner: calc(30% + var(--p, 0) * 25%);
    --mask-outer: calc(60% + var(--p, 0) * 35%);
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 1) var(--mask-inner),
      rgba(0, 0, 0, 0) var(--mask-outer)
    );
    mask-image: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 1) var(--mask-inner),
      rgba(0, 0, 0, 0) var(--mask-outer)
    );
    box-shadow: none;
    transform: scale(calc(1.06 - var(--p, 0) * 0.06));
    filter: saturate(calc(0.88 + var(--p, 0) * 0.12));
  }
  .poem-beat[data-layout="radial-mask"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = anchor-single · beat 04 / 05                            */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="anchor-single"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="anchor-single"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="anchor-single"] .poem-photo[data-role="anchor"] {
    width: var(--photo-w);
    height: var(--photo-h);
    transform: scale(calc(0.94 + var(--p, 0) * 0.06))
      translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-layout="anchor-single"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* 移动端 · ≤ 540px（windows 取消 sticky / absolute，单列流式堆叠） */
  /* solver 在窄屏依然给出尺寸值，但视觉上简化为竖向流式             */
  /* ──────────────────────────────────────────────────────────────  */
  @media (max-width: 540px) {
    .poem-beat,
    .poem-beat[data-layout] {
      min-height: 100vh;
    }
    .poem-stage {
      position: static;
      height: auto;
      min-height: 100vh;
      overflow: visible;
      grid-template-columns: 1fr !important;
      grid-template-rows: auto auto !important;
      padding: 3rem 1rem;
      gap: 1.25rem !important;
    }
    .poem-text {
      text-align: center !important;
      max-width: 100% !important;
      grid-column: auto !important;
      grid-area: auto !important;
      transform: none !important;
      background: transparent !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      padding: 0 !important;
    }
    .poem-photos {
      max-width: 100% !important;
      width: 100% !important;
      height: auto !important;
      grid-area: auto !important;
      grid-column: auto !important;
      grid-template-columns: 1fr !important;
      position: static !important;
      gap: 1rem !important;
    }
    .poem-photo,
    .poem-photo[data-role] {
      position: static !important;
      width: 100% !important;
      height: auto !important;
      transform: none !important;
      filter: none !important;
      mask-image: none !important;
      -webkit-mask-image: none !important;
    }
    .poem-photo :global(picture),
    .poem-photo :global(img) {
      height: auto !important;
      object-fit: contain;
    }
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* prefers-reduced-motion · 完整 composed 帧 + 零动画                 */
  /* ──────────────────────────────────────────────────────────────  */
  @media (prefers-reduced-motion: reduce) {
    .poem-beat {
      --p: 1;
      --p-photo-1: 1;
      --p-photo-2: 1;
      --p-text: 1;
    }
    .poem-photo {
      will-change: auto;
    }
  }
</style>
