---
/**
 * PoemBeat.astro · §2 第一章单个 beat 渲染（v0.9 · v1.62 batch 4：5 套新 layout 全量上线）
 *
 * v0.9 新增（v1.62）：
 *   - **5 套新 layout 视觉**：vignette / overlap / reveal / wooden / pearl，与 schema enum
 *     九项一一对应，从此 beat 06-10 不再回退到通用样式
 *     · vignette (06)：edge 暗角 vignette 圈（夜色感）+ 文字三行 stagger fade-in
 *     · overlap (07)：双层 drop-shadow 模拟"两个灵魂"位错重合 → settle 到一张
 *     · reveal  (08)：clip-path inset 从内向外展开图像（"卸下防备"）
 *     · wooden  (09)：dashed 缝线包边 + 入场 fade-in
 *     · pearl   (10)：linear-gradient 高光横扫
 *   - **SSR 默认 data-story-mode="portrait"** 减轻 FOUC：在 JS 决定 actual mode 前，
 *     大多数访客（手机 / 小平板竖屏）已在 portrait 视觉下；wide 桌面用户仅一帧
 *     re-layout（acceptable）。runtime applyLayout 始终覆写。
 *
 * 视觉模式责任划分（v1.61 起的契约）：
 *   - compact：≤540 phone，static flow，所有 layout 退化为单列堆叠
 *   - portrait：large phone / small tablet portrait → 自然纵向流式（非 sticky）
 *   - wide：landscape tablet / desktop → sticky 100vh cinematic stage + 双列 / 对角
 *
 *   **sticky 100vh stage 仅 wide 模式生效**：portrait 模式 .poem-stage 的 position
 *   被覆盖为 relative + height auto，整个 beat 在自然文档流中以一帧紧凑构图存在。
 *   compact 模式更进一步取消 absolute / mask / transform，回退纯流式。
 *
 * v0.8 修 v1.60 后续截图审计：把视觉模式拆成 compact / portrait / wide。
 *   真实市场视口不是单一 breakpoint：604 / 705 / 820 这类窄版、小平板竖屏不能硬套
 *   desktop wide frame，也不能退回纯手机流式。StoryPoemScroller 现在把 solver 判定出的
 *   `data-story-mode` 写到 beat 上；CSS 只跟这个模式走，不再自行决定核心布局。
 *
 * v0.7 修 v1.58 审计两处 P2（窄屏 / 小平板纵向构图碎掉 + exit-fade 反而留空白）：
 *
 *   v1.58 之前 layout 用「magic % + clamp + 媒体查询断点」硬编码，照片宽 / 文字宽 / gap
 *   全是凑出来的；窄屏几乎必崩。v1.59 把这套替换成 src/lib/story/beatLayoutSolver.ts
 *   的 **constraint-based solver**：
 *     - 输入：viewport(vw,vh) × layout 类型 × photo aspectRatio[]
 *     - 输出：CSS 自定义属性（--photo-w / --photo-h / --text-max-w / --stage-gap /
 *       --stage-cols 等）
 *     - StoryPoemScroller 在 init / window.resize 时跑一次 solver，写到 `.poem-beat`
 *       上；CSS 只负责 `width: var(--photo-w)` / `gap: var(--stage-gap)` 这种消费工作
 *     - 滚动 progress（--p / --p-photo-1/2 / --p-text）继续每帧 rAF flush，互不干扰
 *
 *   同时 v1.59 也修 v1.58 P2 #4（exit-fade 反而出现整屏空白）：
 *     - 收紧每个 beat 的 min-height，把 release zone 从 v1.58 的 ~40-140vh 压到 10-30vh
 *       （sticky 100vh + 短 release）；自然滚动跨过这点的时间 ≪ 一秒，肉眼察觉不到
 *     - 删掉 v1.58 的 `.poem-stage` exit-fade —— 既然 release zone 极短，让两个 beat 在
 *       这 10-30vh 自然重叠比强行 fade 出空白更合理；用户审计具体说明的"空白屏"由此修复
 *
 *   每张 photo 通过 data-aspect-ratio 暴露 width/height ratio 给 solver；缺失时 solver
 *   会用合理 fallback。
 *
 * v0.6 修 v1.57 审计 P2 #3+#4：541-719px 断点缺口下沉到 541px；.poem-stage 加 exit-fade
 *   防 beat 跨转时半截上下两段并存。v1.59 后断点逻辑被 solver 接管，exit-fade 已删除。
 *
 * v0.5 修 v1.56 审计 P2 #1：v1.56 的 grid 1fr/auto + align-self start/end 把 text 与 photo
 *   拆到 100vh 两端的"残缺帧"问题，全部 4 套 layout 重写为 baseline opacity:1 + 紧凑居中堆叠。
 *
 * v0.4 修 v1.55 审计 P2 #1+#2：cinematic stage 架构（外层 scroll spacer + 内层 100vh sticky）。
 *
 * v0.3 修 v1.54 审计：role-driven layout 落地（4 套 data-layout CSS）。
 *
 * v0.2 修 v1.53 P2 #2：data-photo-count 从 .poem-beat 挪到 .poem-photos 让选择器命中。
 *
 * 落地范围（v1.59 收口标准）：
 *   ✓ 4 套 data-layout 真正不同的空间组合 + per-photo 入场 settle
 *   ✓ photo 尺寸 / 文字宽 / gap 全部由 solver 在 viewport 维度求解
 *   ✓ sticky cinematic stage（外层 110-150vh 短 spacer + 内层 100vh sticky）
 *   ✓ scroll-progress driven choreography（StoryPoemScroller 写 --p 等变量，CSS calc 消费）
 *   ✓ a11y：sr-only h3 aria-labelledby + reduced-motion fallback
 *
 * **NOT in this batch**（仍留 §2 后续刀）：
 *   ✗ vignette / overlap / reveal / wooden / pearl 五套 layout solver + CSS（schema 已留位）
 *   ✗ 文字字符级 stagger / blur enter（Phase 5 motion polish）
 *   ✗ beat 05 [N] 天 daysTogether CountUp（DESIGN §2.D · 留独立小刀）
 *   ✗ 鼠标 / 真 inertia parallax（CSS calc scroll-progress 已能表达"远近 settle"）
 */
import CdnImage from "@/components/CdnImage.astro";
import SnowAtmosphere from "@/components/story/SnowAtmosphere.astro";

interface BeatPhoto {
  stem: string;
  cdnTarget:
    | "snow-a"
    | "snow-b"
    | "grassland"
    | "wooden-door"
    | "pearl"
    | "retro"
    | "misc";
  alt: string;
  role:
    | "far"
    | "near"
    | "top-left"
    | "bottom-right"
    | "center"
    | "anchor"
    | "vignette"
    | "overlap"
    | "reveal"
    | "wooden"
    | "pearl";
  width?: number;
  height?: number;
  /** v1.64（v1.63 audit P2 修）：fit 升级为必填，schema 强约束。
   *  人像 / 主体不可裁切 → "contain"；横向氛围图 → "cover"（必要时配 focalPoint） */
  fit: "contain" | "cover";
  /** v1.63: cover 模式下 box 偏移 (0..1)；contain 时忽略 */
  focalPoint?: { x: number; y: number };
}

type BeatLayout =
  | "parallax-pair"
  | "diagonal-gaze"
  | "radial-mask"
  | "anchor-single"
  | "vignette"
  | "overlap"
  | "reveal"
  | "wooden"
  | "pearl";

interface Props {
  id: string; // '01'..'12'
  layout?: BeatLayout;
  lines: string[];
  photos: BeatPhoto[];
  /** 第一帧首屏内（极少数：仅 §2 第 01 个 beat 紧邻 §1）→ priority 'high'；其它 'auto' lazy。 */
  firstAboveFold?: boolean;
}

const { id, layout, lines, photos, firstAboveFold = false } = Astro.props;

const headingId = `beat-${id}-heading`;
const firstLine = lines[0] ?? "";

/**
 * v1.66 SSR 默认 data-text-placement（JS 接管 applyLayout 后仍会覆写）。
 * 与 solver 在 portrait 模式下的输出对齐，减轻 first-paint 与 hydrate 之间
 * 的 layout shift。wooden 在 wide 才走 side-text-photo，SSR 默认 portrait
 * → below 即可（JS 在 wide 设备 hydrate 后切到 side-text-photo）。
 */
function getSsrTextPlacement(l: BeatLayout | undefined): string {
  if (l === "vignette") return "overlay-bottom";
  if (l === "overlap") return "overlay-center";
  if (l === "reveal" || l === "pearl") return "overlay-top";
  if (l === "parallax-pair" || l === "diagonal-gaze") return "between";
  return "below";
}
const ssrTextPlacement = getSsrTextPlacement(layout);

// 给 solver 用的 aspect ratio：原始 width/height 算 w/h 比；缺失时按 layout 给 fallback
function getAspectRatio(p: BeatPhoto): string {
  if (p.width && p.height) return (p.width / p.height).toFixed(4);
  // portrait fallback for diagonal-gaze; landscape fallback for others
  if (p.role === "top-left" || p.role === "bottom-right") return "0.6667";
  return "1.5";
}

/**
 * v1.64（v1.63 audit P2 修）：fit 升级为 schema 必填字段。
 *   组件层不再做"自动推导 fallback"——schema validator 已强约束 photo 必带 fit；
 *   getFit 直接 return p.fit。这样视觉契约从"凭 metadata 推导"改为"显式声明"，
 *   防止 metadata 与 CDN 真实尺寸不一致（v1.63 audit 实测发现 5 张 1600×2400
 *   竖幅人像被错标 3000×2000 横幅）时静默裁掉人物主体。
 */
function getFit(p: BeatPhoto): "contain" | "cover" {
  return p.fit;
}

/**
 * focal point → object-position CSS 值（cover 时生效；contain 时忽略）。
 * 若未提供 focalPoint，返回 undefined → CSS 用默认 center。
 */
function getObjectPositionStyle(p: BeatPhoto): string | undefined {
  if (!p.focalPoint) return undefined;
  const x = (p.focalPoint.x * 100).toFixed(1);
  const y = (p.focalPoint.y * 100).toFixed(1);
  return `--object-position: ${x}% ${y}%`;
}
---

<section
  class="poem-beat"
  data-beat-id={id}
  data-layout={layout}
  data-story-mode="portrait"
  data-text-placement={ssrTextPlacement}
  aria-labelledby={headingId}
>
  <div class="poem-stage">
    <h3 id={headingId} class="sr-only">
      第 {id} 段 · {firstLine}
    </h3>

    <div class="poem-text cn-song">
      {lines.map((line) => <p>{line}</p>)}
    </div>

    {
      photos.length > 0 && (
        <div
          class="poem-photos"
          data-photo-count={photos.length}
          data-roles={photos.map((p) => p.role).join(",")}
        >
          {photos.map((photo) => (
            <figure
              class="poem-photo"
              data-role={photo.role}
              data-aspect-ratio={getAspectRatio(photo)}
              data-fit={getFit(photo)}
              style={getObjectPositionStyle(photo)}
            >
              <CdnImage
                cdnTarget={photo.cdnTarget}
                stem={photo.stem}
                alt={photo.alt}
                priority={firstAboveFold ? "high" : "auto"}
                widths={[320, 640, 1024, 1600, 2400]}
                sizes="(min-width: 720px) 38vw, (min-width: 540px) 60vw, 90vw"
                width={photo.width}
                height={photo.height}
              />
              {/* v1.65：vignette layout 在 photo 之上叠 SnowAtmosphere canvas
                  雪粒子（仅 vignette role；canvas 自身 absolute inset:0 + IO 生命周期）*/}
              {layout === "vignette" && photo.role === "vignette" && (
                <SnowAtmosphere />
              )}
            </figure>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  /* ────────────────────────────────────────────────────────────── */
  /* 外层 scroll-spacer · 高度 = 100vh sticky + 极短 release zone     */
  /* v1.59 收紧 release zone：从 v1.58 的 60-140vh → 10-30vh         */
  /* 自然滚动越过 release zone < 半秒，无需 exit-fade 也不会留空白    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-beat {
    position: relative;
    /* 默认 fallback（无 data-layout / data-story-mode 时）：完整一屏 */
    min-height: 100vh;
    /* phase 变量初值 0；StoryPoemScroller 的 rAF 接管后 0..1 写入 */
    --p: 0;
    --p-photo-1: 0;
    --p-photo-2: 0;
    --p-text: 0;
    /* solver 输出变量 fallback —— 在 JS 接管前给一个能看的初始值 */
    --stage-cols: 1fr;
    --stage-gap: 24px;
    --text-col-w: 100%;
    --text-max-w: 100%;
    --photos-col-w: 100%;
    --photos-col-h: 60vh;
    --photo-w: 80%;
    --photo-h: auto;
    --photo-far-w: 56%;
    --photo-far-h: auto;
    --photo-near-w: 64%;
    --photo-near-h: auto;
    --photo-tl-w: 240px;
    --photo-tl-h: auto;
    --photo-br-w: 240px;
    --photo-br-h: auto;
  }
  .poem-beat[data-layout="parallax-pair"] {
    min-height: 150vh;
  }
  .poem-beat[data-layout="diagonal-gaze"] {
    min-height: 160vh;
  }
  .poem-beat[data-layout="radial-mask"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="anchor-single"] {
    min-height: 130vh;
  }
  /* v1.62 batch 4：新 5 套 single-photo layout（仅 wide 模式给 sticky scroll spacer 高度，
     portrait / compact 由后续 [data-story-mode="..."] 重置回 auto） */
  .poem-beat[data-layout="vignette"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="overlap"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="reveal"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="wooden"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="pearl"] {
    min-height: 130vh;
  }
  .poem-beat[data-story-mode="compact"],
  .poem-beat[data-story-mode="compact"][data-layout] {
    min-height: auto;
  }
  .poem-beat[data-story-mode="portrait"],
  .poem-beat[data-story-mode="portrait"][data-layout] {
    min-height: auto;
    padding: clamp(3rem, 7vh, 5rem) 0;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] {
    min-height: 145vh;
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] {
    min-height: 152vh;
  }
  .poem-beat[data-story-mode="wide"][data-layout="radial-mask"],
  .poem-beat[data-story-mode="wide"][data-layout="anchor-single"],
  .poem-beat[data-story-mode="wide"][data-layout="vignette"],
  .poem-beat[data-story-mode="wide"][data-layout="overlap"],
  .poem-beat[data-story-mode="wide"][data-layout="reveal"],
  .poem-beat[data-story-mode="wide"][data-layout="wooden"],
  .poem-beat[data-story-mode="wide"][data-layout="pearl"] {
    min-height: 125vh;
  }

  /* ────────────────────────────────────────────────────────────── */
  /* sticky 100vh stage                                              */
  /*                                                                 */
  /* v1.60 P2 #1：baseline 改 flex column，让所有 layout 在 narrow      */
  /* (541-719) 段都能用 solver 输出的 size 变量自然居中堆叠；wide      */
  /* (≥720) 才让 parallax-pair / diagonal-gaze 切到 grid 重叠模式。  */
  /* 修掉 v1.59 "solver 给 1fr / CSS 仍 2fr" 的模式不一致。           */
  /* ────────────────────────────────────────────────────────────── */
  .poem-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
    padding: 2rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .poem-beat[data-story-mode="portrait"] .poem-stage {
    position: relative;
    top: auto;
    height: auto;
    min-height: auto;
    overflow: visible;
    padding-block: clamp(1.5rem, 4vh, 2.5rem);
  }

  /* sr-only 兜底 */
  .poem-stage :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ────────────────────────────────────────────────────────────── */
  /* 文字 baseline                                                    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-text {
    color: var(--c-olive-ink);
    font-weight: 300;
    font-size: 1.5rem;
    line-height: 1.85;
    text-align: center;
    width: 100%;
    max-width: var(--text-max-w);
  }
  .poem-text p {
    margin: 0.35em 0;
  }

  /* 移动端字号收一档 */
  @media (max-width: 540px) {
    .poem-text {
      font-size: 1.25rem;
      line-height: 1.7;
    }
  }

  /* ────────────────────────────────────────────────────────────── */
  /* 照片 baseline                                                    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-photos {
    display: grid;
    gap: 1.25rem;
    width: 100%;
    grid-template-columns: 1fr;
  }
  .poem-photo {
    margin: 0;
    box-shadow: var(--shadow-paper);
    will-change: transform, opacity, filter;
    /* v1.63 默认 object-position 写在 CSS 变量上；调用方可通过 inline
       style="--object-position: 50% 30%" 给 cover 模式锁人物头部 */
    --object-position: center;
  }
  .poem-photo :global(picture),
  .poem-photo :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-sm);
    /* v1.63（v1.62 audit P2-A 修）：默认不再 object-fit: cover；
       由 [data-fit="..."] 显式声明，避免竖幅人像被裁掉脸/上半身。 */
  }
  .poem-photo[data-fit="cover"] :global(picture),
  .poem-photo[data-fit="cover"] :global(img) {
    object-fit: cover;
    object-position: var(--object-position, center);
  }
  .poem-photo[data-fit="contain"] :global(picture),
  .poem-photo[data-fit="contain"] :global(img) {
    object-fit: contain;
    /* contain 模式下 background 透出，给一个低饱和的纸白底配 paper-shadow */
    background: var(--c-paper, transparent);
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = parallax-pair · beat 01                                 */
  /*                                                                  */
  /* v1.64（v1.63 audit P2 修）：absolute overlap frame 仅 wide 模式。  */
  /*                                                                  */
  /* photo 尺寸（all modes）：solver 输出的 --photo-far/near-w/h       */
  /*   compact (≤540)：mobile fallback 单列堆叠                         */
  /*   portrait (541-899 / 高瘦视口)：display: contents + flex order，  */
  /*     真自然流：far photo（右对齐）→ 文字（居中）→ near photo        │
  /*     （左对齐）；align-self 暗示远近，不再 absolute overlap。        │
  /*     窄屏不再两图压叠破坏阅读节奏。                                 │
  /*   wide (≥900 + aspect ≥0.85)：grid 双列 + far/near 绝对定位重叠   */
  /*     + 入场 transform —— "记忆被慢慢推近"由 wide cinematic 表达。   │
  /* ──────────────────────────────────────────────────────────────  */
  /* photo 尺寸 baseline（所有模式都用 solver 输出的 box）*/
  .poem-beat[data-layout="parallax-pair"] .poem-photo[data-role="far"] {
    width: var(--photo-far-w);
    height: var(--photo-far-h);
    filter: saturate(0.92);
  }
  .poem-beat[data-layout="parallax-pair"] .poem-photo[data-role="near"] {
    width: var(--photo-near-w);
    height: var(--photo-near-h);
  }
  /* portrait 模式：display: contents 让 photos 子元素直接进 stage flex column；
     order 排"far → text → near"；align-self 暗示远近；不 absolute overlap */
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(1.25rem, 3vh, 2rem);
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-photos {
    display: contents;
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-photo[data-role="far"] {
    order: 1;
    align-self: flex-end;
    margin-right: clamp(0px, 4vw, 32px);
    transform: translateY(calc((1 - var(--p, 0)) * -8px));
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-text {
    order: 2;
    align-self: center;
    max-width: var(--text-max-w);
    text-align: center;
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-photo[data-role="near"] {
    order: 3;
    align-self: flex-start;
    margin-left: clamp(0px, 4vw, 32px);
    transform: translateY(calc((1 - var(--p, 0)) * 8px));
  }
  /* wide 模式：grid 双列 + far/near 绝对重叠 + 入场 transform */
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-stage {
    display: grid;
    grid-template-columns: var(--stage-cols);
    align-items: center;
    justify-items: center;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-text {
    grid-column: 1;
    align-self: center;
    justify-self: end;
    text-align: left;
    max-width: var(--text-col-w);
    z-index: 2;
    transform: translateX(calc((1 - var(--p, 0)) * -8px));
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-photos {
    grid-column: 2;
    position: relative;
    align-self: center;
    width: var(--photos-col-w);
    height: var(--photos-col-h);
    max-width: none;
    grid-template-columns: 1fr;
    gap: 0;
    z-index: 1;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"]
    .poem-photo[data-role="far"] {
    position: absolute;
    top: 0;
    right: 0;
    transform: translateY(calc((1 - var(--p, 0)) * -14%))
      scale(calc(0.96 + var(--p, 0) * 0.04));
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"]
    .poem-photo[data-role="near"] {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 1;
    transform: translateY(calc((1 - var(--p, 0)) * 14%))
      scale(calc(0.96 + var(--p, 0) * 0.04));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = diagonal-gaze · beat 02                                 */
  /*                                                                  */
  /* v1.63（v1.62 audit P2-B 修）：absolute corner frame 仅 wide 模式。 */
  /*                                                                  */
  /* photo 尺寸（all modes）：solver 输出的 --photo-tl/br-w/h           */
  /*   compact (≤540)：mobile fallback 全 !important 取消，单列堆叠     */
  /*   portrait (541-899 / 高瘦视口)：display: contents + flex order，  */
  /*     真自然流式：tl photo（左上对齐）→ 文字（居中）→ br photo       │
  /*     （右下对齐）；align-self 暗示对角，但人像绝不被 absolute 框碎掉。│
  /*   wide (≥900 + aspect ≥0.85)：grid 单 cell stack + tl/br 角落      */
  /*     absolute + 中间文字 backdrop-blur(8px) 浮起 + 入场 translate。│
  /* ──────────────────────────────────────────────────────────────  */
  /* photo 尺寸 baseline（所有模式都用 solver 输出的 box）*/
  .poem-beat[data-layout="diagonal-gaze"] .poem-photo[data-role="top-left"] {
    width: var(--photo-tl-w);
    height: var(--photo-tl-h);
  }
  .poem-beat[data-layout="diagonal-gaze"]
    .poem-photo[data-role="bottom-right"] {
    width: var(--photo-br-w);
    height: var(--photo-br-h);
  }
  /* portrait 模式：display: contents 让 photos 子元素直接进 stage flex column；
     用 order 把 text 排在两张人像中间，align-self 暗示对角而不依赖 absolute */
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(1.25rem, 3vh, 2rem);
  }
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-photos {
    /* 把 photos 容器"flat 化"，让两张 figure 直接成为 stage 的 flex 项 */
    display: contents;
  }
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="top-left"] {
    order: 1;
    align-self: flex-start;
    margin-left: clamp(0px, 4vw, 32px);
    transform: translate(
      calc((1 - var(--p, 0)) * -10px),
      calc((1 - var(--p, 0)) * -6px)
    );
  }
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-text {
    order: 2;
    align-self: center;
    max-width: var(--text-max-w);
    text-align: center;
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="bottom-right"] {
    order: 3;
    align-self: flex-end;
    margin-right: clamp(0px, 4vw, 32px);
    transform: translate(
      calc((1 - var(--p, 0)) * 10px),
      calc((1 - var(--p, 0)) * 6px)
    );
  }
  /* wide 模式：grid 单 cell stack + 角落 absolute + 文字 backdrop-blur 浮起 */
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-stage {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    padding: 0;
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-text {
    grid-area: 1 / 1;
    align-self: center;
    justify-self: center;
    max-width: var(--text-max-w);
    text-align: center;
    z-index: 2;
    padding: 1.25rem 1.5rem;
    background: rgba(245, 240, 230, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-sm);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-photos {
    grid-area: 1 / 1;
    position: relative;
    width: 100%;
    height: 100%;
    grid-template-columns: 1fr;
    gap: 0;
    z-index: 1;
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="top-left"] {
    position: absolute;
    top: 4%;
    left: 4%;
    transform: translate(
      calc((1 - var(--p, 0)) * -15%),
      calc((1 - var(--p, 0)) * -15%)
    );
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="bottom-right"] {
    position: absolute;
    bottom: 4%;
    right: 4%;
    transform: translate(
      calc((1 - var(--p, 0)) * 15%),
      calc((1 - var(--p, 0)) * 15%)
    );
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = radial-mask · beat 03                                   */
  /* solver 给 photo 单图尺寸；CSS 单 stage 紧凑居中堆叠              */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="radial-mask"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="radial-mask"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="radial-mask"] .poem-photo[data-role="center"] {
    width: var(--photo-w);
    height: var(--photo-h);
    --mask-inner: calc(30% + var(--p, 0) * 25%);
    --mask-outer: calc(60% + var(--p, 0) * 35%);
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 1) var(--mask-inner),
      rgba(0, 0, 0, 0) var(--mask-outer)
    );
    mask-image: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 1) var(--mask-inner),
      rgba(0, 0, 0, 0) var(--mask-outer)
    );
    box-shadow: none;
    transform: scale(calc(1.06 - var(--p, 0) * 0.06));
    filter: saturate(calc(0.88 + var(--p, 0) * 0.12));
  }
  .poem-beat[data-layout="radial-mask"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = anchor-single · beat 04 / 05                            */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="anchor-single"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="anchor-single"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="anchor-single"] .poem-photo[data-role="anchor"] {
    width: var(--photo-w);
    height: var(--photo-h);
    transform: scale(calc(0.94 + var(--p, 0) * 0.06))
      translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-layout="anchor-single"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = vignette · beat 06（夜色重点舞台 + 文字 overlay-bottom）   */
  /*                                                                   */
  /* v1.65（v1.64 audit P2-C 修）：从"暗角图 + 下方文字"升级为重点氛围  */
  /* 舞台。变化：                                                      │
  /*   1) text 从 below 改 overlay-bottom（solver 已输出 textPlacement） │
  /*   2) photo 占整个 stage（solver photoMaxWFactor 0.85→0.92，         │
  /*      photoMaxAbs 720→820；gap=0；text reserve=0）                  │
  /*   3) 暗角更深：edge alpha 0.6→0.78；inner stop 30%→18%（夜色更收）  │
  /*   4) text 浮卡：rgba(15,18,30,0.45) + backdrop-blur(6px) +         │
  /*      白文字 (0.95) + padding/border-radius —— 婚礼站亲密夜读语境  │
  /*   5) 三行 stagger 保留                                             │
  /*   6) <SnowAtmosphere /> canvas 雪粒子由 PoemBeat 在 vignette layout │
  /*      条件渲染（粒子动画 + IO 生命周期 + reduced-motion guard）     │
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="vignette"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    /* stage 自己已是 position: sticky / relative，containing block 给 text 用 */
  }
  .poem-beat[data-layout="vignette"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="vignette"] .poem-photo[data-role="vignette"] {
    width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }
  /* dark vignette 暗角（更深更收，强化夜色 / 重点感）*/
  .poem-beat[data-layout="vignette"] .poem-photo[data-role="vignette"]::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      rgba(8, 10, 24, 0) 18%,
      rgba(8, 10, 24, 0.4) 72%,
      rgba(8, 10, 24, 0.78) 100%
    );
    border-radius: var(--radius-sm);
    z-index: 2;
  }
  /* 文字浮卡：overlay-bottom + 半透明深底 + backdrop-blur + 白色文字 */
  .poem-beat[data-layout="vignette"][data-text-placement="overlay-bottom"]
    .poem-text {
    position: absolute;
    bottom: clamp(2rem, 6vh, 4rem);
    left: 50%;
    transform: translateX(-50%);
    width: min(var(--text-max-w), 88%);
    max-width: 92%;
    text-align: center;
    z-index: 4;
    padding: 1rem 1.5rem;
    background: rgba(15, 18, 30, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: rgba(255, 255, 255, 0.95);
    border-radius: var(--radius-sm);
  }
  /* 文字三行 stagger：每行用不同的 --p-text 区段 */
  .poem-beat[data-layout="vignette"] .poem-text p {
    transition: opacity 80ms linear;
  }
  .poem-beat[data-layout="vignette"] .poem-text p:nth-child(1) {
    opacity: clamp(0, calc(var(--p-text, 0) * 1.4), 1);
  }
  .poem-beat[data-layout="vignette"] .poem-text p:nth-child(2) {
    opacity: clamp(0, calc((var(--p-text, 0) - 0.18) * 1.6), 1);
  }
  .poem-beat[data-layout="vignette"] .poem-text p:nth-child(3) {
    opacity: clamp(0, calc((var(--p-text, 0) - 0.36) * 1.8), 1);
  }
  /* SnowAtmosphere canvas overlay 容器：z 在 photo 之上、暗角之下 */
  .poem-beat[data-layout="vignette"] .snow-atmosphere {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    border-radius: var(--radius-sm);
    /* v1.66 P3 修：mix-blend-mode: screen 让 canvas 雪粒子真正与下方
       photo / 暗角混合发光，而非只是普通透明白点。screen 比 add 柔，
       夜色暗部白雪发亮、亮部不爆色。v1.65 注释里的"screen blend"承诺
       由此真正生效（之前只在 canvas 内 globalCompositeOperation 不影响外部）。*/
    mix-blend-mode: screen;
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* v1.66 textPlacement 通用规则（按 data-text-placement 选择器）    */
  /*                                                                   */
  /* 各 layout 的 base CSS 仍是 "flex column 图 + 文居中 below"；        */
  /* 这些规则用更具体的 selector 在特定 layout 上覆盖为 overlay-* /     */
  /* side-* 模式，让 textPlacement 真正参与构图。                       */
  /* ──────────────────────────────────────────────────────────────  */

  /* —— overlap 单行短诗 → overlay-center（夜色 ghost 收敛之上浮卡） —— */
  .poem-beat[data-layout="overlap"][data-text-placement="overlay-center"]
    .poem-stage {
    position: relative;
  }
  .poem-beat[data-layout="overlap"][data-text-placement="overlay-center"]
    .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="overlap"][data-text-placement="overlay-center"]
    .poem-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) translateY(calc((1 - var(--p, 0)) * 6px));
    width: min(var(--text-max-w), 76%);
    z-index: 4;
    padding: 1rem 1.75rem;
    background: rgba(245, 240, 230, 0.7);
    backdrop-filter: blur(7px);
    -webkit-backdrop-filter: blur(7px);
    border-radius: var(--radius-sm);
    text-align: center;
    color: var(--c-olive-ink);
  }

  /* —— reveal 竖幅展开 → overlay-top（文字浮在顶端，photo 由内向外露出） —— */
  .poem-beat[data-layout="reveal"][data-text-placement="overlay-top"]
    .poem-stage {
    position: relative;
  }
  .poem-beat[data-layout="reveal"][data-text-placement="overlay-top"]
    .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="reveal"][data-text-placement="overlay-top"]
    .poem-text {
    position: absolute;
    top: clamp(1.5rem, 5vh, 3rem);
    left: 50%;
    transform: translateX(-50%) translateY(calc((1 - var(--p, 0)) * -6px));
    width: min(var(--text-max-w), 84%);
    z-index: 4;
    padding: 0.75rem 1.5rem;
    background: rgba(245, 240, 230, 0.65);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: var(--radius-sm);
    text-align: center;
    color: var(--c-olive-ink);
  }

  /* —— pearl 竖幅人像 + 高光 sweep → overlay-top（与 reveal 对称） —— */
  .poem-beat[data-layout="pearl"][data-text-placement="overlay-top"]
    .poem-stage {
    position: relative;
  }
  .poem-beat[data-layout="pearl"][data-text-placement="overlay-top"]
    .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="pearl"][data-text-placement="overlay-top"]
    .poem-text {
    position: absolute;
    top: clamp(1.5rem, 5vh, 3rem);
    left: 50%;
    transform: translateX(-50%) translateY(calc((1 - var(--p, 0)) * -6px));
    width: min(var(--text-max-w), 84%);
    z-index: 4;
    padding: 0.75rem 1.5rem;
    background: rgba(245, 240, 230, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: var(--radius-sm);
    text-align: center;
    color: var(--c-olive-ink);
  }

  /* —— wooden 横幅木门 + 3 行长诗 → wide 模式 side-text-photo（信件式） —— */
  /* 仅 wide 生效；portrait/compact 走默认 below */
  .poem-beat[data-layout="wooden"][data-text-placement="side-text-photo"]
    .poem-stage {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, var(--photo-w));
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    justify-items: center;
  }
  .poem-beat[data-layout="wooden"][data-text-placement="side-text-photo"]
    .poem-text {
    grid-column: 1;
    align-self: center;
    justify-self: end;
    text-align: left;
    max-width: var(--text-max-w);
    transform: translateX(calc((1 - var(--p, 0)) * -8px));
  }
  .poem-beat[data-layout="wooden"][data-text-placement="side-text-photo"]
    .poem-photos {
    grid-column: 2;
    align-self: center;
    width: var(--photo-w);
    max-width: var(--photo-w);
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = overlap · beat 07（双层 ghost 重合 → 收敛单图）           */
  /*                                                                   */
  /* 视觉：双侧白色 drop-shadow ghost；--p 0→1 把 ghost 偏移 12px→0     */
  /*   合到单图。"两个契合的灵魂" 由两层错位渐合表达。                 */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="overlap"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="overlap"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="overlap"] .poem-photo[data-role="overlap"] {
    width: var(--photo-w);
    height: var(--photo-h);
    /* 用 filter drop-shadow 实现"双层 ghost"——纯 CSS，不需要复制 DOM */
    filter: drop-shadow(
        calc((1 - var(--p, 0)) * 12px) 0 0 rgba(255, 255, 255, 0.32)
      )
      drop-shadow(calc((1 - var(--p, 0)) * -12px) 0 0 rgba(245, 240, 230, 0.32));
    transition: filter 120ms linear;
  }
  .poem-beat[data-layout="overlap"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = reveal · beat 08（clip-path inset 从中心向外展开）        */
  /*                                                                   */
  /* 视觉：图像四周 inset clip 从 8% → 0；--p 0→1 完整露出。            */
  /* "卸下防备" 由"图像层从遮蔽中展开"表达。                          */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="reveal"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="reveal"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="reveal"] .poem-photo[data-role="reveal"] {
    width: var(--photo-w);
    height: var(--photo-h);
    --reveal-inset: calc((1 - var(--p, 0)) * 9%);
    clip-path: inset(
      var(--reveal-inset) var(--reveal-inset) var(--reveal-inset)
        var(--reveal-inset) round 6px
    );
    transform: scale(calc(0.98 + var(--p, 0) * 0.02));
    transition:
      clip-path 120ms linear,
      transform 120ms linear;
  }
  .poem-beat[data-layout="reveal"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = wooden · beat 09（木门 + dashed 缝线包边）                */
  /*                                                                   */
  /* 视觉：photo 包一层 dashed 缝线 border（::after 伪元素）；          */
  /*   --p 0→1 缝线 opacity 0→0.85，scale 0.96→1.02。                  */
  /* "缝缝补补" 由 stitched 边表达。                                  */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="wooden"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="wooden"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="wooden"] .poem-photo[data-role="wooden"] {
    width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="wooden"] .poem-photo[data-role="wooden"]::after {
    content: "";
    position: absolute;
    inset: 6px;
    pointer-events: none;
    border: 2px dashed rgba(180, 130, 80, 0.78);
    border-radius: 4px;
    opacity: clamp(0, calc(var(--p, 0) * 1.2), 0.92);
    transform: scale(calc(0.96 + var(--p, 0) * 0.04));
    transform-origin: center;
    transition:
      opacity 140ms linear,
      transform 140ms linear;
  }
  .poem-beat[data-layout="wooden"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
