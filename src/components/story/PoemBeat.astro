import CdnImage from "@/components/CdnImage.astro";
import SnowAtmosphere from "@/components/story/SnowAtmosphere.astro";

interface BeatPhoto {
  stem: string;
  cdnTarget:
    | "snow-a"
    | "snow-b"
    | "grassland"
    | "wooden-door"
    | "pearl"
    | "retro"
    | "misc";
  alt: string;
  role:
    | "far"
    | "near"
    | "top-left"
    | "bottom-right"
    | "center"
    | "anchor"
    | "vignette"
    | "overlap"
    | "reveal"
    | "wooden"
    | "pearl";
  width?: number;
  height?: number;
  /** v1.64（v1.63 audit P2 修）：fit 升级为必填，schema 强约束。
   *  人像 / 主体不可裁切 → "contain"；横向氛围图 → "cover"（必要时配 focalPoint） */
  fit: "contain" | "cover";
  /** v1.63: cover 模式下 box 偏移 (0..1)；contain 时忽略 */
  focalPoint?: { x: number; y: number };
}

type BeatLayout =
  | "parallax-pair"
  | "diagonal-gaze"
  | "radial-mask"
  | "anchor-single"
  | "scroll-unfold"
  | "vignette"
  | "overlap"
  | "reveal"
  | "wooden"
  | "pearl";

interface Props {
  id: string; // '01'..'12'
  layout?: BeatLayout;
  lines: string[];
  photos: BeatPhoto[];
  /** 第一帧首屏内（极少数：仅 §2 第 01 个 beat 紧邻 §1）→ priority 'high'；其它 'auto' lazy。 */
  firstAboveFold?: boolean;
  /** v1.74：main.json `anchor_date`（"YYYY-MM-DD"），用于 beat 05 [N] 天的实时计算 +
   *  入场 CountUp。父组件 StoryPoemScroller 从 main.data.anchor_date 透传；不传则不
   *  做替换（保留 "[N]" 字面量，相当于 v1.73 之前的行为）。 */
  anchorDate?: string;
  /** Vercel static edition：照片停在最终完成帧，不挂雪粒子 / scroll motion。 */
  staticStory?: boolean;
}

const {
  id,
  layout,
  lines,
  photos,
  firstAboveFold = false,
  anchorDate,
  staticStory = false,
} = Astro.props;

/**
 * v1.74-v1.75：beat 05 "不知不觉，已携手走过 [N] 天" 的 [N] 实时计算 + CountUp + a11y。
 *
 * 这里在 SSR 阶段算一次"build time / SSR time"的 N（initialDaysCount），同时
 * 写进三个地方：
 *   - visible 数字 span（用 aria-hidden 把 CountUp 动画屏蔽出 AT 朗读流）
 *   - sr-only sibling（拿稳定终值，AT 朗读这一项）
 *   - sr-only h3（v1.76 新增 firstLineLabel：[N] 也在 heading 里替换，避免
 *     AT 读"括号 N 天"的实现占位符）
 * 让无 JS 访客也能看到合理的数字（不会读出 "[N] 天" 占位符）。
 *
 * 客户端有 JS 时，StoryPoemScroller 内的 inline script 在 IO 入场时：
 *   - 重新算 client-time 的 N（避访客在 build 之后访问导致 N 漂老）
 *   - sr-only sibling 一次性写 client-time N（AT 朗读对得上）
 *   - visible span 跑 0 → client-time N over 1.4s ease-out cubic 动画
 *   - reduced-motion → visible 直接钉到 client-time N，不动画
 *
 * 拆分约定（v1.75 起）：源行含 "[N]" → 前后切分为 prefix / suffix；中间渲染
 *   <span class="days-together-wrap">
 *     <span class="days-together" aria-hidden="true">visible CountUp</span>
 *     <span class="sr-only" data-days-together-sr>stable terminal N</span>
 *   </span>
 * AT 在初次扫读这一行时只听到 sr-only 里的稳定数字一次，不会被 1.4s 内的
 * CountUp 过渡值（每帧不同的"X 天"）刷屏。aria-live 已**完全不用**——v1.74
 * 的旧设计在 visible span 上挂 aria-live="polite" 是 v1.75 audit P2 的根因。
 */
let initialDaysCount: number | null = null;
if (anchorDate) {
  // 复用 lib：与客户端脚本同款解析（避免"build time 用 ISO，runtime 用别的"漂移）
  const { parseAnchorDate, daysTogether } =
    await import("@/lib/story/daysTogether");
  initialDaysCount = daysTogether(parseAnchorDate(anchorDate));
}

/**
 * v1.68（v1.67 audit P2 修）：把 `#beat-XX-heading` 这个公开 deep-link 锚点
 * 从 sr-only h3 移到 .poem-beat 外层容器。原因：
 *   - sr-only h3 是 absolute / clip:rect 的 1×1 视觉不可见元素，浏览器哈希
 *     滚动会把它对齐到视口顶部，但它在 sticky stage 内部某个位置，落点不是
 *     intentional composed frame
 *   - 外层 .poem-beat 是 scroll-spacer，它的 top 对齐视口 → 触发 sticky 起点
 *     → composed frame（p≈0 的初始构图）正好出现在视口
 *
 * 拆分两个 id：
 *   - `headingId = beat-${id}-heading` 留给 .poem-beat（公开哈希、可导航）
 *   - `ariaHeadingId = beat-${id}-aria-heading` 给 sr-only h3（仅 aria-labelledby 引用，
 *     不暴露为公开 URL；命名带 -aria 后缀清楚指明用途）
 */
const headingId = `beat-${id}-heading`;
const ariaHeadingId = `beat-${id}-aria-heading`;
const firstLine = lines[0] ?? "";

/**
 * v1.77（v1.76 audit P2 修）：sr-only h3 的标签**不**用 build-time N，改用
 * 静态非数字描述，永不漂移。
 *
 * 背景：v1.76 把 [N] 替换为 build-time initialDaysCount（如 2657），这在 SSR
 * 当下 OK；但站点是 GitHub Pages 静态部署，下次 +08:00 午夜过后 client-time N
 * 已经变成 2658，CountUp 视觉数字 + .sr-only sibling 都被脚本同步到 2658，
 * 唯独 sr-only h3 还停在 build-time 的 2657 → AT 朗读 section 标签时会读到
 * 昨天的数，紧接着段落里读到今天的数，前后矛盾。
 *
 * 两个修法（用户审计列）：
 *   (a) 客户端脚本一并回写 h3 textContent
 *   (b) heading 改为稳定 / 非数字
 *
 * 选 (b)：heading 是给 AT 导航用的"section 标题"，不需要精确天数；精确数字
 * 已经在段落正文（.days-together-wrap 里 sr-only sibling）传达。把 " [N] 天"
 * 整体替换为 "的每一天" → 句意完整、永不漂移、不需要客户端二次回写。
 *
 * 例：beat 05 firstLine "不知不觉，已携手走过 [N] 天。" →
 *     headingLabel  "不知不觉，已携手走过的每一天。"
 *
 * 不含 [N] 的 beat 退化回 firstLine 原文（regex 不命中）；未来若加新的
 * `[N] X` 占位（如 `[N] 周`），按需补 regex 分支。
 */
const headingLabel = firstLine.replace(/\s*\[N\]\s*天/, "的每一天");

/**
 * v1.66 SSR 默认 data-text-placement（JS 接管 applyLayout 后仍会覆写）。
 * 与 solver 在 portrait 模式下的输出对齐，减轻 first-paint 与 hydrate 之间
 * 的 layout shift。wooden 在 wide 才走 side-text-photo，SSR 默认 portrait
 * → below 即可（JS 在 wide 设备 hydrate 后切到 side-text-photo）。
 */
function getSsrTextPlacement(l: BeatLayout | undefined): string {
  if (l === "vignette") return "overlay-bottom";
  if (l === "overlap") return "below";
  if (l === "reveal" || l === "pearl") return "overlay-top";
  if (l === "parallax-pair" || l === "diagonal-gaze") return "between";
  return "below";
}
const ssrTextPlacement = getSsrTextPlacement(layout);

// 给 solver 用的 aspect ratio：原始 width/height 算 w/h 比；缺失时按 layout 给 fallback
function getAspectRatio(p: BeatPhoto): string {
  if (p.width && p.height) return (p.width / p.height).toFixed(4);
  // portrait fallback for diagonal-gaze; landscape fallback for others
  if (p.role === "top-left" || p.role === "bottom-right") return "0.6667";
  return "1.5";
}

/**
 * v1.64（v1.63 audit P2 修）：fit 升级为 schema 必填字段。
 *   组件层不再做"自动推导 fallback"——schema validator 已强约束 photo 必带 fit；
 *   getFit 直接 return p.fit。这样视觉契约从"凭 metadata 推导"改为"显式声明"，
 *   防止 metadata 与 CDN 真实尺寸不一致（v1.63 audit 实测发现 5 张 1600×2400
 *   竖幅人像被错标 3000×2000 横幅）时静默裁掉人物主体。
 */
function getFit(p: BeatPhoto): "contain" | "cover" {
  return p.fit;
}

/**
 * focal point → object-position CSS 值（cover 时生效；contain 时忽略）。
 * 若未提供 focalPoint，返回 undefined → CSS 用默认 center。
 */
function getObjectPositionStyle(p: BeatPhoto): string | undefined {
  if (!p.focalPoint) return undefined;
  const x = (p.focalPoint.x * 100).toFixed(1);
  const y = (p.focalPoint.y * 100).toFixed(1);
  return `--object-position: ${x}% ${y}%`;
}
