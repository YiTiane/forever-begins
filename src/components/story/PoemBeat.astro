<section
  class="poem-beat"
  id={headingId}
  data-beat-id={id}
  data-layout={layout}
  data-story-mode="portrait"
  data-static-story={staticStory ? "true" : undefined}
  data-text-placement={ssrTextPlacement}
  aria-labelledby={ariaHeadingId}
>
  <div class="poem-stage">
    <h3 id={ariaHeadingId} class="sr-only">
      第 {id} 段 · {headingLabel}
    </h3>

    <div class="poem-text cn-song">
      {
        lines.map((line) => {
          // v1.74 [N] 占位 + v1.75 a11y 修：含 "[N]" 的行拆成
          //   prefix / .days-together-wrap (visual aria-hidden + sr-only 静态)
          //   / suffix。其它行原样。
          //
          // a11y 设计（修 v1.74 audit P2）：visible span aria-hidden="true" →
          // CountUp 动画期间不进 AT 读流，避免 1.4s 内向 AT 抛 60 个不同的
          // 错误天数；sr-only sibling 拿稳定终值（SSR build-time，客户端脚本
          // 入场前一次性改成 client-time），AT 在初次扫读这一行时读到一个
          // 准确数字"2657 天"，不再是过渡值。
          const idx = line.indexOf("[N]");
          if (idx === -1 || initialDaysCount === null || !anchorDate) {
            return <p>{line}</p>;
          }
          const prefix = line.slice(0, idx);
          const suffix = line.slice(idx + 3);
          return (
            <p>
              {prefix}
              <span class="days-together-wrap">
                <span
                  class="days-together"
                  data-days-anchor={anchorDate}
                  aria-hidden="true"
                >
                  {initialDaysCount}
                </span>
                <span class="sr-only" data-days-together-sr>
                  {initialDaysCount}
                </span>
              </span>
              {suffix}
            </p>
          );
        })
      }
    </div>

    {
      photos.length > 0 && (
        <div
          class="poem-photos"
          data-photo-count={photos.length}
          data-roles={photos.map((p) => p.role).join(",")}
        >
          {photos.map((photo) => (
            <figure
              class="poem-photo"
              data-role={photo.role}
              data-aspect-ratio={getAspectRatio(photo)}
              data-fit={getFit(photo)}
              style={getObjectPositionStyle(photo)}
            >
              <CdnImage
                cdnTarget={photo.cdnTarget}
                stem={photo.stem}
                alt={photo.alt}
                priority={firstAboveFold ? "high" : "auto"}
                widths={[320, 640, 1024, 1600, 2400]}
                sizes="(min-width: 720px) 38vw, (min-width: 540px) 60vw, 90vw"
                width={photo.width}
                height={photo.height}
              />
              {/* v1.65：vignette layout 在 photo 之上叠 SnowAtmosphere canvas
                  雪粒子（仅 vignette role；canvas 自身 absolute inset:0 + IO 生命周期）*/}
              {!staticStory &&
                layout === "vignette" &&
                photo.role === "vignette" && <SnowAtmosphere />}
            </figure>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  /* ────────────────────────────────────────────────────────────── */
  /* 外层 scroll-spacer · 高度 = 100vh sticky + 极短 release zone     */
  /* v1.59 收紧 release zone：从 v1.58 的 60-140vh → 10-30vh         */
  /* 自然滚动越过 release zone < 半秒，无需 exit-fade 也不会留空白    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-beat {
    position: relative;
    /* 默认 fallback（无 data-layout / data-story-mode 时）：完整一屏 */
    min-height: 100vh;
    /* v1.68 P2 修：deep-link / 哈希滚动落点 = beat 顶端，不被任何固定 header 偏移
       （目前页面无固定 header；保留 0 是显式契约，未来若加 site nav 也只需
        改这里一处统一调整 scroll-padding） */
    scroll-margin-top: 0;
    /* phase 变量初值 0；StoryPoemScroller 的 rAF 接管后 0..1 写入 */
    --p: 0;
    --p-photo-1: 0;
    --p-photo-2: 0;
    --p-text: 0;
    /* solver 输出变量 fallback —— 在 JS 接管前给一个能看的初始值 */
    --stage-cols: 1fr;
    --stage-gap: 24px;
    --text-col-w: 100%;
    --text-max-w: 100%;
    --photos-col-w: 100%;
    --photos-col-h: 60vh;
    --photo-w: 80%;
    --photo-h: auto;
    --photo-far-w: 56%;
    --photo-far-h: auto;
    --photo-near-w: 64%;
    --photo-near-h: auto;
    --photo-pair-gap: 24px;
    --photo-tl-w: 240px;
    --photo-tl-h: auto;
    --photo-br-w: 240px;
    --photo-br-h: auto;
  }
  .poem-beat[data-layout="parallax-pair"] {
    min-height: 150vh;
  }
  .poem-beat[data-layout="diagonal-gaze"] {
    min-height: 160vh;
  }
  .poem-beat[data-layout="radial-mask"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="anchor-single"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="scroll-unfold"] {
    min-height: 135vh;
  }
  /* v1.62 batch 4：新 5 套 single-photo layout（仅 wide 模式给 sticky scroll spacer 高度，
     portrait / compact 由后续 [data-story-mode="..."] 重置回 auto） */
  .poem-beat[data-layout="vignette"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="overlap"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="reveal"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="wooden"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="pearl"] {
    min-height: 130vh;
  }
  .poem-beat[data-story-mode="compact"],
  .poem-beat[data-story-mode="compact"][data-layout] {
    min-height: auto;
  }
  .poem-beat[data-story-mode="portrait"],
  .poem-beat[data-story-mode="portrait"][data-layout] {
    min-height: auto;
    padding: clamp(3rem, 7vh, 5rem) 0;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] {
    min-height: 160vh;
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] {
    min-height: 165vh;
  }
  .poem-beat[data-story-mode="wide"][data-layout="radial-mask"],
  .poem-beat[data-story-mode="wide"][data-layout="anchor-single"],
  .poem-beat[data-story-mode="wide"][data-layout="scroll-unfold"],
  .poem-beat[data-story-mode="wide"][data-layout="vignette"],
  .poem-beat[data-story-mode="wide"][data-layout="overlap"],
  .poem-beat[data-story-mode="wide"][data-layout="reveal"],
  .poem-beat[data-story-mode="wide"][data-layout="wooden"],
  .poem-beat[data-story-mode="wide"][data-layout="pearl"] {
    min-height: 142vh;
  }

  /* ────────────────────────────────────────────────────────────── */
  /* sticky 100vh stage                                              */
  /*                                                                 */
  /* v1.87 注释同步：当前布局模式由 getStoryLayoutMode 写入            */
  /* data-story-mode=(compact|portrait|wide)。baseline flex column     */
  /* 是 compact/portrait 的自然流兜底；                                */
  /* 只有 data-story-mode="wide" 的 layout-specific block 才切回       */
  /* sticky 100vh / grid / absolute cinematic frame。                  */
  /* ────────────────────────────────────────────────────────────── */
  .poem-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
    padding: 2rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .poem-beat[data-story-mode="portrait"] .poem-stage {
    position: relative;
    top: auto;
    height: auto;
    min-height: auto;
    overflow: visible;
    padding-block: clamp(1.5rem, 4vh, 2.5rem);
  }

  /* sr-only 兜底 */
  .poem-stage :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ────────────────────────────────────────────────────────────── */
  /* 文字 baseline                                                    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-text {
    color: var(--c-olive-ink);
    font-weight: 300;
    font-size: 1.5rem;
    line-height: 1.85;
    text-align: center;
    width: 100%;
    max-width: var(--text-max-w);
  }
  .poem-text p {
    margin: 0.35em 0;
  }

  /* v1.74 §2.D：[N] 天 实时数字（StoryPoemScroller 内 IIFE 的 IO + ease-out 动画
     会改写 textContent，从 0 计到当前 N）。视觉上比正文更厚重 + honey 色让
     "携手 N 天"在低饱和 sage 背景里立得起来；inline 不破坏行高。
     v1.75：visible span aria-hidden + .sr-only sibling 拿稳定终值给 AT，
     避免 CountUp 1.4s 内 60 帧不同过渡值灌入 AT 朗读流。 */
  .poem-text .days-together-wrap {
    /* wrap 是包裹 visible 数字 + sr-only 字符串的 inline 容器，必须不引入额外
       盒模型 / 行高变化 —— display:inline 让两个 span 都在父行内 */
    display: inline;
  }
  .poem-text .days-together {
    display: inline-block;
    color: var(--c-honey, #c69d4e);
    font-weight: 400;
    /* 数字 tabular 等宽，CountUp 改写时不会让上下行抖动 */
    font-variant-numeric: tabular-nums;
    /* 数字稍大 + 字距收紧让"天"贴近数字 */
    font-size: 1.18em;
    margin: 0 0.18em;
    letter-spacing: 0.01em;
  }

  /* 移动端字号收一档 */
  @media (max-width: 540px) {
    .poem-text {
      font-size: 1.25rem;
      line-height: 1.7;
    }
  }

  /* ────────────────────────────────────────────────────────────── */
  /* 照片 baseline                                                    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-photos {
    display: grid;
    gap: 1.25rem;
    width: 100%;
    grid-template-columns: 1fr;
  }
  .poem-photo {
    margin: 0;
    box-shadow: var(--shadow-paper);
    will-change: transform, opacity, filter;
    /* v1.63 默认 object-position 写在 CSS 变量上；调用方可通过 inline
       style="--object-position: 50% 30%" 给 cover 模式锁人物头部 */
    --object-position: center;
  }
  .poem-photo :global(picture),
  .poem-photo :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-sm);
    /* v1.63（v1.62 audit P2-A 修）：默认不再 object-fit: cover；
       由 [data-fit="..."] 显式声明，避免竖幅人像被裁掉脸/上半身。 */
  }
  .poem-photo[data-fit="cover"] :global(picture),
  .poem-photo[data-fit="cover"] :global(img) {
    object-fit: cover;
    object-position: var(--object-position, center);
  }
  .poem-photo[data-fit="contain"] :global(picture),
  .poem-photo[data-fit="contain"] :global(img) {
    object-fit: contain;
    /* contain 模式下 background 透出，给一个低饱和的纸白底配 paper-shadow */
    background: var(--c-paper, transparent);
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = parallax-pair · beat 01                                 */
  /*                                                                  */
  /* v1.64（v1.63 audit P2 修）：absolute overlap frame 仅 wide 模式。  */
  /*                                                                  */
  /* photo 尺寸（all modes）：solver 输出的 --photo-far/near-w/h       */
  /*   compact (≤540)：mobile fallback 单列堆叠                         */
  /*   portrait (541-899 / 高瘦视口)：display: contents + flex order，  */
  /*     真自然流：far photo（右对齐）→ 文字（居中）→ near photo        │
  /*     （左对齐）；align-self 暗示远近，不再 absolute overlap。        │
  /*     窄屏不再两图压叠破坏阅读节奏。                                 │
  /*   wide (≥900 + aspect ≥0.85)：grid 双列 + far/near 绝对定位重叠   */
  /*     + 入场 transform —— "记忆被慢慢推近"由 wide cinematic 表达。   │
  /* ──────────────────────────────────────────────────────────────  */
  /* photo 尺寸 baseline（所有模式都用 solver 输出的 box）*/
  .poem-beat[data-layout="parallax-pair"] .poem-photo[data-role="far"] {
    width: var(--photo-far-w);
    height: var(--photo-far-h);
    filter: saturate(0.92);
  }
  .poem-beat[data-layout="parallax-pair"] .poem-photo[data-role="near"] {
    width: var(--photo-near-w);
    height: var(--photo-near-h);
  }
  /* portrait 模式：display: contents 让 photos 子元素直接进 stage flex column；
     order 排"far → text → near"；align-self 暗示远近；不 absolute overlap */
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(1.25rem, 3vh, 2rem);
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-photos {
    display: contents;
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-photo[data-role="far"] {
    order: 1;
    align-self: flex-end;
    margin-right: clamp(0px, 4vw, 32px);
    transform: translateY(calc((1 - var(--p, 0)) * -8px));
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-text {
    order: 2;
    align-self: center;
    max-width: var(--text-max-w);
    text-align: center;
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-photo[data-role="near"] {
    order: 3;
    align-self: flex-start;
    margin-left: clamp(0px, 4vw, 32px);
    transform: translateY(calc((1 - var(--p, 0)) * 8px));
  }
  /* wide 模式：grid 双列 + far/near 绝对重叠 + 入场 transform */
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-stage {
    display: grid;
    grid-template-columns: var(--stage-cols);
    align-items: center;
    justify-items: center;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-text {
    grid-column: 1;
    align-self: center;
    justify-self: end;
    text-align: left;
    max-width: var(--text-col-w);
    z-index: 2;
    transform: translateX(calc((1 - var(--p, 0)) * -8px));
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-photos {
    grid-column: 2;
    position: relative;
    align-self: center;
    width: var(--photos-col-w);
    height: var(--photos-col-h);
    max-width: none;
    grid-template-columns: 1fr;
    gap: 0;
    z-index: 1;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"]
    .poem-photo[data-role="far"] {
    position: absolute;
    top: 0;
    right: 0;
    transform: translateY(calc((1 - var(--p, 0)) * -14%))
      scale(calc(0.96 + var(--p, 0) * 0.04));
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"]
    .poem-photo[data-role="near"] {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 1;
    transform: translateY(calc((1 - var(--p, 0)) * 14%))
      scale(calc(0.96 + var(--p, 0) * 0.04));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = diagonal-gaze · beat 02                                 */
  /*                                                                  */
  /* v1.63（v1.62 audit P2-B 修）：absolute corner frame 仅 wide 模式。 */
  /*                                                                  */
  /* photo 尺寸（all modes）：solver 输出的 --photo-tl/br-w/h           */
  /*   compact (≤540)：mobile fallback 全 !important 取消，单列堆叠     */
  /*   portrait (541-899 / 高瘦视口)：display: contents + flex order，  */
  /*     真自然流式：tl photo（左上对齐）→ 文字（居中）→ br photo       │
  /*     （右下对齐）；align-self 暗示对角，但人像绝不被 absolute 框碎掉。│
  /*   wide (≥900 + aspect ≥0.85)：grid 单 cell stack + tl/br 角落      */
  /*     absolute + 中间文字 backdrop-blur(8px) 浮起 + 入场 translate。│
  /* ──────────────────────────────────────────────────────────────  */
  /* photo 尺寸 baseline（所有模式都用 solver 输出的 box）*/
  .poem-beat[data-layout="diagonal-gaze"] .poem-photo[data-role="top-left"] {
    width: var(--photo-tl-w);
    height: var(--photo-tl-h);
  }
  .poem-beat[data-layout="diagonal-gaze"]
    .poem-photo[data-role="bottom-right"] {
    width: var(--photo-br-w);
    height: var(--photo-br-h);
  }
  /* portrait 模式：display: contents 让 photos 子元素直接进 stage flex column；
     用 order 把 text 排在两张人像中间，align-self 暗示对角而不依赖 absolute */
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(1.25rem, 3vh, 2rem);
  }
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-photos {
    /* 把 photos 容器"flat 化"，让两张 figure 直接成为 stage 的 flex 项 */
    display: contents;
  }
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="top-left"] {
    order: 1;
    align-self: flex-start;
    margin-left: clamp(0px, 4vw, 32px);
    transform: translate(
      calc((1 - var(--p, 0)) * -10px),
      calc((1 - var(--p, 0)) * -6px)
    );
  }
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-text {
    order: 2;
    align-self: center;
    max-width: var(--text-max-w);
    text-align: center;
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-story-mode="portrait"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="bottom-right"] {
    order: 3;
    align-self: flex-end;
    margin-right: clamp(0px, 4vw, 32px);
    transform: translate(
      calc((1 - var(--p, 0)) * 10px),
      calc((1 - var(--p, 0)) * 6px)
    );
  }
  /* wide 模式：grid 单 cell stack + 角落 absolute + 文字 backdrop-blur 浮起 */
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-stage {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    padding: 0;
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-text {
    grid-area: 1 / 1;
    align-self: center;
    justify-self: center;
    max-width: var(--text-max-w);
    text-align: center;
    z-index: 2;
    padding: 1.25rem 1.5rem;
    background: rgba(245, 240, 230, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-sm);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-photos {
    grid-area: 1 / 1;
    position: relative;
    width: 100%;
    height: 100%;
    grid-template-columns: 1fr;
    gap: 0;
    z-index: 1;
  }
  /* v2.14：diagonal-gaze 继续加大动作幅度。solver 给更大的 portrait box，
     CSS 用 7% 角落 inset + ±12% entrance transform，让两张人像从对角更明显地
     靠近中央，但仍给 1366/1375/1920 宽屏留安全边界。 */
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="top-left"] {
    position: absolute;
    top: 7%;
    left: 7%;
    transform: translate(
      calc((1 - var(--p, 0)) * -12%),
      calc((1 - var(--p, 0)) * -12%)
    );
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="bottom-right"] {
    position: absolute;
    bottom: 7%;
    right: 7%;
    transform: translate(
      calc((1 - var(--p, 0)) * 12%),
      calc((1 - var(--p, 0)) * 12%)
    );
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = radial-mask · beat 03                                   */
  /* solver 给 photo 单图尺寸；CSS 单 stage 紧凑居中堆叠              */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="radial-mask"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="radial-mask"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="radial-mask"] .poem-photo[data-role="center"] {
    width: var(--photo-w);
    height: var(--photo-h);
    --mask-inner: calc(30% + var(--p, 0) * 25%);
    --mask-outer: calc(60% + var(--p, 0) * 35%);
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 1) var(--mask-inner),
      rgba(0, 0, 0, 0) var(--mask-outer)
    );
    mask-image: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 1) var(--mask-inner),
      rgba(0, 0, 0, 0) var(--mask-outer)
    );
    box-shadow: none;
    transform: scale(calc(1.06 - var(--p, 0) * 0.06));
    filter: saturate(calc(0.88 + var(--p, 0) * 0.12));
  }
  .poem-beat[data-layout="radial-mask"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = anchor-single · beat 04                                  */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="anchor-single"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="anchor-single"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="anchor-single"] .poem-photo[data-role="anchor"] {
    width: var(--photo-w);
    height: var(--photo-h);
    transform: scale(calc(0.94 + var(--p, 0) * 0.06))
      translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-layout="anchor-single"]
    .poem-photo[data-role="anchor"][data-fit="cover"] {
    clip-path: inset(calc((1 - var(--p, 0)) * 7%) round var(--radius-sm));
    transform: translateY(calc((1 - var(--p, 0)) * 16px))
      scale(calc(0.9 + var(--p, 0) * 0.1));
    filter: saturate(calc(0.82 + var(--p, 0) * 0.18))
      contrast(calc(0.94 + var(--p, 0) * 0.06));
  }
  .poem-beat[data-layout="anchor-single"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = scroll-unfold · beat 05（Snow_13 卷轴展开 + CountUp）     */
  /*                                                                   */
  /* 视觉：竖幅照片从上下同时展开，不做旧照片褪色；保留原照片亮度，     */
  /* 用细滚轴边和轻微阴影让「已携手走过 [N] 天」像被慢慢展开的相册页。 */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="scroll-unfold"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="scroll-unfold"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
    perspective: 1200px;
  }
  .poem-beat[data-layout="scroll-unfold"] .poem-photo[data-role="anchor"] {
    width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
    overflow: hidden;
    clip-path: inset(
      calc((1 - var(--p, 0)) * 40%) 0 calc((1 - var(--p, 0)) * 40%) 0 round
        var(--radius-sm)
    );
    transform: translateY(calc((1 - var(--p, 0)) * 12px))
      rotateX(calc((1 - var(--p, 0)) * 2deg))
      scale(calc(0.955 + var(--p, 0) * 0.045));
    transform-origin: center;
    box-shadow:
      0 18px 42px rgba(47, 58, 37, 0.12),
      0 0 0 1px rgba(91, 102, 62, 0.08);
  }
  .poem-beat[data-layout="scroll-unfold"]
    .poem-photo[data-role="anchor"]::before,
  .poem-beat[data-layout="scroll-unfold"]
    .poem-photo[data-role="anchor"]::after {
    content: "";
    position: absolute;
    left: 0.45rem;
    right: 0.45rem;
    height: 7px;
    z-index: 2;
    pointer-events: none;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      rgba(255, 249, 235, 0.12),
      rgba(255, 249, 235, 0.72),
      rgba(91, 102, 62, 0.18)
    );
    opacity: calc(0.18 + var(--p, 0) * 0.42);
    box-shadow: 0 2px 8px rgba(47, 58, 37, 0.14);
  }
  .poem-beat[data-layout="scroll-unfold"]
    .poem-photo[data-role="anchor"]::before {
    top: 0.5rem;
  }
  .poem-beat[data-layout="scroll-unfold"]
    .poem-photo[data-role="anchor"]::after {
    bottom: 0.5rem;
  }
  .poem-beat[data-layout="scroll-unfold"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 8px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = vignette · beat 06（夜色重点舞台 + 文字 overlay-bottom）   */
  /*                                                                   */
  /* v1.65（v1.64 audit P2-C 修）：从"暗角图 + 下方文字"升级为重点氛围  */
  /* 舞台。变化：                                                      │
  /*   1) text 从 below 改 overlay-bottom（solver 已输出 textPlacement） │
  /*   2) photo 占整个 stage（solver photoMaxWFactor 0.85→0.92，         │
  /*      photoMaxAbs 720→820；gap=0；text reserve=0）                  │
  /*   3) 暗角更深：edge alpha 0.6→0.78；inner stop 30%→18%（夜色更收）  │
  /*   4) text 浮卡：rgba(15,18,30,0.45) + backdrop-blur(6px) +         │
  /*      白文字 (0.95) + padding/border-radius —— 婚礼站亲密夜读语境  │
  /*   5) 三行 stagger 保留                                             │
  /*   6) <SnowAtmosphere /> canvas 雪粒子由 PoemBeat 在 vignette layout │
  /*      条件渲染（粒子动画 + IO 生命周期 + reduced-motion guard）     │
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="vignette"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    /* stage 自己已是 position: sticky / relative，containing block 给 text 用 */
  }
  .poem-beat[data-layout="vignette"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="vignette"] .poem-photo[data-role="vignette"] {
    width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }
  /* dark vignette 暗角（更深更收，强化夜色 / 重点感）*/
  .poem-beat[data-layout="vignette"] .poem-photo[data-role="vignette"]::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      rgba(8, 10, 24, 0) 18%,
      rgba(8, 10, 24, 0.4) 72%,
      rgba(8, 10, 24, 0.78) 100%
    );
    border-radius: var(--radius-sm);
    z-index: 2;
  }
  /* 文字浮卡：overlay-bottom + 半透明深底 + backdrop-blur + 白色文字 */
  .poem-beat[data-layout="vignette"][data-text-placement="overlay-bottom"]
    .poem-text {
    position: absolute;
    bottom: clamp(2rem, 6vh, 4rem);
    left: 50%;
    transform: translateX(-50%);
    width: min(var(--text-max-w), 88%);
    max-width: 92%;
    text-align: center;
    z-index: 4;
    padding: 1rem 1.5rem;
    background: rgba(15, 18, 30, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: rgba(255, 255, 255, 0.95);
    border-radius: var(--radius-sm);
  }
  /* 文字浮卡（v1.85 修用户 Snow_08 空白框反馈）：
     v1.69 只让第 1 行常亮，第 2/3 行 opacity gate 但仍占布局高度；
     hash / 快速滚动落点会看到一块只有首句、下方大面积空白的深色面板，
     用户误判为“下雪动画消失后留下空白框”。Snow_08 的重点舞台不应把
     motion stagger 放在可读性之前，因此三行全部常亮；雪动画承担动态层。 */
  .poem-beat[data-layout="vignette"] .poem-text p {
    opacity: 1;
  }
  /* SnowAtmosphere canvas overlay 容器样式由 SnowAtmosphere.astro 自己持有。
     注意：不要在父组件 scoped CSS 里直接写 `.snow-atmosphere`，Astro 会把它
     编译成带父组件 cid 的选择器，匹配不到子组件生成的 canvas。 */

  /* ──────────────────────────────────────────────────────────────  */
  /* v1.66 textPlacement 通用规则（按 data-text-placement 选择器）    */
  /*                                                                   */
  /* 各 layout 的 base CSS 仍是 "flex column 图 + 文居中 below"；        */
  /* 这些规则用更具体的 selector 在特定 layout 上覆盖为 overlay-* /     */
  /* side-* 模式，让 textPlacement 真正参与构图。                       */
  /* ──────────────────────────────────────────────────────────────  */

  /* overlap v1.80：用户宽屏截图审计指出 overlay-center 浮卡遮挡人物。
     solver 已改回 data-text-placement="below"，文字跟随 baseline 成为 photo
     下方短句 caption；这里不再写 absolute overlay 规则。 */

  /* —— reveal 竖幅展开 → overlay-top（文字浮在顶端，photo 由内向外露出） ——
     v1.79（v1.78 audit P2-1 修）：同 overlap，删 `.poem-stage { position: relative }`
     覆盖以保住 sticky stage 与 HOLD_PHASE 完成帧契约。 */
  .poem-beat[data-layout="reveal"][data-text-placement="overlay-top"]
    .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="reveal"][data-text-placement="overlay-top"]
    .poem-text {
    position: absolute;
    top: clamp(1.5rem, 5vh, 3rem);
    left: 50%;
    transform: translateX(-50%) translateY(calc((1 - var(--p, 0)) * -6px));
    width: min(var(--text-max-w), 84%);
    z-index: 4;
    padding: 0.75rem 1.5rem;
    background: rgba(245, 240, 230, 0.65);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: var(--radius-sm);
    text-align: center;
    color: var(--c-olive-ink);
  }

  /* —— pearl 竖幅人像 + 高光 sweep → overlay-top（与 reveal 对称） ——
     v1.79（v1.78 audit P2-1 修）：同 overlap / reveal，删 stage relative 覆盖。 */
  .poem-beat[data-layout="pearl"][data-text-placement="overlay-top"]
    .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="pearl"][data-text-placement="overlay-top"]
    .poem-text {
    position: absolute;
    top: clamp(1.5rem, 5vh, 3rem);
    left: 50%;
    transform: translateX(-50%) translateY(calc((1 - var(--p, 0)) * -6px));
    width: min(var(--text-max-w), 84%);
    z-index: 4;
    padding: 0.75rem 1.5rem;
    background: rgba(245, 240, 230, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: var(--radius-sm);
    text-align: center;
    color: var(--c-olive-ink);
  }

  /* —— wooden 横幅木门 + 3 行长诗 → wide 模式 side-text-photo（信件式） —— */
  /* 仅 wide 生效；portrait/compact 走默认 below */
  .poem-beat[data-layout="wooden"][data-text-placement="side-text-photo"]
    .poem-stage {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, var(--photo-w));
    gap: clamp(1rem, 2.25vw, 1.75rem);
    align-items: center;
    justify-items: center;
  }
  .poem-beat[data-layout="wooden"][data-text-placement="side-text-photo"]
    .poem-text {
    grid-column: 1;
    align-self: center;
    justify-self: end;
    text-align: left;
    max-width: var(--text-max-w);
    transform: translateX(calc((1 - var(--p, 0)) * -8px));
  }
  .poem-beat[data-layout="wooden"][data-text-placement="side-text-photo"]
    .poem-photos {
    grid-column: 2;
    align-self: center;
    width: var(--photo-w);
    max-width: var(--photo-w);
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = overlap · beat 07（双层 ghost 重合 → 收敛单图）           */
  /*                                                                   */
  /* 视觉：双侧暖金 / 橄榄 ghost；--p 0→1 把 ghost 偏移 34px→0           */
  /*   合到单图。"两个契合的灵魂" 由两层错位渐合表达。                 */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="overlap"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="overlap"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="overlap"] .poem-photo[data-role="overlap"] {
    width: var(--photo-w);
    height: var(--photo-h);
    transform: scale(calc(0.965 + var(--p, 0) * 0.035))
      translateY(calc((1 - var(--p, 0)) * 8px));
    /* 用 filter drop-shadow 实现"双层 ghost"——纯 CSS，不复制 DOM */
    filter: drop-shadow(
        calc((1 - var(--p, 0)) * 34px) 0 0 rgba(91, 102, 62, 0.2)
      )
      drop-shadow(calc((1 - var(--p, 0)) * -34px) 0 0 rgba(231, 195, 105, 0.32));
    transition:
      filter 120ms linear,
      transform 120ms linear;
  }
  .poem-beat[data-layout="overlap"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = reveal · beat 08（clip-path inset 从中心向外展开）        */
  /*                                                                   */
  /* 视觉：图像四周 inset clip 从 8% → 0；--p 0→1 完整露出。            */
  /* "卸下防备" 由"图像层从遮蔽中展开"表达。                          */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="reveal"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="reveal"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="reveal"] .poem-photo[data-role="reveal"] {
    width: var(--photo-w);
    height: var(--photo-h);
    --reveal-inset: calc((1 - var(--p, 0)) * 9%);
    clip-path: inset(
      var(--reveal-inset) var(--reveal-inset) var(--reveal-inset)
        var(--reveal-inset) round 6px
    );
    transform: scale(calc(0.98 + var(--p, 0) * 0.02));
    transition:
      clip-path 120ms linear,
      transform 120ms linear;
  }
  .poem-beat[data-layout="reveal"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = wooden · beat 09（木门 + dashed 缝线包边）                */
  /*                                                                   */
  /* 视觉：photo 包一层 dashed 缝线 border（::after 伪元素）；          */
  /*   --p 0→1 缝线 opacity 0→0.85，scale 0.96→1.02。                  */
  /* "缝缝补补" 由 stitched 边表达。                                  */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="wooden"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="wooden"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="wooden"] .poem-photo[data-role="wooden"] {
    width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
  }
  .poem-beat[data-layout="wooden"] .poem-photo[data-role="wooden"]::after {
    content: "";
    position: absolute;
    inset: 6px;
    pointer-events: none;
    border: 2px dashed rgba(180, 130, 80, 0.78);
    border-radius: 4px;
    opacity: clamp(0, calc(var(--p, 0) * 1.2), 0.92);
    transform: scale(calc(0.96 + var(--p, 0) * 0.04));
    transform-origin: center;
    transition:
      opacity 140ms linear,
      transform 140ms linear;
  }
  .poem-beat[data-layout="wooden"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = pearl · beat 10（珍珠高光横扫）                            */
  /*                                                                   */
  /* 视觉：linear-gradient 高光斜带覆盖在 photo 上，沿 --p 从左到右      */
  /*   平移 -100% → 100%；gradient 中段 12% 半透明白让光带有"珍珠光泽"。│
  /* "克制" 由 mix-blend-mode: soft-light 表达。                       */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="pearl"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="pearl"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="pearl"] .poem-photo[data-role="pearl"] {
    width: var(--photo-w);
    height: var(--photo-h);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }
  .poem-beat[data-layout="pearl"] .poem-photo[data-role="pearl"]::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 38%,
      rgba(255, 255, 255, 0.28) 50%,
      transparent 62%
    );
    transform: translateX(calc(var(--p, 0) * 200% - 100%));
    mix-blend-mode: soft-light;
    transition: transform 140ms linear;
  }
  .poem-beat[data-layout="pearl"] .poem-text {
    max-width: var(--text-max-w);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* Vercel static story edition                                      */
  /*                                                                   */
  /* 父级 StoryPoemScroller 写 data-static-story 并在首帧把所有 progress */
  /* 变量固定为 1；这里提供 SSR/CSS 兜底，移除 sticky spacer 与所有过渡感。 */
  /* ──────────────────────────────────────────────────────────────  */
  :global(.story-poem[data-static-story]) .poem-beat,
  :global(.story-poem[data-static-story]) .poem-beat[data-layout],
  :global(.story-poem[data-static-story])
    .poem-beat[data-story-mode="wide"][data-layout] {
    min-height: auto;
    padding: clamp(1.75rem, 4vh, 3rem) 0;
    overflow: hidden;
    --p: 1;
    --p-photo-1: 1;
    --p-photo-2: 1;
    --p-text: 1;
  }
  :global(.story-poem[data-static-story]) .poem-beat + .poem-beat {
    margin-top: clamp(1.75rem, 4vh, 3rem);
  }
  :global(.story-poem[data-static-story]) .poem-stage {
    position: relative;
    top: auto;
    height: auto;
    min-height: auto;
    overflow: visible;
    padding-block: clamp(1.25rem, 3vh, 2.25rem);
  }
  :global(.story-poem[data-static-story])
    .poem-beat[data-story-mode="wide"]
    .poem-stage {
    min-height: max(var(--stage-h), 720px);
  }
  :global(.story-poem[data-static-story])
    .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"]
    .poem-stage {
    min-height: calc(var(--photos-col-h) + clamp(10rem, 18vh, 14rem));
  }
  :global(.story-poem[data-static-story])
    .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"]
    .poem-stage {
    min-height: calc(
      var(--photo-tl-h) + var(--photo-br-h) + clamp(8rem, 15vh, 12rem)
    );
  }
  :global(.story-poem[data-static-story]) .poem-photo,
  :global(.story-poem[data-static-story]) .poem-photo::before,
  :global(.story-poem[data-static-story]) .poem-photo::after,
  :global(.story-poem[data-static-story]) .poem-text {
    transition: none !important;
  }
  :global(.story-poem[data-static-story])
    .poem-beat[data-layout="radial-mask"]
    .poem-photo[data-role="center"],
  :global(.story-poem[data-static-story])
    .poem-beat[data-layout="reveal"]
    .poem-photo[data-role="reveal"],
  :global(.story-poem[data-static-story])
    .poem-beat[data-layout="scroll-unfold"]
    .poem-photo[data-role="anchor"],
  :global(.story-poem[data-static-story])
    .poem-beat[data-layout="anchor-single"]
    .poem-photo[data-role="anchor"][data-fit="cover"] {
    clip-path: none !important;
    mask-image: none !important;
    -webkit-mask-image: none !important;
  }
  :global(.story-poem[data-static-story])
    .poem-beat[data-layout="overlap"]
