---
/**
 * PoemBeat.astro · §2 第一章单个 beat 渲染（v0.9 · v1.62 batch 4：5 套新 layout 全量上线）
 *
 * v0.9 新增（v1.62）：
 *   - **5 套新 layout 视觉**：vignette / overlap / reveal / wooden / pearl，与 schema enum
 *     九项一一对应，从此 beat 06-10 不再回退到通用样式
 *     · vignette (06)：edge 暗角 vignette 圈（夜色感）+ 文字三行 stagger fade-in
 *     · overlap (07)：双层 drop-shadow 模拟"两个灵魂"位错重合 → settle 到一张
 *     · reveal  (08)：clip-path inset 从内向外展开图像（"卸下防备"）
 *     · wooden  (09)：dashed 缝线包边 + 入场 fade-in
 *     · pearl   (10)：linear-gradient 高光横扫
 *   - **SSR 默认 data-story-mode="portrait"** 减轻 FOUC：在 JS 决定 actual mode 前，
 *     大多数访客（手机 / 小平板竖屏）已在 portrait 视觉下；wide 桌面用户仅一帧
 *     re-layout（acceptable）。runtime applyLayout 始终覆写。
 *
 * 视觉模式责任划分（v1.61 起的契约）：
 *   - compact：≤540 phone，static flow，所有 layout 退化为单列堆叠
 *   - portrait：large phone / small tablet portrait → 自然纵向流式（非 sticky）
 *   - wide：landscape tablet / desktop → sticky 100vh cinematic stage + 双列 / 对角
 *
 *   **sticky 100vh stage 仅 wide 模式生效**：portrait 模式 .poem-stage 的 position
 *   被覆盖为 relative + height auto，整个 beat 在自然文档流中以一帧紧凑构图存在。
 *   compact 模式更进一步取消 absolute / mask / transform，回退纯流式。
 *
 * v0.8 修 v1.60 后续截图审计：把视觉模式拆成 compact / portrait / wide。
 *   真实市场视口不是单一 breakpoint：604 / 705 / 820 这类窄版、小平板竖屏不能硬套
 *   desktop wide frame，也不能退回纯手机流式。StoryPoemScroller 现在把 solver 判定出的
 *   `data-story-mode` 写到 beat 上；CSS 只跟这个模式走，不再自行决定核心布局。
 *
 * v0.7 修 v1.58 审计两处 P2（窄屏 / 小平板纵向构图碎掉 + exit-fade 反而留空白）：
 *
 *   v1.58 之前 layout 用「magic % + clamp + 媒体查询断点」硬编码，照片宽 / 文字宽 / gap
 *   全是凑出来的；窄屏几乎必崩。v1.59 把这套替换成 src/lib/story/beatLayoutSolver.ts
 *   的 **constraint-based solver**：
 *     - 输入：viewport(vw,vh) × layout 类型 × photo aspectRatio[]
 *     - 输出：CSS 自定义属性（--photo-w / --photo-h / --text-max-w / --stage-gap /
 *       --stage-cols 等）
 *     - StoryPoemScroller 在 init / window.resize 时跑一次 solver，写到 `.poem-beat`
 *       上；CSS 只负责 `width: var(--photo-w)` / `gap: var(--stage-gap)` 这种消费工作
 *     - 滚动 progress（--p / --p-photo-1/2 / --p-text）继续每帧 rAF flush，互不干扰
 *
 *   同时 v1.59 也修 v1.58 P2 #4（exit-fade 反而出现整屏空白）：
 *     - 收紧每个 beat 的 min-height，把 release zone 从 v1.58 的 ~40-140vh 压到 10-30vh
 *       （sticky 100vh + 短 release）；自然滚动跨过这点的时间 ≪ 一秒，肉眼察觉不到
 *     - 删掉 v1.58 的 `.poem-stage` exit-fade —— 既然 release zone 极短，让两个 beat 在
 *       这 10-30vh 自然重叠比强行 fade 出空白更合理；用户审计具体说明的"空白屏"由此修复
 *
 *   每张 photo 通过 data-aspect-ratio 暴露 width/height ratio 给 solver；缺失时 solver
 *   会用合理 fallback。
 *
 * v0.6 修 v1.57 审计 P2 #3+#4：541-719px 断点缺口下沉到 541px；.poem-stage 加 exit-fade
 *   防 beat 跨转时半截上下两段并存。v1.59 后断点逻辑被 solver 接管，exit-fade 已删除。
 *
 * v0.5 修 v1.56 审计 P2 #1：v1.56 的 grid 1fr/auto + align-self start/end 把 text 与 photo
 *   拆到 100vh 两端的"残缺帧"问题，全部 4 套 layout 重写为 baseline opacity:1 + 紧凑居中堆叠。
 *
 * v0.4 修 v1.55 审计 P2 #1+#2：cinematic stage 架构（外层 scroll spacer + 内层 100vh sticky）。
 *
 * v0.3 修 v1.54 审计：role-driven layout 落地（4 套 data-layout CSS）。
 *
 * v0.2 修 v1.53 P2 #2：data-photo-count 从 .poem-beat 挪到 .poem-photos 让选择器命中。
 *
 * 落地范围（v1.59 收口标准）：
 *   ✓ 4 套 data-layout 真正不同的空间组合 + per-photo 入场 settle
 *   ✓ photo 尺寸 / 文字宽 / gap 全部由 solver 在 viewport 维度求解
 *   ✓ sticky cinematic stage（外层 110-150vh 短 spacer + 内层 100vh sticky）
 *   ✓ scroll-progress driven choreography（StoryPoemScroller 写 --p 等变量，CSS calc 消费）
 *   ✓ a11y：sr-only h3 aria-labelledby + reduced-motion fallback
 *
 * **NOT in this batch**（仍留 §2 后续刀）：
 *   ✗ vignette / overlap / reveal / wooden / pearl 五套 layout solver + CSS（schema 已留位）
 *   ✗ 文字字符级 stagger / blur enter（Phase 5 motion polish）
 *   ✗ beat 05 [N] 天 daysTogether CountUp（DESIGN §2.D · 留独立小刀）
 *   ✗ 鼠标 / 真 inertia parallax（CSS calc scroll-progress 已能表达"远近 settle"）
 */
import CdnImage from "@/components/CdnImage.astro";

interface BeatPhoto {
  stem: string;
  cdnTarget:
    | "snow-a"
    | "snow-b"
    | "grassland"
    | "wooden-door"
    | "pearl"
    | "retro"
    | "misc";
  alt: string;
  role:
    | "far"
    | "near"
    | "top-left"
    | "bottom-right"
    | "center"
    | "anchor"
    | "vignette"
    | "overlap"
    | "reveal"
    | "wooden"
    | "pearl";
  width?: number;
  height?: number;
}

type BeatLayout =
  | "parallax-pair"
  | "diagonal-gaze"
  | "radial-mask"
  | "anchor-single"
  | "vignette"
  | "overlap"
  | "reveal"
  | "wooden"
  | "pearl";

interface Props {
  id: string; // '01'..'12'
  layout?: BeatLayout;
  lines: string[];
  photos: BeatPhoto[];
  /** 第一帧首屏内（极少数：仅 §2 第 01 个 beat 紧邻 §1）→ priority 'high'；其它 'auto' lazy。 */
  firstAboveFold?: boolean;
}

const { id, layout, lines, photos, firstAboveFold = false } = Astro.props;

const headingId = `beat-${id}-heading`;
const firstLine = lines[0] ?? "";

// 给 solver 用的 aspect ratio：原始 width/height 算 w/h 比；缺失时按 layout 给 fallback
function getAspectRatio(p: BeatPhoto): string {
  if (p.width && p.height) return (p.width / p.height).toFixed(4);
  // portrait fallback for diagonal-gaze; landscape fallback for others
  if (p.role === "top-left" || p.role === "bottom-right") return "0.6667";
  return "1.5";
}
---

<section
  class="poem-beat"
  data-beat-id={id}
  data-layout={layout}
  data-story-mode="portrait"
  aria-labelledby={headingId}
>
  <div class="poem-stage">
    <h3 id={headingId} class="sr-only">
      第 {id} 段 · {firstLine}
    </h3>

    <div class="poem-text cn-song">
      {lines.map((line) => <p>{line}</p>)}
    </div>

    {
      photos.length > 0 && (
        <div
          class="poem-photos"
          data-photo-count={photos.length}
          data-roles={photos.map((p) => p.role).join(",")}
        >
          {photos.map((photo) => (
            <figure
              class="poem-photo"
              data-role={photo.role}
              data-aspect-ratio={getAspectRatio(photo)}
            >
              <CdnImage
                cdnTarget={photo.cdnTarget}
                stem={photo.stem}
                alt={photo.alt}
                priority={firstAboveFold ? "high" : "auto"}
                widths={[320, 640, 1024, 1600, 2400]}
                sizes="(min-width: 720px) 38vw, (min-width: 540px) 60vw, 90vw"
                width={photo.width}
                height={photo.height}
              />
            </figure>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  /* ────────────────────────────────────────────────────────────── */
  /* 外层 scroll-spacer · 高度 = 100vh sticky + 极短 release zone     */
  /* v1.59 收紧 release zone：从 v1.58 的 60-140vh → 10-30vh         */
  /* 自然滚动越过 release zone < 半秒，无需 exit-fade 也不会留空白    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-beat {
    position: relative;
    /* 默认 fallback（无 data-layout / data-story-mode 时）：完整一屏 */
    min-height: 100vh;
    /* phase 变量初值 0；StoryPoemScroller 的 rAF 接管后 0..1 写入 */
    --p: 0;
    --p-photo-1: 0;
    --p-photo-2: 0;
    --p-text: 0;
    /* solver 输出变量 fallback —— 在 JS 接管前给一个能看的初始值 */
    --stage-cols: 1fr;
    --stage-gap: 24px;
    --text-col-w: 100%;
    --text-max-w: 100%;
    --photos-col-w: 100%;
    --photos-col-h: 60vh;
    --photo-w: 80%;
    --photo-h: auto;
    --photo-far-w: 56%;
    --photo-far-h: auto;
    --photo-near-w: 64%;
    --photo-near-h: auto;
    --photo-tl-w: 240px;
    --photo-tl-h: auto;
    --photo-br-w: 240px;
    --photo-br-h: auto;
  }
  .poem-beat[data-layout="parallax-pair"] {
    min-height: 150vh;
  }
  .poem-beat[data-layout="diagonal-gaze"] {
    min-height: 160vh;
  }
  .poem-beat[data-layout="radial-mask"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="anchor-single"] {
    min-height: 130vh;
  }
  /* v1.62 batch 4：新 5 套 single-photo layout（仅 wide 模式给 sticky scroll spacer 高度，
     portrait / compact 由后续 [data-story-mode="..."] 重置回 auto） */
  .poem-beat[data-layout="vignette"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="overlap"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="reveal"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="wooden"] {
    min-height: 130vh;
  }
  .poem-beat[data-layout="pearl"] {
    min-height: 130vh;
  }
  .poem-beat[data-story-mode="compact"],
  .poem-beat[data-story-mode="compact"][data-layout] {
    min-height: auto;
  }
  .poem-beat[data-story-mode="portrait"],
  .poem-beat[data-story-mode="portrait"][data-layout] {
    min-height: auto;
    padding: clamp(3rem, 7vh, 5rem) 0;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] {
    min-height: 145vh;
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] {
    min-height: 152vh;
  }
  .poem-beat[data-story-mode="wide"][data-layout="radial-mask"],
  .poem-beat[data-story-mode="wide"][data-layout="anchor-single"],
  .poem-beat[data-story-mode="wide"][data-layout="vignette"],
  .poem-beat[data-story-mode="wide"][data-layout="overlap"],
  .poem-beat[data-story-mode="wide"][data-layout="reveal"],
  .poem-beat[data-story-mode="wide"][data-layout="wooden"],
  .poem-beat[data-story-mode="wide"][data-layout="pearl"] {
    min-height: 125vh;
  }

  /* ────────────────────────────────────────────────────────────── */
  /* sticky 100vh stage                                              */
  /*                                                                 */
  /* v1.60 P2 #1：baseline 改 flex column，让所有 layout 在 narrow      */
  /* (541-719) 段都能用 solver 输出的 size 变量自然居中堆叠；wide      */
  /* (≥720) 才让 parallax-pair / diagonal-gaze 切到 grid 重叠模式。  */
  /* 修掉 v1.59 "solver 给 1fr / CSS 仍 2fr" 的模式不一致。           */
  /* ────────────────────────────────────────────────────────────── */
  .poem-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
    padding: 2rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .poem-beat[data-story-mode="portrait"] .poem-stage {
    position: relative;
    top: auto;
    height: auto;
    min-height: auto;
    overflow: visible;
    padding-block: clamp(1.5rem, 4vh, 2.5rem);
  }

  /* sr-only 兜底 */
  .poem-stage :global(.sr-only) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ────────────────────────────────────────────────────────────── */
  /* 文字 baseline                                                    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-text {
    color: var(--c-olive-ink);
    font-weight: 300;
    font-size: 1.5rem;
    line-height: 1.85;
    text-align: center;
    width: 100%;
    max-width: var(--text-max-w);
  }
  .poem-text p {
    margin: 0.35em 0;
  }

  /* 移动端字号收一档 */
  @media (max-width: 540px) {
    .poem-text {
      font-size: 1.25rem;
      line-height: 1.7;
    }
  }

  /* ────────────────────────────────────────────────────────────── */
  /* 照片 baseline                                                    */
  /* ────────────────────────────────────────────────────────────── */
  .poem-photos {
    display: grid;
    gap: 1.25rem;
    width: 100%;
    grid-template-columns: 1fr;
  }
  .poem-photo {
    margin: 0;
    box-shadow: var(--shadow-paper);
    will-change: transform, opacity, filter;
  }
  .poem-photo :global(picture),
  .poem-photo :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = parallax-pair · beat 01                                 */
  /*                                                                  */
  /* photo size（all widths）：solver 输出的 --photo-far/near-w/h     */
  /*   narrow (541-719)：默认 flex column，photos 自然垂直堆叠         */
  /*   wide   (≥ 720)：grid 双列 + far/near 绝对定位重叠 + 入场 transform */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="parallax-pair"] .poem-photos {
    position: relative;
    width: min(var(--photos-col-w), 100%);
    height: var(--photos-col-h);
    max-width: 100%;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .poem-beat[data-layout="parallax-pair"] .poem-photo[data-role="far"] {
    position: absolute;
    top: 0;
    right: 4%;
    width: var(--photo-far-w);
    height: var(--photo-far-h);
    filter: saturate(0.92);
    transform: translateY(calc((1 - var(--p, 0)) * -8%))
      scale(calc(0.98 + var(--p, 0) * 0.02));
  }
  .poem-beat[data-layout="parallax-pair"] .poem-photo[data-role="near"] {
    position: absolute;
    bottom: 0;
    left: 4%;
    z-index: 1;
    width: var(--photo-near-w);
    height: var(--photo-near-h);
    transform: translateY(calc((1 - var(--p, 0)) * 8%))
      scale(calc(0.98 + var(--p, 0) * 0.02));
  }
  .poem-beat[data-story-mode="portrait"][data-layout="parallax-pair"]
    .poem-text {
    max-width: var(--text-max-w);
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-stage {
    display: grid;
    grid-template-columns: var(--stage-cols);
    align-items: center;
    justify-items: center;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-text {
    grid-column: 1;
    align-self: center;
    justify-self: end;
    text-align: left;
    max-width: var(--text-col-w);
    z-index: 2;
    transform: translateX(calc((1 - var(--p, 0)) * -8px));
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"] .poem-photos {
    grid-column: 2;
    position: relative;
    align-self: center;
    width: var(--photos-col-w);
    height: var(--photos-col-h);
    max-width: none;
    grid-template-columns: 1fr;
    gap: 0;
    z-index: 1;
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"]
    .poem-photo[data-role="far"] {
    position: absolute;
    top: 0;
    right: 0;
    transform: translateY(calc((1 - var(--p, 0)) * -14%))
      scale(calc(0.96 + var(--p, 0) * 0.04));
  }
  .poem-beat[data-story-mode="wide"][data-layout="parallax-pair"]
    .poem-photo[data-role="near"] {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 1;
    transform: translateY(calc((1 - var(--p, 0)) * 14%))
      scale(calc(0.96 + var(--p, 0) * 0.04));
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = diagonal-gaze · beat 02                                 */
  /*                                                                  */
  /* photo size（all widths）：solver 输出的 --photo-tl/br-w/h         */
  /*   narrow (541-719)：默认 flex column，tl-photo / text / br-photo  */
  /*     垂直堆叠；不再有 backdrop-blur / 对角错位                     */
  /*   wide   (≥ 720)：grid 单 cell stack + tl/br 角落绝对 + 中间文字   */
  /*     backdrop-blur(8px) 浮起 + 入场 translate                      */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="diagonal-gaze"] .poem-stage {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
  }
  .poem-beat[data-layout="diagonal-gaze"] .poem-text {
    grid-area: 1 / 1;
    align-self: center;
    justify-self: center;
    max-width: var(--text-max-w);
    text-align: center;
    z-index: 2;
    padding: 1rem 1.2rem;
    background: rgba(245, 240, 230, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-sm);
    transform: translateY(calc((1 - var(--p, 0)) * 6px));
  }
  .poem-beat[data-layout="diagonal-gaze"] .poem-photos {
    grid-area: 1 / 1;
    position: relative;
    width: 100%;
    height: var(--photos-col-h);
    grid-template-columns: 1fr;
    gap: 0;
    z-index: 1;
  }
  .poem-beat[data-layout="diagonal-gaze"] .poem-photo[data-role="top-left"] {
    position: absolute;
    top: 0;
    left: 6%;
    width: var(--photo-tl-w);
    height: var(--photo-tl-h);
    transform: translate(
      calc((1 - var(--p, 0)) * -9%),
      calc((1 - var(--p, 0)) * -9%)
    );
  }
  .poem-beat[data-layout="diagonal-gaze"]
    .poem-photo[data-role="bottom-right"] {
    position: absolute;
    bottom: 0;
    right: 6%;
    width: var(--photo-br-w);
    height: var(--photo-br-h);
    transform: translate(
      calc((1 - var(--p, 0)) * 9%),
      calc((1 - var(--p, 0)) * 9%)
    );
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-stage {
    padding: 0;
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-text {
    padding: 1.25rem 1.5rem;
    background: rgba(245, 240, 230, 0.7);
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"] .poem-photos {
    width: 100%;
    height: 100%;
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="top-left"] {
    top: 4%;
    left: 4%;
    transform: translate(
      calc((1 - var(--p, 0)) * -15%),
      calc((1 - var(--p, 0)) * -15%)
    );
  }
  .poem-beat[data-story-mode="wide"][data-layout="diagonal-gaze"]
    .poem-photo[data-role="bottom-right"] {
    bottom: 4%;
    right: 4%;
    transform: translate(
      calc((1 - var(--p, 0)) * 15%),
      calc((1 - var(--p, 0)) * 15%)
    );
  }

  /* ──────────────────────────────────────────────────────────────  */
  /* layout = radial-mask · beat 03                                   */
  /* solver 给 photo 单图尺寸；CSS 单 stage 紧凑居中堆叠              */
  /* ──────────────────────────────────────────────────────────────  */
  .poem-beat[data-layout="radial-mask"] .poem-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--stage-gap);
  }
  .poem-beat[data-layout="radial-mask"] .poem-photos {
    width: var(--photo-w);
    max-width: var(--photo-w);
  }
  .poem-beat[data-layout="radial-mask"] .poem-photo[data-role="center"] {
    width: var(--photo-w);
