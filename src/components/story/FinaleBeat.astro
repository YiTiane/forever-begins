---
/**
 * FinaleBeat.astro · §2.C 星空照片走马灯 · 包装 StarCarouselFinale React 岛
 *   v0.8（Phase 2 §2 batch 8 · finale single-source hold）
 *
 * 数据流（DESIGN §15.1 单一源）：
 *   - finale.lines 来自 main.json beat 12 (kind="finale")
 *   - 15 张照片序列 + CDN URL 来自 src/lib/story/finalePhotos.ts
 *   - JS-on normal 初始帧只显示星空，不放任何照片 fallback；Pearl_04 主海报只用于
 *     reduced/static、首张 texture 双 CDN 全败、以及 <noscript> fallback
 *
 * 渲染机制（v0.2 起）：
 *   - 外层 .finale-beat 给 hash 锚 #beat-12-heading（与 PoemBeat / GlobeBeat 同款契约）
 *   - 长 spacer ~700vh：给 15 张照片各 ~45vh 走完 lifecycle。React 岛在
 *     scrollable 前 96% 完成 progress=1，余下极短区间稳定 hold final Pearl_04。
 *   - 内层 .finale-stage 100vh sticky + 深邃午夜蓝 #06091a 背景（与 R3F clearColor +
 *     NightSkyBackground 一致）—— finale 使用独立的满天星辰夜空，不承接 §2.B
 *     GlobeDistanceScene 的视觉场
 *   - <StarCarouselFinale client:visible /> 仅视口内 hydrate；Canvas alpha=false 不透明。
 *     正常刷新首帧必须是纯星空，照片只能由 scroll-driven R3F timeline 带入
 *   - v1.95：显式给 .finale-canvas 内的 astro-island wrapper 100% 尺寸，避免
 *     client:visible 的 IntersectionObserver 看见 0 尺寸 custom element 而不 hydrate
 *   - <noscript> 内置同款 Pearl_04 + lines；JS fallback 仅在 html.js 时显示，
 *     避免 no-JS 下重复两张海报
 *   - motion tier 由 React 岛内部处理：full/lite 保留同一动画语义；static
 *     用于 reduced-motion / WebGL failure，保留 HTML fallback poster + 静态星空
 *   - v1.100 暂撤 FinaleLightbox 入口：右上角 overlay button 在实测中可能卡死，
 *     且设计价值待复审；主滚动叙事不再挂载该入口
 *   - v1.98 曾在 React timeline 后追加 aria-hidden 静态 end frame；v0.8 移除。
 *     最终 Pearl_04 现在只有 R3F final PhotoPlane 一个来源，避免继续滚动时
 *     主海报重复显示。
 *   - v1.99：移除 `.finale-stage` 的 100vmax box-shadow 铺底。该 shadow 会在
 *     sticky handoff 前提前穿透到上一个 Story/Globe 视口，导致 finale 星空遮挡
 *     beat 10/11；深色铺底改由 `.finale-beat` 自身背景和 R3F canvas 承担。
 *
 * v1.100 correction：撤销正常 JS-on fallback poster。初始首帧为纯星空；只有
 *   static/reduced 或首张 texture 双 CDN 全败才显 Pearl_04 fallback。
 *
 * a11y：
 *   - section aria-labelledby 指向 sr-only h3（与 PoemBeat / GlobeBeat 同款契约）
 *   - canvas 容器 role="img" + aria-label "走过的回忆 · 最终定格主海报"
 *   - shader dissolve 动画对 AT 不可见，AT 仍只读到 sr-only h3 + 浮卡 lines
 *
 * NOT in this batch（v0.7+ 留刀）：
 *   - 更高端的 GPU 粒子风场 / 轨迹拖尾（当前已是照片点阵破碎 + 持久星点
 *     twinkle；后续只做精修，不再作为基础缺口）
 *   - 文字 stagger / 节奏控制（poems lines 是定格静态，不随 progress 渐显）
 */
import { getCollection } from "astro:content";
import CdnImage from "@/components/CdnImage.astro";
import { StarCarouselFinale } from "@/components/story/StarCarouselFinale";

interface Props {
  /** main.json beat 12 的 lines（"还好我们有牢牢抱紧。" "幸好最终是你。"） */
  lines: readonly string[];
}

const { lines } = Astro.props;

// 校验 schema 数据可用（与 GlobeBeat 同款契约）
const storyEntries = await getCollection("storyPoem");
const main = storyEntries.find((e) => e.id === "main");
if (!main) {
  throw new Error(
    "FinaleBeat.astro: src/content/story-poem/main.json missing — schema 已严约束 12=finale",
  );
}
const finaleBeat = main.data.beats.find((b) => b.kind === "finale");
if (!finaleBeat) {
  throw new Error(
    "FinaleBeat.astro: schema 缺 finale beat（应是 beats[11].kind === 'finale'）",
  );
}

const headingId = "beat-12-heading";
const ariaHeadingId = "beat-12-aria-heading";

const ariaLabel = `走过的回忆 · 最终定格主海报：${(lines[0] ?? "还好我们有牢牢抱紧。").replace(/[，。]$/, "")}`;
---

<section
  class="finale-beat"
  id={headingId}
  data-beat-id="12"
  data-kind="finale"
  aria-labelledby={ariaHeadingId}
>
  <div class="finale-stage">
    <h3 id={ariaHeadingId} class="sr-only">
      第 12 段 · {lines[0]}
    </h3>

    <div class="finale-canvas" role="img" aria-label={ariaLabel}>
      {
        /* Phase 4 v1.100：JS-enabled normal 首帧只给星空，不放照片 fallback。
           Pearl_04 仅在 static/reduced 或首张 R3F texture 双 CDN 全败时出现。 */
      }
      <script is:inline>
        document.documentElement.classList.add("js");
      </script>
      <figure
        class="finale-fallback-photo finale-js-fallback finale-static-fallback"
        data-finale-static-fallback
        aria-hidden="true"
      >
        <CdnImage
          cdnTarget="pearl"
          stem="Pearl_04"
          alt=""
          priority="auto"
          widths={[320, 640, 1024, 1600, 2400]}
          sizes="(min-width: 960px) 480px, (min-width: 540px) 56vw, 80vw"
          width={2000}
          height={3000}
        />
      </figure>
      <script is:inline>
        (() => {
          const targetProgress = 0;
          const canvasShell = document.querySelector(".finale-canvas");
          let firstFrameReady = Boolean(window.__finaleFirstFrameReady);
          let forcedStaticFallback = false;
          function handleFirstFrameReady() {
            firstFrameReady = true;
            forcedStaticFallback = false;
            syncFallbackMode();
          }
          function prefersStaticFallback() {
            return Boolean(
              window.matchMedia?.("(prefers-reduced-motion: reduce)").matches,
            );
          }
          function syncFallbackMode() {
            const root = document.querySelector(".finale-canvas-root");
            const isStatic =
              root?.getAttribute("data-motion-tier") === "static" ||
              prefersStaticFallback();
            canvasShell?.classList.toggle(
              "is-static-fallback",
              Boolean(isStatic || forcedStaticFallback),
            );
          }
          window.addEventListener(
            "finale:first-frame-ready",
            handleFirstFrameReady,
            { once: true },
          );
          window.addEventListener("finale:texture-failed", (event) => {
            const detail = event.detail || {};
            if (!firstFrameReady && detail.stem === "Grassland_01") {
              forcedStaticFallback = true;
              syncFallbackMode();
            }
          });
          window
            .matchMedia?.("(prefers-reduced-motion: reduce)")
            .addEventListener?.("change", syncFallbackMode);
          if (window.__finaleFirstFrameReady) handleFirstFrameReady();
          const fallbackObserver = new MutationObserver(syncFallbackMode);
          fallbackObserver.observe(document.documentElement, {
            childList: true,
            subtree: true,
            attributes: true,
            attributeFilter: ["data-motion-tier"],
          });
          syncFallbackMode();

          function alignFinaleHash() {
            if (window.location.hash !== "#beat-12-heading") return;
            const beat = document.getElementById("beat-12-heading");
            if (!beat) return;
            beat.dataset.initialProgress = String(targetProgress);
            window.__finaleInitialProgress = targetProgress;
            const publish = () => {
              const root = document.querySelector(".finale-canvas-root");
              if (root) {
                if (root.getAttribute("data-motion-tier") === "static") {
                  syncFallbackMode();
                  root.setAttribute("data-progress", "1.000");
                  root.setAttribute("data-current-index", "14");
                  return;
                }
                root.setAttribute("data-progress", targetProgress.toFixed(3));
              }
              window.dispatchEvent(
                new CustomEvent("finale:set-progress", {
                  detail: { progress: targetProgress },
                }),
              );
            };
            const rect = beat.getBoundingClientRect();
            const absoluteTop = window.scrollY + rect.top;
            const vh = window.innerHeight || 1;
            const scrollable = Math.max(0, beat.offsetHeight - vh);
            const top =
              scrollable > 0
                ? absoluteTop + scrollable * targetProgress
                : absoluteTop;
            window.scrollTo({ top: Math.max(0, top), behavior: "auto" });
            publish();
            window.requestAnimationFrame(publish);
            window.setTimeout(publish, 250);
            window.setTimeout(publish, 1000);
          }
          alignFinaleHash();
          window.addEventListener("hashchange", () => {
            window.requestAnimationFrame(alignFinaleHash);
          });
        })();
      </script>
      <StarCarouselFinale client:visible />
    </div>

    <div class="finale-text">
      <p class="finale-line cn-kaishu">
        {lines.map((line) => <span class="finale-text-line">{line}</span>)}
      </p>
    </div>

    <noscript>
      <figure class="finale-fallback-photo">
        <CdnImage
          cdnTarget="pearl"
          stem="Pearl_04"
          alt="珍珠系列主海报 · 两个人相拥"
          priority="auto"
          widths={[320, 640, 1024, 1600, 2400]}
          sizes="(min-width: 960px) 480px, (min-width: 540px) 56vw, 80vw"
          width={2000}
          height={3000}
        />
      </figure>
      <p class="finale-noscript">{lines.join(" ")}</p>
    </noscript>
  </div>
</section>

<style>
  .finale-beat {
    position: relative;
    scroll-margin-top: 0;
    background: #06091a;
    padding-bottom: 3rem;
    /* 15 张照片 × ~45vh per lifecycle = ~700vh 滚动空间。React 岛在前 96%
       完成 timeline，末尾仅保留一小段 Pearl_04 主海报 hold；不再额外追加
       静态 end-frame，避免最后一张重复显示。 */
    min-height: 720vh;
  }

  /* v1.94：stage 背景保持 #06091a 深邃午夜蓝；R3F 内再叠独立夜空
     shader + 星尘点云，避免把 finale 设计误绑定到 §2.B globe 场景 */
  .finale-stage {
    position: sticky;
    top: 0;
    height: calc(100vh + 3rem);
    height: calc(100dvh + 3rem);
    min-height: calc(100vh + 3rem);
    min-height: calc(100dvh + 3rem);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr auto;
    justify-items: center;
    align-items: stretch;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.5rem 1.25rem;
    gap: 1rem;
    box-sizing: border-box;
    background: #06091a;
    z-index: 2;
  }

  .finale-stage .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .finale-canvas {
    width: 100%;
    height: 100%;
    min-height: 0;
    position: relative; /* 给 fallback 与 React 岛叠层用 */
    background:
      radial-gradient(
          circle at 18% 22%,
          rgba(255, 255, 255, 0.7) 0 1px,
          transparent 1.7px
        )
        0 0 / 13rem 11rem,
      radial-gradient(
          circle at 76% 38%,
          rgba(255, 244, 207, 0.62) 0 1.2px,
          transparent 2px
        )
        0 0 / 19rem 17rem,
      radial-gradient(
          circle at 42% 78%,
          rgba(205, 224, 255, 0.48) 0 0.8px,
          transparent 1.6px
        )
        0 0 / 15rem 21rem,
      #06091a;
  }

  .finale-canvas :global(astro-island) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* fallback 海报：JS-on 时作为 WebGL/texture failure fallback；no-JS 时由
     <noscript> 同款结构接住。 */
  .finale-fallback-photo {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .finale-fallback-photo :global(picture),
  .finale-fallback-photo :global(img) {
    max-width: min(420px, 70%);
    max-height: 80%;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  .finale-js-fallback {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    opacity: 1;
    transition:
      opacity 420ms ease,
      visibility 420ms ease;
  }
  :global(html.js) .finale-js-fallback {
    display: flex;
  }
  .finale-js-fallback.is-hidden {
    opacity: 0;
    visibility: hidden;
  }
  .finale-canvas .finale-static-fallback {
    display: none;
  }
  :global(html.js) .finale-canvas.is-static-fallback .finale-static-fallback {
    display: flex;
  }

  /* React 岛根：真实 R3F canvas；正常首帧只显示星空。Pearl_04 fallback
     仅在 static/reduced 或首张 texture 双 CDN 全败时由 is-static-fallback 打开。 */
  .finale-canvas :global(.finale-canvas-root) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
  }
  .finale-canvas :global(.finale-canvas-root canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  /* v0.2：stage 改深色后，文字浮卡 alpha 0.62→0.88 让 paper 浮卡在夜空 stage 上
     仍清晰可读；color 保持 --c-olive-ink 让文字在浅纸面上不刺眼 */
  .finale-text {
    width: min(420px, 86%);
    padding: 0.85rem 1.25rem;
    text-align: center;
    color: var(--c-olive-ink);
    background: rgba(245, 240, 230, 0.88);
    border-radius: var(--radius-sm);
    transform: translateY(-3rem);
    z-index: 5;
  }
  .finale-line {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.85;
    font-weight: 300;
  }
  .finale-text-line {
    display: block;
  }

  .finale-noscript {
    grid-column: 1;
    grid-row: 1 / -1;
    align-self: end;
    color: var(--c-olive-ink);
    text-align: center;
    z-index: 3;
  }

  /* portrait（小平板 / 大手机竖屏）：释放 sticky；走马灯改为单屏走完 */
  @media (max-width: 899px) {
    .finale-beat {
      min-height: 500vh; /* 仍给 15 张足够 spacer */
    }
    .finale-stage {
      padding: 1rem 1rem 0.75rem;
    }
  }

  /* compact（≤540 phone）：进一步压缩 spacer */
  @media (max-width: 540px) {
    .finale-beat {
      min-height: 380vh;
    }
    .finale-stage {
      padding: 0.75rem 0.75rem 0.5rem;
      gap: 0.5rem;
    }
    .finale-line {
      font-size: 1.05rem;
      line-height: 1.7;
    }
  }
</style>
