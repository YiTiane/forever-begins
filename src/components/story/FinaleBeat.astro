---
/**
 * FinaleBeat.astro · §2.C 静态星空终章（Vercel static edition）
 *
 * Vercel 专用版本不再加载 StarCarouselFinale / React / R3F：
 *   - 背景是静态午夜蓝星空；
 *   - 只显示最终主海报 pearl/Pearl_04；
 *   - 保留 finale.lines 两句文案；
 *   - 图片经 CdnImage 输出全套 AVIF/WebP/JPG srcset，且 CdnImage 在本分支
 *     已全局 eager，刷新页面时立即进入加载队列。
 */
import { getCollection } from "astro:content";
import CdnImage from "@/components/CdnImage.astro";

interface Props {
  /** main.json beat 12 的 lines（"还好我们有牢牢抱紧。" "幸好最终是你。"） */
  lines: readonly string[];
}

const { lines } = Astro.props;

const storyEntries = await getCollection("storyPoem");
const main = storyEntries.find((e) => e.id === "main");
if (!main) {
  throw new Error(
    "FinaleBeat.astro: src/content/story-poem/main.json missing — check content collection state",
  );
}
const finaleBeat = main.data.beats.find((b) => b.kind === "finale");
if (!finaleBeat) {
  throw new Error(
    "FinaleBeat.astro: schema 缺 finale beat（应是 beats[11].kind === 'finale'）",
  );
}

const headingId = "beat-12-heading";
const ariaHeadingId = "beat-12-aria-heading";
const ariaLabel = `最终主海报：${(lines[0] ?? "还好我们有牢牢抱紧。").replace(/[，。]$/, "")}`;
---

<section
  class="finale-beat"
  id={headingId}
  data-beat-id="12"
  data-kind="finale"
  data-motion-tier="static"
  data-motion-reason="vercel-static"
  aria-labelledby={ariaHeadingId}
>
  <div class="finale-stage">
    <h3 id={ariaHeadingId} class="sr-only">
      第 12 段 · {lines[0]}
    </h3>

    <div class="finale-sky" role="img" aria-label={ariaLabel}>
      <figure class="finale-poster">
        <CdnImage
          cdnTarget="pearl"
          stem="Pearl_04"
          alt="珍珠系列主海报 · 两个人相拥"
          priority="high"
          widths={[320, 640, 1024, 1600, 2400]}
          sizes="(min-width: 960px) 460px, (min-width: 540px) 56vw, 82vw"
          width={2000}
          height={3000}
        />
      </figure>
    </div>

    <div class="finale-text">
      <p class="finale-line cn-kaishu">
        {lines.map((line) => <span class="finale-text-line">{line}</span>)}
      </p>
    </div>
  </div>
</section>

<style>
  .finale-beat {
    position: relative;
    scroll-margin-top: 0;
    background: #06091a;
    min-height: 100vh;
    color: var(--c-olive-ink);
  }

  .finale-stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: clamp(0.75rem, 2vh, 1.25rem);
    align-items: stretch;
    justify-items: center;
    width: min(100%, 1280px);
    margin: 0 auto;
    padding: clamp(1rem, 3vh, 2rem) 1.5rem clamp(1rem, 3vh, 1.75rem);
    box-sizing: border-box;
    background:
      radial-gradient(
        circle at 50% 18%,
        rgba(255, 246, 212, 0.08),
        transparent 32%
      ),
      #06091a;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .finale-sky {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: min(72vh, 720px);
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background:
      radial-gradient(
          circle at 13% 20%,
          rgba(255, 255, 255, 0.82) 0 1px,
          transparent 1.8px
        )
        0 0 / 9rem 11rem,
      radial-gradient(
          circle at 78% 30%,
          rgba(255, 232, 170, 0.78) 0 1.3px,
          transparent 2.2px
        )
        0 0 / 15rem 13rem,
      radial-gradient(
          circle at 44% 74%,
          rgba(201, 220, 255, 0.62) 0 0.9px,
          transparent 1.8px
        )
        0 0 / 12rem 17rem,
      radial-gradient(
        circle at 50% 42%,
        rgba(35, 45, 88, 0.62),
        transparent 54%
      ),
      linear-gradient(180deg, #080b22 0%, #040613 72%, #03030a 100%);
    box-shadow:
      inset 0 0 5rem rgba(0, 0, 0, 0.32),
      0 1.4rem 3rem rgba(6, 9, 26, 0.22);
  }

  .finale-poster {
    position: relative;
    z-index: 1;
    margin: 0;
    width: min(460px, 56vw);
    max-height: 86%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .finale-poster::before {
    content: "";
    position: absolute;
    inset: -0.85rem;
    border-radius: calc(var(--radius-sm) + 0.85rem);
    background: radial-gradient(
      circle,
      rgba(255, 237, 180, 0.18),
      transparent 68%
    );
    z-index: -1;
  }

  .finale-poster :global(picture),
  .finale-poster :global(img) {
    display: block;
    width: 100%;
    height: auto;
    max-height: min(76vh, 720px);
    object-fit: contain;
    border-radius: var(--radius-sm);
    box-shadow: 0 1.2rem 2.4rem rgba(0, 0, 0, 0.36);
  }

  .finale-text {
    width: min(420px, 86%);
    padding: 0.85rem 1.25rem;
    text-align: center;
    color: var(--c-olive-ink);
    background: rgba(245, 240, 230, 0.9);
    border-radius: var(--radius-sm);
  }

  .finale-line {
    margin: 0;
    font-size: calc(1.25rem + 3px);
    line-height: 1.85;
    font-weight: 300;
  }

  .finale-text-line {
    display: block;
  }

  @media (max-width: 899px) {
    .finale-stage {
      padding: 1rem;
    }

    .finale-sky {
      min-height: min(66vh, 620px);
    }

    .finale-poster {
      width: min(420px, 68vw);
    }
  }

  @media (max-width: 540px) {
    .finale-stage {
      gap: 0.75rem;
      padding: 0.75rem;
    }

    .finale-sky {
      min-height: 62vh;
    }

    .finale-poster {
      width: min(340px, 82vw);
    }

    .finale-line {
      font-size: calc(1.05rem + 3px);
      line-height: 1.7;
    }
  }
</style>
