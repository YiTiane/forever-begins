---
/**
 * Details.astro · Phase 6 这一天
 *
 * Astro-only 婚礼详情区：日期 / 时间 / 地点、静态地图、日历入口、联系新人。
 * 地图导航采用 POI 优先：国内地图优先用场地名和地址搜索；坐标只作兜底。
 * 本组件不加入 RSVP 文案，不展示微信号。
 */
import { getCollection } from "astro:content";
import DetailsMap from "@/components/details/DetailsMap.astro";
import SoftRSVP from "@/components/details/SoftRSVP.astro";

const metaEntries = await getCollection("meta");
const wedding = metaEntries.find((entry) => entry.id === "wedding");

if (!wedding) {
  throw new Error("Details.astro: src/content/meta/wedding.json missing");
}

const venue = wedding.data.venue;
const contact = wedding.data.contact;
const calendarPath = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/calendar/wedding-2026-06-14.ics`;

const encodedVenueName = encodeURIComponent(venue.cn_short);
const encodedVenueAddress = encodeURIComponent(venue.address_cn);
const encodedVenueQuery = encodeURIComponent(
  `${venue.cn_short} ${venue.address_cn}`,
);
const encodedVenueEn = encodeURIComponent(venue.address_en);
const coords = venue.coords;
const wgs = coords.wgs84;
const gcj = coords.gcj02;
const bd = coords.bd09;
const hasGcj = Number.isFinite(gcj.lng) && Number.isFinite(gcj.lat);
const hasBd = Number.isFinite(bd.lng) && Number.isFinite(bd.lat);

const mapLinks = [
  {
    provider: "amap" as const,
    label: "高德地图",
    href: hasGcj
      ? `https://uri.amap.com/marker?position=${gcj.lng},${gcj.lat}&name=${encodedVenueName}&src=forever-begins`
      : `https://uri.amap.com/search?keyword=${encodedVenueQuery}&src=forever-begins`,
  },
  {
    provider: "baidu" as const,
    label: "百度地图",
    href: hasBd
      ? `https://api.map.baidu.com/marker?location=${bd.lat},${bd.lng}&title=${encodedVenueName}&content=${encodedVenueAddress}&coord_type=bd09ll&output=html&src=forever-begins`
      : `https://map.baidu.com/search/${encodedVenueAddress}`,
  },
  {
    provider: "apple" as const,
    label: "Apple 地图",
    href: `https://maps.apple.com/?q=${encodedVenueEn}&ll=${wgs.lat},${wgs.lng}`,
  },
  {
    provider: "google" as const,
    label: "Google Maps",
    href: `https://www.google.com/maps/search/?api=1&query=${wgs.lat},${wgs.lng}`,
  },
];

const googleCalendarParams = new URLSearchParams({
  action: "TEMPLATE",
  text: "杨倚天与希尔娜依的婚礼",
  dates: "20260614T110000Z/20260614T150000Z",
  ctz: "Asia/Shanghai",
  location: venue.address_cn,
  details:
    "我们无法判断一个瞬间的价值，直至它变成回忆。愿有岁月可回首，且以深情共白头。",
});

const infoItems = [
  { label: "日期", value: "二〇二六年六月十四日", sub: "星期日" },
  { label: "时间", value: "晚七点", sub: "19:00–23:00" },
  { label: "地点", value: venue.cn_short, sub: venue.address_cn },
];
---

<section
  id="the-day"
  class="details-section"
  data-nav-section
  aria-labelledby="the-day-heading"
>
  <div class="details-inner">
    <h2 id="the-day-heading" class="details-title cn-kaishu details-reveal">
      这一天
    </h2>
    <p class="details-quote cn-song details-reveal">
      花径不曾缘客扫，蓬门今始为君开。
    </p>

    <div class="details-info-grid details-reveal" aria-label="婚礼信息">
      {
        infoItems.map((item) => (
          <article class="details-info-card">
            <p class="details-info-label latin-ui">{item.label}</p>
            <p class="details-info-value cn-kaishu">{item.value}</p>
            <p class="details-info-sub cn-song">{item.sub}</p>
          </article>
        ))
      }
    </div>

    <div class="details-map-wrap details-reveal">
      <DetailsMap venue={venue} mapLinks={mapLinks} />
    </div>

    <div class="details-actions details-reveal">
      <div class="details-action-group map-link-group" data-map-link-group>
        {
          mapLinks.map((link) => (
            <a
              class="details-action"
              data-map-provider={link.provider}
              href={link.href}
              target="_blank"
              rel="noreferrer"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="details-action-group calendar-link-group">
        <a
          class="details-action details-action-primary"
          href={calendarPath}
          download
        >
          添加日历
        </a>
        <a
          class="details-action"
          href={`https://calendar.google.com/calendar/render?${googleCalendarParams.toString()}`}
          target="_blank"
          rel="noreferrer"
        >
          Google Calendar
        </a>
      </div>
    </div>

    <div class="details-contact details-reveal">
      <SoftRSVP contact={contact} />
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector(".details-section");
    if (!(root instanceof HTMLElement)) return;

    const language = navigator.language || "";
    const preferred = language.toLowerCase().startsWith("zh")
      ? ["amap", "baidu", "apple", "google"]
      : ["google", "apple", "amap", "baidu"];

    root.querySelectorAll("[data-map-provider]").forEach((link) => {
      if (!(link instanceof HTMLElement)) return;
      const index = preferred.indexOf(link.dataset.mapProvider || "");
      link.style.order = String(index === -1 ? preferred.length : index);
    });

    const revealItems = root.querySelectorAll(".details-reveal");
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      revealItems.forEach((item) => item.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.18 },
    );

    revealItems.forEach((item) => observer.observe(item));
  })();
</script>

<style>
  .details-section {
    position: relative;
    isolation: isolate;
    padding-block: clamp(5.5rem, 11vh, 8rem) clamp(4.5rem, 9vh, 7rem);
    padding-inline: max(var(--page-padding, 1rem), 1rem);
    background:
      radial-gradient(
        circle at 16% 12%,
        rgba(230, 199, 107, 0.16),
        transparent 32%
      ),
      linear-gradient(
        180deg,
        color-mix(in oklch, var(--c-paper) 92%, white) 0%,
        var(--c-paper) 52%,
        color-mix(in oklch, var(--c-ivory) 88%, var(--c-paper)) 100%
      );
    color: var(--c-olive-ink);
  }

  .details-inner {
    width: min(100%, 1120px);
    margin: 0 auto;
  }

  .details-title {
    margin: 0;
    color: var(--c-sage-deep);
    font-size: var(--text-title-lg);
    line-height: var(--leading-cn-tight);
    letter-spacing: 0;
  }

  .details-quote {
    max-width: 42rem;
    margin: 1rem 0 0;
    color: var(--c-olive-ink);
    font-size: var(--text-title-sm);
    line-height: var(--leading-cn);
  }

  .details-info-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.75rem, 2vw, 1rem);
    margin-top: clamp(2rem, 5vh, 3rem);
  }

  .details-info-card {
    min-height: 9rem;
    padding: 1.25rem;
    border: 1px solid color-mix(in oklch, var(--c-honey) 28%, transparent);
    border-radius: var(--radius-md);
    background: color-mix(in oklch, var(--c-paper) 86%, white);
    box-shadow: var(--shadow-paper);
  }

  .details-info-label {
    margin: 0 0 0.8rem;
    color: var(--c-sage);
    font-size: var(--text-meta);
    letter-spacing: 0;
  }

  .details-info-value {
    margin: 0;
    color: var(--c-sage-deep);
    font-size: var(--text-title-md);
    line-height: var(--leading-cn-tight);
  }

  .details-info-sub {
    margin: 0.7rem 0 0;
    color: color-mix(in oklch, var(--c-olive-ink) 82%, var(--c-sage));
    font-size: var(--text-body);
    line-height: var(--leading-cn);
  }

  .details-map-wrap {
    margin-top: clamp(1.25rem, 3vw, 2rem);
  }

  .details-actions {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .details-action-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .details-action {
    display: inline-flex;
    min-height: 2.7rem;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in oklch, var(--c-sage) 34%, transparent);
    border-radius: var(--radius-pill);
    padding: 0.62rem 0.95rem;
    background: color-mix(in oklch, var(--c-paper) 84%, white);
    color: var(--c-sage-deep);
    font-family: var(--font-cn-sans);
    font-size: var(--text-caption);
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 6px 18px -14px
      color-mix(in oklch, var(--c-ink) 28%, transparent);
    transition:
      border-color 180ms var(--ease-paper),
      background 180ms var(--ease-paper),
      transform 180ms var(--ease-paper);
  }

  .details-action-primary {
    border-color: color-mix(in oklch, var(--c-honey) 54%, var(--c-sage));
    background: color-mix(in oklch, var(--c-mimosa) 16%, var(--c-paper));
  }

  .details-action:hover {
    border-color: color-mix(in oklch, var(--c-honey) 58%, var(--c-sage));
    background: color-mix(in oklch, var(--c-mimosa) 12%, var(--c-paper));
    transform: translateY(-1px);
  }

  .details-contact {
    margin-top: clamp(1.6rem, 4vh, 2.4rem);
  }

  .details-reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 520ms var(--ease-paper),
      transform 620ms var(--ease-paper);
  }

  .details-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 820px) {
    .details-info-grid,
    .details-actions {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 539px) {
    .details-section {
      padding-top: 4.5rem;
    }

    .details-info-card {
      min-height: 0;
      padding: 1rem;
    }

    .details-action,
    .details-action-group {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .details-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .details-action {
      transition: none;
    }

    .details-action:hover {
      transform: none;
    }
  }
</style>
