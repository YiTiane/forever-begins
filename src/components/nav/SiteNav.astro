---
/**
 * SiteNav.astro · Phase 6 全局导航与滚动进度
 *
 * 固定导航只在首屏之后出现；桌面右上极简菜单，移动端右下浮点菜单。
 * 左侧 1px progress rail 反映整页阅读进度；active section 由 viewport 中线计算。
 */

const links = [
  { id: "cover", label: "邀请" },
  { id: "invitation", label: "序章" },
  { id: "story", label: "故事" },
  { id: "family", label: "彩蛋" },
  { id: "the-day", label: "这一天" },
  { id: "closing", label: "落款" },
];
---

<div class="scroll-rail" aria-hidden="true">
  <span class="scroll-rail-fill" data-scroll-rail-fill></span>
</div>

<nav class="site-nav" data-site-nav aria-label="页面导航">
  <div class="site-nav-desktop">
    {
      links.map((link) => (
        <a href={`#${link.id}`} data-nav-link={link.id}>
          {link.label}
        </a>
      ))
    }
  </div>

  <div class="site-nav-mobile">
    <button
      class="site-nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav-mobile-panel"
      data-nav-toggle
    >
      <span aria-hidden="true">≡</span>
      <span class="sr-only">打开导航</span>
    </button>
    <div
      class="site-nav-mobile-panel"
      id="site-nav-mobile-panel"
      data-nav-panel
      hidden
    >
      {
        links.map((link) => (
          <a href={`#${link.id}`} data-nav-link={link.id}>
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  (() => {
    const nav = document.querySelector("[data-site-nav]");
    const fill = document.querySelector("[data-scroll-rail-fill]");
    const toggle = document.querySelector("[data-nav-toggle]");
    const panel = document.querySelector("[data-nav-panel]");
    const sections = Array.from(
      document.querySelectorAll("[data-nav-section]"),
    ).filter((section) => section instanceof HTMLElement && section.id);
    const links = Array.from(
      document.querySelectorAll("[data-nav-link]"),
    ).filter((link) => link instanceof HTMLAnchorElement);

    if (!(nav instanceof HTMLElement) || !(fill instanceof HTMLElement)) return;

    let currentId = "";
    let raf = 0;

    const setActive = (id) => {
      if (!id || id === currentId) return;
      currentId = id;
      links.forEach((link) => {
        const isActive = link.dataset.navLink === id;
        link.toggleAttribute("aria-current", isActive);
      });
      const targetHash = `#${id}`;
      if (
        window.location.hash !== targetHash &&
        window.scrollY > window.innerHeight * 0.5
      ) {
        history.replaceState(
          null,
          "",
          `${window.location.pathname}${window.location.search}${targetHash}`,
        );
      }
    };

    const update = () => {
      raf = 0;
      const scrollable = Math.max(
        1,
        document.documentElement.scrollHeight - window.innerHeight,
      );
      const progress = Math.min(1, Math.max(0, window.scrollY / scrollable));
      fill.style.transform = `scaleY(${progress.toFixed(4)})`;
      nav.classList.toggle(
        "is-visible",
        window.scrollY > window.innerHeight * 0.72,
      );

      const anchorY = window.innerHeight * 0.45;
      let best = sections[0];
      let bestDistance = Number.POSITIVE_INFINITY;
      sections.forEach((section) => {
        if (!(section instanceof HTMLElement)) return;
        const rect = section.getBoundingClientRect();
        const distance =
          rect.top <= anchorY && rect.bottom >= anchorY
            ? 0
            : Math.min(
                Math.abs(rect.top - anchorY),
                Math.abs(rect.bottom - anchorY),
              );
        if (distance < bestDistance) {
          bestDistance = distance;
          best = section;
        }
      });
      if (best instanceof HTMLElement) setActive(best.id);
    };

    const requestUpdate = () => {
      if (raf) return;
      raf = window.requestAnimationFrame(update);
    };

    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    requestUpdate();

    if (toggle instanceof HTMLButtonElement && panel instanceof HTMLElement) {
      const closePanel = () => {
        panel.hidden = true;
        toggle.setAttribute("aria-expanded", "false");
      };
      toggle.addEventListener("click", () => {
        const nextOpen = panel.hidden;
        panel.hidden = !nextOpen;
        toggle.setAttribute("aria-expanded", String(nextOpen));
      });
      links.forEach((link) => {
        link.addEventListener("click", closePanel);
      });
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closePanel();
      });
    }
  })();
</script>

<style>
  .scroll-rail {
    position: fixed;
    top: 0;
    left: 0;
    width: 1px;
    height: 100vh;
    background: color-mix(in oklch, var(--c-sage) 18%, transparent);
    z-index: 80;
    pointer-events: none;
  }

  .scroll-rail-fill {
    display: block;
    width: 100%;
    height: 100%;
    transform: scaleY(0);
    transform-origin: top;
    background: color-mix(in oklch, var(--c-honey) 70%, var(--c-sage));
  }

  .site-nav {
    position: fixed;
    z-index: 90;
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms var(--ease-paper);
  }

  .site-nav.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .site-nav-desktop {
    position: fixed;
    top: 1rem;
    right: 1rem;
    display: flex;
    gap: 0.35rem;
    padding: 0.35rem;
    border: 1px solid color-mix(in oklch, var(--c-sage) 22%, transparent);
    border-radius: var(--radius-pill);
    background: color-mix(in oklch, var(--c-paper) 82%, white);
    box-shadow: var(--shadow-paper);
    backdrop-filter: blur(10px);
  }

  .site-nav a {
    display: inline-flex;
    min-height: 2.1rem;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    padding: 0.45rem 0.72rem;
    color: var(--c-sage-deep);
    font-family: var(--font-cn-sans);
    font-size: var(--text-meta);
    line-height: 1;
    text-decoration: none;
    transition:
      background 160ms var(--ease-paper),
      color 160ms var(--ease-paper);
  }

  .site-nav a[aria-current="true"] {
    background: color-mix(in oklch, var(--c-honey) 22%, var(--c-paper));
    color: var(--c-olive-ink);
  }

  .site-nav-mobile {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .site-nav-desktop {
      display: none;
    }

    .site-nav-mobile {
      position: fixed;
      right: 1rem;
      bottom: 1rem;
      display: block;
    }

    .site-nav-toggle {
      display: grid;
      width: 3rem;
      height: 3rem;
      place-items: center;
      border: 1px solid color-mix(in oklch, var(--c-sage) 24%, transparent);
      border-radius: var(--radius-pill);
      background: color-mix(in oklch, var(--c-paper) 86%, white);
      color: var(--c-sage-deep);
      box-shadow: var(--shadow-paper);
      font: inherit;
      cursor: pointer;
      backdrop-filter: blur(10px);
    }

    .site-nav-mobile-panel {
      position: absolute;
      right: 0;
      bottom: 3.45rem;
      display: grid;
      min-width: 8.5rem;
      gap: 0.25rem;
      padding: 0.45rem;
      border: 1px solid color-mix(in oklch, var(--c-sage) 22%, transparent);
      border-radius: var(--radius-md);
      background: color-mix(in oklch, var(--c-paper) 90%, white);
      box-shadow: var(--shadow-card);
      backdrop-filter: blur(10px);
    }

    .site-nav-mobile-panel[hidden] {
      display: none;
    }

    .site-nav a {
      justify-content: flex-start;
      min-height: 2.3rem;
      padding-inline: 0.85rem;
      font-size: var(--text-caption);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav,
    .site-nav a {
      transition: none;
    }
  }
</style>
